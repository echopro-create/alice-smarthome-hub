---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import CookieConsent from "../components/CookieConsent.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";

interface Props {
	title: string;
	description: string;
	image?: string;
	jsonLd?: string;
	noindex?: boolean;
}

const { title, description, image = "/og-image.png", jsonLd, noindex = false } = Astro.props;

const host = (Astro.site?.href || "https://smart-hub.info").replace(/\/$/, "");
const cleanPath = Astro.url.pathname.replace(/\/$/, "");
const canonicalURLString = cleanPath === "" ? `${host}/` : `${host}${cleanPath.toLowerCase()}`;
---

<!doctype html>
<html lang="ru">
	<head>
		<!-- Global Metadata -->
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="32x32" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="generator" content={Astro.generator} />

		<!-- View Transitions -->
		<ClientRouter />

		<!-- Theme Initialization Script to avoid FOUC -->
		<script is:inline>
			const theme = (() => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
					return 'dark';
				}
				return 'light';
			})();
			
			if (theme === 'dark') {
				document.documentElement.classList.add('dark');
			} else {
				document.documentElement.classList.remove('dark');
			}
		</script>

		<link rel="dns-prefetch" href="https://yastatic.net" />

		<!-- Self-hosted Fonts Preload (critical render path) -->
		<link rel="preload" href="/fonts/inter-cyrillic-wght-normal.woff2" as="font" type="font/woff2" crossorigin />
		<link rel="preload" href="/fonts/inter-latin-wght-normal.woff2" as="font" type="font/woff2" crossorigin />
		<link rel="preload" href="/fonts/outfit-latin-wght-normal.woff2" as="font" type="font/woff2" crossorigin />
		<style is:inline>
			/* Inter — Cyrillic + Latin subsets (Variable) */
			@font-face {
				font-family: 'Inter';
				font-style: normal;
				font-weight: 100 900;
				font-display: swap;
				src: url('/fonts/inter-cyrillic-wght-normal.woff2') format('woff2-variations'),
				     url('/fonts/inter-cyrillic-wght-normal.woff2') format('woff2');
				unicode-range: U+0301, U+0400-045F, U+0490-0491, U+04B0-04B1, U+2116;
			}
			@font-face {
				font-family: 'Inter';
				font-style: normal;
				font-weight: 100 900;
				font-display: swap;
				src: url('/fonts/inter-latin-wght-normal.woff2') format('woff2-variations'),
				     url('/fonts/inter-latin-wght-normal.woff2') format('woff2');
				unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+2000-206F, U+2074, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
			}

			/* Outfit — Latin subset (Variable) */
			@font-face {
				font-family: 'Outfit';
				font-style: normal;
				font-weight: 100 900;
				font-display: swap;
				src: url('/fonts/outfit-latin-wght-normal.woff2') format('woff2-variations'),
				     url('/fonts/outfit-latin-wght-normal.woff2') format('woff2');
				unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+2000-206F, U+2074, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
			}
		</style>

		<!-- Canonical URL -->
		<link rel="canonical" href={canonicalURLString} />

		<!-- Localization Hreflang -->
		<link rel="alternate" hreflang="ru" href={canonicalURLString} />
		<link rel="alternate" hreflang="x-default" href={canonicalURLString} />

		<!-- Primary Meta Tags -->
		<title>{title} | Умный Дом с Алисой</title>
		<meta name="title" content={`${title} | Умный Дом с Алисой`} />
		<meta name="description" content={description} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={`${title} | Умный Дом с Алисой`} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(image, Astro.url)} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={Astro.url} />
		<meta name="twitter:title" content={`${title} | Умный Дом с Алисой`} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={new URL(image, Astro.url)} />

		<!-- JSON-LD Structured Data: Organization + WebSite (every page) -->
		<script type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "Organization",
				"name": "Умный Дом с Алисой",
				"url": "https://smart-hub.info",
				"logo": "https://smart-hub.info/favicon.svg",
				"email": "hello@smart-hub.info",
				"description": "Библиотека пошаговых сценариев и руководств по траблшутингу для Умного Дома с Алисой"
			}
		</script>
		<script type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "WebSite",
				"name": "Умный Дом с Алисой",
				"url": "https://smart-hub.info"
			}
		</script>

		<!-- JSON-LD: Page-specific structured data (BreadcrumbList, HowTo, TechArticle) -->
		{jsonLd && <script type="application/ld+json" set:html={jsonLd} />}

		<!-- Google Fonts for premium typography -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,200..800&family=Space+Grotesk:wght@300..700&display=swap" rel="stylesheet" />
		{noindex && <meta name="robots" content="noindex, follow" />}
	</head>
	<body>
		<!-- Cursor follower element -->
		<div class="cursor-glow" id="cursor-glow" aria-hidden="true"></div>

		<a href="#main-content" class="skip-link">Перейти к содержанию</a>
		
		<!-- Noise overlay for premium 2026 textured aesthetics -->
		<div class="noise-overlay" aria-hidden="true"></div>
		<svg style="display: none;" aria-hidden="true">
			<filter id="noise">
				<feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch"/>
				<feColorMatrix type="saturate" values="0"/>
			</filter>
		</svg>

		<Header />

		<main id="main-content" class="container">
			<slot />
		</main>

		<Footer />
		<CookieConsent />

		<!-- Animations & Interactive Scripts -->
		<script>
			function initAnimations() {
				// 1. Scroll-triggered animations via IntersectionObserver
				const scrollElements = document.querySelectorAll('.reveal-on-scroll');
				
				const elementObserver = new IntersectionObserver((entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							entry.target.classList.add('revealed');
							
							// Staggered reveal for children if container
							if (entry.target.classList.contains('reveal-stagger-container')) {
								const items = entry.target.querySelectorAll('.reveal-stagger-item');
								items.forEach((item, index) => {
									setTimeout(() => {
										item.classList.add('revealed');
									}, index * 80);
								});
							}
						}
					});
				}, {
					threshold: 0.05,
					rootMargin: '0px 0px -50px 0px'
				});
				
				scrollElements.forEach((el) => elementObserver.observe(el));

				// 2. Counter-up animation for stats
				const stats = document.querySelectorAll('.stat-number');
				if (stats.length > 0) {
					const statsObserver = new IntersectionObserver((entries) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting) {
								const target = entry.target as HTMLElement;
								const targetValue = parseInt(target.getAttribute('data-target') || '0', 10);
								let start = 0;
								const duration = 1500;
								const startTime = performance.now();
								
								function updateCount(timestamp: number) {
									const elapsed = timestamp - startTime;
									const progress = Math.min(elapsed / duration, 1);
									const ease = progress * (2 - progress);
									const current = Math.floor(ease * targetValue);
									target.textContent = String(current);
									
									if (progress < 1) {
										requestAnimationFrame(updateCount);
									} else {
										target.textContent = String(targetValue);
									}
								}
								requestAnimationFrame(updateCount);
								statsObserver.unobserve(target);
							}
						});
					}, { threshold: 0.1 });
					stats.forEach(s => statsObserver.observe(s));
				}

				// 3. Cursor Follower (desktop only)
				const glow = document.getElementById('cursor-glow');
				if (glow && window.matchMedia('(min-width: 1024px)').matches) {
					let mouseX = 0;
					let mouseY = 0;
					let glowX = 0;
					let glowY = 0;
					
					const onMouseMove = (e: MouseEvent) => {
						mouseX = e.clientX;
						mouseY = e.clientY;
					};
					
					window.addEventListener('mousemove', onMouseMove);
					
					const updateGlow = () => {
						glowX += (mouseX - glowX) * 0.08;
						glowY += (mouseY - glowY) * 0.08;
						
						glow.style.transform = `translate3d(${glowX}px, ${glowY}px, 0)`;
						requestAnimationFrame(updateGlow);
					};
					updateGlow();
					
					document.addEventListener('astro:before-swap', () => {
						window.removeEventListener('mousemove', onMouseMove);
					}, { once: true });
				}

				// 4. Haptic Feedback (Navigator.vibrate)
				if ('vibrate' in navigator) {
					const interactiveElements = document.querySelectorAll('button, a.btn, .anatomy-step-btn, .tab-btn');
					interactiveElements.forEach(el => {
						el.addEventListener('click', () => {
							navigator.vibrate(10);
						});
					});
				}
			}

			// Run on startup
			initAnimations();
			// Run on View Transitions page swap
			document.addEventListener('astro:page-load', initAnimations);
		</script>
	</body>
</html>

<style>
	main {
		flex: 1;
		margin-bottom: 4rem;
	}
</style>
