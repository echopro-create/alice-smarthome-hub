---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
	description: string;
	image?: string;
	jsonLd?: string; // Строка JSON-LD для SEO-микроразметки
}

const { 
	title, 
	description, 
	image = '/og-image.jpg', 
	jsonLd 
} = Astro.props;

let canonicalURLString = new URL(Astro.url.pathname, Astro.site || 'https://alice-smarthome.ru').href.toLowerCase();
if (canonicalURLString.endsWith('/') && canonicalURLString.split('/').length > 4) {
  canonicalURLString = canonicalURLString.slice(0, -1);
}
---

<!doctype html>
<html lang="ru">
	<head>
		<!-- Global Metadata -->
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />

		<!-- Canonical URL -->
		<link rel="canonical" href={canonicalURLString} />

		<!-- Primary Meta Tags -->
		<title>{title} | Умный Дом с Алисой</title>
		<meta name="title" content={`${title} | Умный Дом с Алисой`} />
		<meta name="description" content={description} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={`${title} | Умный Дом с Алисой`} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(image, Astro.url)} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={Astro.url} />
		<meta property="twitter:title" content={`${title} | Умный Дом с Алисой`} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL(image, Astro.url)} />

		<!-- JSON-LD Structured Data -->
		{jsonLd && <script type="application/ld+json" set:html={jsonLd} />}
	</head>
	<body>
		<Header />

		<main class="container">
			<slot />
		</main>

		<Footer />
	</body>
</html>

<style>
	main {
		flex: 1;
		margin-bottom: 4rem;
	}
</style>
