---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import CookieConsent from "../components/CookieConsent.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";

interface Props {
	title: string;
	description: string;
	image?: string;
	jsonLd?: string;
	noindex?: boolean;
}

const { title, description, image = "/og-image.png", jsonLd, noindex = false } = Astro.props;

const host = (Astro.site?.href || "https://smart-hub.info").replace(/\/$/, "");
const pathname = Astro.url.pathname.toLowerCase().replace(/\/$/, "");
const canonicalURLString = pathname === "" ? `${host}/` : `${host}${pathname}/`;

const yandexVerification = import.meta.env.PUBLIC_YANDEX_VERIFICATION || "";
const yandexMetrikaId = import.meta.env.PUBLIC_YANDEX_METRIKA_ID || "";
---

<!doctype html>
<html lang="ru">
	<head>
		<!-- Global Metadata -->
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="32x32" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="generator" content={Astro.generator} />

		<!-- View Transitions -->
		<ClientRouter />

		<!-- Theme Initialization Script to avoid FOUC -->
		<script is:inline>
			const theme = (() => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
					return 'dark';
				}
				return 'light';
			})();
			
			if (theme === 'dark') {
				document.documentElement.classList.add('dark');
			} else {
				document.documentElement.classList.remove('dark');
			}
		</script>

		<link rel="dns-prefetch" href="https://yastatic.net" />
		<link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />
		<link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />

		<!-- Self-hosted Fonts Preload (critical render path) -->
		<link rel="preload" href="/fonts/inter-cyrillic-wght-normal.woff2" as="font" type="font/woff2" crossorigin />
		<link rel="preload" href="/fonts/inter-latin-wght-normal.woff2" as="font" type="font/woff2" crossorigin />
		<link rel="preload" href="/fonts/outfit-latin-wght-normal.woff2" as="font" type="font/woff2" crossorigin />
		<style is:inline>
			/* Inter — Cyrillic + Latin subsets (Variable) */
			@font-face {
				font-family: 'Inter';
				font-style: normal;
				font-weight: 100 900;
				font-display: swap;
				src: url('/fonts/inter-cyrillic-wght-normal.woff2') format('woff2-variations'),
				     url('/fonts/inter-cyrillic-wght-normal.woff2') format('woff2');
				unicode-range: U+0301, U+0400-045F, U+0490-0491, U+04B0-04B1, U+2116;
			}
			@font-face {
				font-family: 'Inter';
				font-style: normal;
				font-weight: 100 900;
				font-display: swap;
				src: url('/fonts/inter-latin-wght-normal.woff2') format('woff2-variations'),
				     url('/fonts/inter-latin-wght-normal.woff2') format('woff2');
				unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+2000-206F, U+2074, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
			}

			/* Outfit — Latin subset (Variable) */
			@font-face {
				font-family: 'Outfit';
				font-style: normal;
				font-weight: 100 900;
				font-display: swap;
				src: url('/fonts/outfit-latin-wght-normal.woff2') format('woff2-variations'),
				     url('/fonts/outfit-latin-wght-normal.woff2') format('woff2');
				unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+2000-206F, U+2074, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
			}
		</style>

		<!-- Canonical URL -->
		<link rel="canonical" href={canonicalURLString} />

		<!-- Localization Hreflang -->
		<link rel="alternate" hreflang="ru" href={canonicalURLString} />
		<link rel="alternate" hreflang="x-default" href={canonicalURLString} />

		<!-- Primary Meta Tags -->
		<title>{title} | Умный Дом с Алисой</title>
		<meta name="title" content={`${title} | Умный Дом с Алисой`} />
		<meta name="description" content={description} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURLString} />
		<meta property="og:title" content={`${title} | Умный Дом с Алисой`} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(image, Astro.url)} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={canonicalURLString} />
		<meta name="twitter:title" content={`${title} | Умный Дом с Алисой`} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={new URL(image, Astro.url)} />

		<!-- JSON-LD Structured Data: Organization + WebSite (every page) -->
		<script type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "Organization",
				"name": "Умный Дом с Алисой",
				"url": "https://smart-hub.info",
				"logo": "https://smart-hub.info/favicon.svg",
				"email": "hello@smart-hub.info",
				"description": "Библиотека пошаговых сценариев и руководств по траблшутингу для Умного Дома с Алисой"
			}
		</script>
		<script type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "WebSite",
				"name": "Умный Дом с Алисой",
				"url": "https://smart-hub.info"
			}
		</script>

		<!-- JSON-LD: Page-specific structured data (BreadcrumbList, HowTo, TechArticle) -->
		{jsonLd && <script type="application/ld+json" set:html={jsonLd} />}


		{noindex && <meta name="robots" content="noindex, follow" />}
		{yandexVerification && <meta name="yandex-verification" content={yandexVerification} />}

		<!-- KaTeX Math Formulas Rendering -->
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" crossorigin="anonymous">
		<script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js" crossorigin="anonymous"></script>
		<script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/auto-render.min.js" crossorigin="anonymous"></script>
		<script is:inline>
			function renderMath() {
				if (typeof renderMathInElement === 'function') {
					renderMathInElement(document.body, {
						delimiters: [
							{left: '$$', right: '$$', display: true},
							{left: '$', right: '$', display: false},
							{left: '\\(', right: '\\)', display: false},
							{left: '\\[', right: '\\]', display: true}
						],
						throwOnError: false
					});
				}
			}
			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', renderMath);
			} else {
				renderMath();
			}
			document.addEventListener('astro:page-load', renderMath);
		</script>
	</head>
	<body>


		<a href="#main-content" class="skip-link">Перейти к содержанию</a>
		


		<Header />

		<main id="main-content" class="container">
			<slot />
		</main>

		<Footer />
		<CookieConsent />

		<!-- Animations & Interactive Scripts -->
		<script>
			function initAnimations() {
				// Haptic Feedback (Navigator.vibrate)
				if ('vibrate' in navigator) {
					const interactiveElements = document.querySelectorAll('button, a.btn, .anatomy-step-btn, .tab-btn');
					interactiveElements.forEach(el => {
						el.addEventListener('click', () => {
							navigator.vibrate(10);
						});
					});
				}
			}

			// Run on startup
			initAnimations();
			// Run on View Transitions page swap
			document.addEventListener('astro:page-load', initAnimations);
		</script>

		<!-- Back to Top Button -->
		<button id="back-to-top" class="back-to-top-btn glass" aria-label="Вернуться к началу страницы" title="Наверх">
			<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="arrow-up-icon"><path d="m18 15-6-6-6 6"/></svg>
		</button>

		<script>
			function initBackToTop() {
				const btn = document.getElementById('back-to-top');
				if (!btn) return;

				const handleScroll = () => {
					const winScroll = document.documentElement.scrollTop || document.body.scrollTop;
					if (winScroll > 300) {
						btn.classList.add('visible');
					} else {
						btn.classList.remove('visible');
					}
				};

				btn.addEventListener('click', () => {
					window.scrollTo({
						top: 0,
						behavior: 'smooth'
					});
				});

				window.removeEventListener('scroll', handleScroll);
				window.addEventListener('scroll', handleScroll);
				handleScroll();
			}

			initBackToTop();
			document.addEventListener('astro:page-load', initBackToTop);
		</script>

		<!-- Yandex.Metrika counter -->
		{yandexMetrikaId && (
			<script type="text/javascript" is:inline set:html={`
				(function(m,e,t,r,i,k,a){m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
				m[i].l=1*new Date();
				for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
				k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)})
				(window, document, "script", "https://mc.yandex.ru/metrika/tag.js", "ym");

				ym(${yandexMetrikaId}, "init", {
					clickmap:true,
					trackLinks:true,
					accurateTrackBounce:true,
					webvisor:true
				});
			`} />
			<noscript>
				<div>
					<img src={`https://mc.yandex.ru/watch/${yandexMetrikaId}`} style="position:absolute; left:-9999px;" alt="" loading="lazy" decoding="async" width="1" height="1" />
				</div>
			</noscript>
		)}
	</body>
</html>

<style>
	main {
		flex: 1;
		margin-bottom: 4rem;
	}

	/* Back to Top button */
	.back-to-top-btn {
		position: fixed;
		bottom: 2rem;
		right: 2rem;
		width: 46px;
		height: 46px;
		border-radius: 50%;
		background: var(--bg-surface);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
		border: 1px solid var(--border-primary);
		color: var(--text-secondary);
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		z-index: 90;
		opacity: 0;
		pointer-events: none;
		transform: translateY(10px);
		transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
		box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
	}

	.back-to-top-btn.visible {
		opacity: 1;
		pointer-events: auto;
		transform: translateY(0);
	}

	.back-to-top-btn:hover, .back-to-top-btn:focus-visible {
		color: var(--accent-signature);
		border-color: var(--accent-signature-semi);
		background: var(--bg-hover);
		transform: translateY(-2px);
		box-shadow: 0 6px 20px var(--accent-signature-glow);
	}

	.back-to-top-btn:active {
		transform: translateY(0);
	}

	.arrow-up-icon {
		transition: transform 0.25s ease;
	}

	.back-to-top-btn:hover .arrow-up-icon {
		transform: translateY(-2px);
	}

	@media (max-width: 640px) {
		.back-to-top-btn {
			bottom: 1.5rem;
			right: 1.5rem;
			width: 44px;
			height: 44px;
		}
	}
</style>
