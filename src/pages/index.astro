---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { getDifficultyLabel } from '../utils/difficulty';
import heroImage from '../assets/images/hero-main.png';
import deviceNotRespondingImg from '../assets/images/steps/device-not-responding-1.png';
import wifiDropImg from '../assets/images/steps/wifi-drop-1.png';
import batteryDrainImg from '../assets/images/steps/battery-drain-1.png';

const allEntries = await getCollection('scenarios');

// Разделяем записи по категориям и сортируем по дате (самые свежие первые)
const scenarios = allEntries
  .filter(entry => entry.data.category === 'scenario')
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());
const troubleshooting = allEntries
  .filter(entry => entry.data.category === 'troubleshooting')
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());

const scenariosToShow = scenarios.slice(0, 6);
const troubleshootingToShow = troubleshooting.slice(0, 6);

const latestEntries = allEntries
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime())
  .slice(0, 3);
---

<Layout 
  title="Пошаговые сценарии автоматизации и инструкции по настройке" 
  description="Библиотека пошаговых сценариев и руководств по траблшутингу для вашего Умного Дома с Алисой. Систематизируем опыт закрытых сообществ."
>
  <!-- Hero Section -->
  <section class="hero-section bento-grid">
    <!-- Main Card (Text & Actions) -->
    <div class="bento-card bento-card-main glass">
      <div class="hero-badge font-outfit">База знаний Умного Дома</div>
      <h1 class="hero-title font-outfit">
        Сделайте ваш дом действительно <span class="accent-title-word">Умным</span> с Алисой
      </h1>
      <p class="hero-subtitle">
        Пошаговые руководства, детальные схемы интеграции и готовые решения проблем. Мы задокументировали и структурировали хаотичный опыт сотен технических сообществ и форумов.
      </p>
      <div class="hero-actions">
        <a href="/scenarios/" class="btn btn-primary font-outfit">
          Изучить сценарии
          <span class="btn-arrow" aria-hidden="true">→</span>
        </a>
        <a href="/troubleshooting/" class="btn btn-secondary font-outfit">База траблшутинга</a>
      </div>
    </div>

    <!-- Image Card -->
    <div class="bento-card bento-card-image">
      <img 
        src={heroImage.src} 
        alt="Премиальный умный дом с Яндекс Станцией и датчиками" 
        class="hero-image"
        loading="lazy"
        decoding="async"
        width="600"
        height="450"
      />
    </div>

    <!-- Feature Card 1: Local Automation -->
    <div class="bento-card bento-card-feature glass">
      <div class="feature-icon" aria-hidden="true">⚡</div>
      <div class="feature-content">
        <div class="feature-title font-outfit">Локальность</div>
        <p class="feature-desc">Настройка сценариев автоматизации, работающих локально без интернета.</p>
      </div>
    </div>

    <!-- Feature Card 2: Compatibility -->
    <div class="bento-card bento-card-feature glass">
      <div class="feature-icon" aria-hidden="true">🔌</div>
      <div class="feature-content">
        <div class="feature-title font-outfit">Совместимость</div>
        <p class="feature-desc">Интеграция Zigbee, Matter и Wi-Fi устройств от разных брендов в единую сеть.</p>
      </div>
    </div>

    <!-- Feature Card 3: Troubleshooting -->
    <div class="bento-card bento-card-feature glass">
      <div class="feature-icon" aria-hidden="true">🔧</div>
      <div class="feature-content">
        <div class="feature-title font-outfit">Решение проблем</div>
        <p class="feature-desc">Устранение задержек, отвалов беспроводных датчиков и радиопомех.</p>
      </div>
    </div>

    <div class="hero-glow"></div>
  </section>

  <!-- Scenarios Slider Section -->
  <!-- Scenarios Section: Anatomy of Automation -->
  <section id="scenarios" class="section-container automation-anatomy-section">
    <h2 class="section-title font-outfit"><span aria-hidden="true">🔮</span> Один день с Алисой</h2>
    <div class="section-divider"></div>
    <p class="section-desc">Выберите сценарий, чтобы увидеть работу датчиков и устройств умного дома в реальном времени.</p>
    
    <div class="anatomy-grid glass">
      <!-- Left: Interactive steps (tabs) -->
      <div class="anatomy-steps" role="tablist" aria-label="Сценарии автоматизации">
        <button class="anatomy-step-btn active" data-scene="morning" aria-selected="true" role="tab" id="scene-tab-morning" aria-controls="scene-panel-morning">
          <span class="step-num font-outfit">🌅</span>
          <div class="step-text">
            <h3 class="step-title font-outfit">07:30 — Утреннее пробуждение</h3>
            <p class="step-desc">Мягкий старт дня: плавное включение света, свежий кофе и утреннее шоу Алисы.</p>
          </div>
        </button>
        <button class="anatomy-step-btn" data-scene="away" aria-selected="false" role="tab" id="scene-tab-away" aria-controls="scene-panel-away">
          <span class="step-num font-outfit">🚶‍♂️</span>
          <div class="step-text">
            <h3 class="step-title font-outfit">09:00 — Все ушли (Охрана)</h3>
            <p class="step-desc">Автоматическое сбережение энергии, активация видеокамер и запуск уборки.</p>
          </div>
        </button>
        <button class="anatomy-step-btn" data-scene="cinema" aria-selected="false" role="tab" id="scene-tab-cinema" aria-controls="scene-panel-cinema">
          <span class="step-num font-outfit">🍿</span>
          <div class="step-text">
            <h3 class="step-title font-outfit">20:00 — Вечерний уют</h3>
            <p class="step-desc">Создание идеальной атмосферы: закрытие штор, приглушенный неон и включение кино.</p>
          </div>
        </button>

        <!-- Dynamic Logic Scheme (ЕСЛИ ... ТО ...) -->
        <div class="logic-scheme glass">
          <div class="logic-block logic-if">
            <span class="logic-label font-outfit">ЕСЛИ</span>
            <span class="logic-value" id="logic-val-if">Датчик движения зафиксировал активность</span>
          </div>
          <div class="logic-block logic-and" id="logic-block-and">
            <span class="logic-label font-outfit">И</span>
            <span class="logic-value" id="logic-val-and">Время суток с 07:00 до 09:00</span>
          </div>
          <div class="logic-block logic-then">
            <span class="logic-label font-outfit">ТО</span>
            <span class="logic-value" id="logic-val-then">Сварить кофе, включить лампу, запустить утренний плейлист</span>
          </div>
        </div>
        
        <div class="anatomy-link-wrapper">
          <a href="/scenarios/" class="card-link font-outfit">
            Все сценарии автоматизации <span class="arrow">→</span>
          </a>
        </div>
      </div>
      
      <!-- Right: Interactive Visual Scheme (Blueprint) -->
      <div class="anatomy-visual">
        <div class="visual-container" data-active-scene="morning">
          <!-- Central Hub: Alice (🔊) - Active in morning and cinema -->
          <div class="blueprint-device node-blueprint-hub device-hub-always" id="node-blueprint-hub">
            <div class="device-icon" aria-hidden="true">🔊</div>
            <span class="device-label">Яндекс Станция</span>
          </div>
          
          <!-- Morning Devices -->
          <!-- Motion Sensor (🚶‍♂️) -->
          <div class="blueprint-device node-blueprint-motion device-morning" id="node-blueprint-motion">
            <div class="device-icon" aria-hidden="true">🚶‍♂️</div>
            <span class="device-label">Датчик движения</span>
          </div>
          <!-- Smart Plug (☕) -->
          <div class="blueprint-device node-blueprint-plug device-morning" id="node-blueprint-plug">
            <div class="device-icon" aria-hidden="true">☕</div>
            <span class="device-label">Умная розетка</span>
          </div>
          <!-- Smart Bulb (💡) -->
          <div class="blueprint-device node-blueprint-bulb device-morning device-cinema" id="node-blueprint-bulb">
            <div class="device-icon" aria-hidden="true">💡</div>
            <span class="device-label">Умная лампа</span>
          </div>
          
          <!-- Away Devices -->
          <!-- Smart Lock / Door Sensor (🚪) -->
          <div class="blueprint-device node-blueprint-lock device-away" id="node-blueprint-lock">
            <div class="device-icon" aria-hidden="true">🚪</div>
            <span class="device-label">Датчик двери</span>
          </div>
          <!-- Vacuum Cleaner (🧹) -->
          <div class="blueprint-device node-blueprint-vacuum device-away" id="node-blueprint-vacuum">
            <div class="device-icon" aria-hidden="true">🧹</div>
            <span class="device-label">Пылесос</span>
          </div>
          <!-- Smart Camera (📹) -->
          <div class="blueprint-device node-blueprint-camera device-away" id="node-blueprint-camera">
            <div class="device-icon" aria-hidden="true">📹</div>
            <span class="device-label">Видеокамера</span>
          </div>

          <!-- Cinema Devices -->
          <!-- LED Strip (🌈) -->
          <div class="blueprint-device node-blueprint-strip device-cinema" id="node-blueprint-strip">
            <div class="device-icon" aria-hidden="true">🌈</div>
            <span class="device-label">Светодиодная лента</span>
          </div>
          <!-- Curtains (⛺) -->
          <div class="blueprint-device node-blueprint-curtains device-cinema" id="node-blueprint-curtains">
            <div class="device-icon" aria-hidden="true">⛺</div>
            <span class="device-label">Умные шторы</span>
          </div>
          
          <!-- Isometric Room Blueprint (SVG) -->
          <svg class="blueprint-svg" viewBox="0 0 500 350" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- Стены и пол (основа комнаты) -->
            <path class="blueprint-wall-base" d="M100,260 L250,180 L400,260" stroke="var(--blueprint-line)" stroke-width="1.5" />
            <path class="blueprint-wall-corner" d="M250,180 L250,60" stroke="var(--blueprint-line)" stroke-width="1.5" />
            <path class="blueprint-wall-top" d="M100,140 L250,60 L400,140" stroke="var(--blueprint-line)" stroke-width="1.5" />
            
            <!-- Дверной проем слева -->
            <path class="blueprint-furniture" d="M120,249 L120,170 L150,155 L150,233 Z" stroke="var(--blueprint-line)" stroke-width="1.2" stroke-dasharray="3,3" />
            
            <!-- Окно справа -->
            <path class="blueprint-furniture" d="M300,185 L300,135 L360,105 L360,155 Z" stroke="var(--blueprint-line)" stroke-width="1.2" />
            <line class="blueprint-furniture" x1="330" y1="170" x2="330" y2="120" stroke="var(--blueprint-line)" stroke-width="1" />
            
            <!-- Изометрическая кровать -->
            <path class="blueprint-furniture" d="M170,210 L220,235 L280,205 L230,180 Z" stroke="var(--blueprint-line)" stroke-width="1.2" />
            <path class="blueprint-furniture" d="M170,225 L220,250 L280,220 L280,205 L220,235 L170,210 Z" stroke="var(--blueprint-line)" stroke-width="1.2" />
            <path class="blueprint-furniture" d="M170,225 L170,210 M220,250 L220,235 M280,220 L280,205" stroke="var(--blueprint-line)" stroke-width="1.2" />
            
            <path class="blueprint-furniture" d="M185,200 L205,210 L215,205 L195,195 Z" stroke="var(--blueprint-line)" stroke-width="1" />
            <path class="blueprint-furniture" d="M205,190 L225,200 L235,195 L215,185 Z" stroke="var(--blueprint-line)" stroke-width="1" />

            <!-- Кухонный стол справа -->
            <path class="blueprint-furniture" d="M310,215 L350,235 L380,220 L340,200 Z" stroke="var(--blueprint-line)" stroke-width="1.2" />
            <line class="blueprint-furniture" x1="310" y1="215" x2="310" y2="245" stroke="var(--blueprint-line)" stroke-width="1.2" />
            <line class="blueprint-furniture" x1="350" y1="235" x2="350" y2="265" stroke="var(--blueprint-line)" stroke-width="1.2" />
            <line class="blueprint-furniture" x1="380" y1="220" x2="380" y2="250" stroke="var(--blueprint-line)" stroke-width="1.2" />

            <!-- Робот-пылесос (схематично на полу) -->
            <ellipse class="blueprint-furniture" cx="260" cy="245" rx="14" ry="7" stroke="var(--blueprint-line)" stroke-width="1" />

            <!-- Подсветка комнат -->
            <polygon class="room-highlight morning" points="90,260 250,180 410,260 250,340" fill="url(#morning-grad)" opacity="0" />
            <polygon class="room-highlight away" points="90,260 250,180 410,260 250,340" fill="url(#away-grad)" opacity="0" />
            <polygon class="room-highlight cinema" points="90,260 250,180 410,260 250,340" fill="url(#cinema-grad)" opacity="0" />

            <defs>
              <radialGradient id="morning-grad" cx="50%" cy="50%" r="50%" fx="50%" fy="50%">
                <stop offset="0%" stop-color="#f59e0b" stop-opacity="0.25" />
                <stop offset="100%" stop-color="#f59e0b" stop-opacity="0" />
              </radialGradient>
              <radialGradient id="away-grad" cx="50%" cy="50%" r="50%" fx="50%" fy="50%">
                <stop offset="0%" stop-color="#0ea5e9" stop-opacity="0.2" />
                <stop offset="100%" stop-color="#0ea5e9" stop-opacity="0" />
              </radialGradient>
              <radialGradient id="cinema-grad" cx="50%" cy="50%" r="50%" fx="50%" fy="50%">
                <stop offset="0%" stop-color="#8b5cf6" stop-opacity="0.3" />
                <stop offset="100%" stop-color="#8b5cf6" stop-opacity="0" />
              </radialGradient>
            </defs>

            <!-- Пути связей устройств -->
            <!-- Сценарий: Утро (morning) -->
            <path class="line line-morning" id="path-morning-1" d="M125,200 L225,185" stroke="var(--line-color)" stroke-width="2.5" stroke-dasharray="5,5" />
            <path class="line line-morning" id="path-morning-2" d="M225,185 L360,225" stroke="var(--line-color)" stroke-width="2.5" stroke-dasharray="5,5" />
            <path class="line line-morning" id="path-morning-3" d="M225,185 L340,95" stroke="var(--line-color)" stroke-width="2.5" stroke-dasharray="5,5" />

            <!-- Сценарий: Вне дома (away) -->
            <path class="line line-away" id="path-away-1" d="M85,195 L250,75" stroke="var(--line-color)" stroke-width="2.5" stroke-dasharray="5,5" />
            <path class="line line-away" id="path-away-2" d="M85,195 L260,245" stroke="var(--line-color)" stroke-width="2.5" stroke-dasharray="5,5" />

            <!-- Сценарий: Кинотеатр (cinema) -->
            <path class="line line-cinema" id="path-cinema-1" d="M225,185 L180,210" stroke="var(--line-color)" stroke-width="2.5" stroke-dasharray="5,5" />
            <path class="line line-cinema" id="path-cinema-2" d="M225,185 L410,130" stroke="var(--line-color)" stroke-width="2.5" stroke-dasharray="5,5" />
          </svg>
        </div>
      </div>
    </div>

    <div class="view-all-container">
      <a href="/scenarios/" class="view-all-btn font-outfit">
        <span>Все сценарии</span>
        <span class="view-all-arrow">→</span>
      </a>
    </div>
  </section>

  <!-- Troubleshooting Section: Feature Strips (Z-pattern) -->
  <section id="troubleshooting" class="section-container troubleshooting-strips-section">
    <div class="trouble-glow" aria-hidden="true"></div>
    <h2 class="section-title font-outfit"><span aria-hidden="true">🔧</span> База траблшутинга</h2>
    <div class="section-divider"></div>
    <p class="section-desc">Пошаговое решение критических сбоев, борьба с радиопомехами и отвалами беспроводных датчиков.</p>
    
    <div class="troubleshooting-strips-list">
      <!-- Strip 1: Device not responding (Text left, Image right) -->
      <div class="trouble-strip glass">
        <div class="strip-content">
          <div class="card-header">
            <span class="difficulty-badge easy">ЛЕГКО</span>
            <span class="date-badge">20 июня 2026</span>
          </div>
          <h3 class="strip-title font-outfit">Устройство не отвечает в Доме с Алисой: причины решения</h3>
          <p class="strip-desc">Подробный разбор причин отвала розеток, ламп и датчиков. Диагностика проблем питания, забитого радиоэфира и сбоев интеграции в облачных или локальных сценариях.</p>
          
          <div class="card-devices">
            <span class="device-tag">Яндекс Станция</span>
            <span class="device-tag">Умная розетка</span>
            <span class="device-tag">Датчик температуры</span>
          </div>
          
          <a href="/troubleshooting/device-not-responding/" class="trouble-link font-outfit">
            Решение проблемы <span class="arrow">→</span>
          </a>
        </div>
        <div class="strip-image-wrap">
          <img 
            src={deviceNotRespondingImg.src} 
            alt="Схема решения ошибки Устройство не отвечает в приложении Умный Дом с Алисой" 
            class="strip-image"
            loading="lazy"
            decoding="async"
            width="500"
            height="330"
          />
        </div>
      </div>

      <!-- Strip 2: Wifi drop (Image left, Text right) -->
      <div class="trouble-strip glass reverse">
        <div class="strip-content">
          <div class="card-header">
            <span class="difficulty-badge easy">ЛЕГКО</span>
            <span class="date-badge">18 июня 2026</span>
          </div>
          <h3 class="strip-title font-outfit">Яндекс Станция теряет Wi-Fi и отключается от сети</h3>
          <p class="strip-desc">Устранение постоянных обрывов Wi-Fi соединения на колонках Алиса. Оптимальная настройка домашнего роутера, выбор частоты 5 ГГц и свободных каналов для стабильной локальной автоматизации.</p>
          
          <div class="card-devices">
            <span class="device-tag">Яндекс Станция (все модели)</span>
            <span class="device-tag">Домашний роутер Wi-Fi</span>
          </div>
          
          <a href="/troubleshooting/yandex-station-wifi-drop/" class="trouble-link font-outfit">
            Решение проблемы <span class="arrow">→</span>
          </a>
        </div>
        <div class="strip-image-wrap">
          <img 
            src={wifiDropImg.src} 
            alt="Инструкция по настройке Wi-Fi роутера для Яндекс Станции" 
            class="strip-image"
            loading="lazy"
            decoding="async"
            width="500"
            height="330"
          />
        </div>
      </div>

      <!-- Strip 3: Battery drain (Text left, Image right) -->
      <div class="trouble-strip glass">
        <div class="strip-content">
          <div class="card-header">
            <span class="difficulty-badge medium">СРЕДНЕ</span>
            <span class="date-badge">15 июня 2026</span>
          </div>
          <h3 class="strip-title font-outfit">Быстрый разряд батареек в беспроводных датчиках</h3>
          <p class="strip-desc">Почему Zigbee датчики Aqara/Tuya разряжают элементы CR2032 за пару недель. Разбор причин: плохой линк с хабом, радиопомехи, неправильные настройки интервала опроса и как это исправить.</p>
          
          <div class="card-devices">
            <span class="device-tag">Датчики движения / открытия</span>
            <span class="device-tag">Zigbee репитеры</span>
            <span class="device-tag">Батарейки CR2032</span>
          </div>
          
          <a href="/troubleshooting/battery-drain-troubleshooting/" class="trouble-link font-outfit">
            Решение проблемы <span class="arrow">→</span>
          </a>
        </div>
        <div class="strip-image-wrap">
          <img 
            src={batteryDrainImg.src} 
            alt="Инструкция по экономии батареек в датчиках умного дома" 
            class="strip-image"
            loading="lazy"
            decoding="async"
            width="500"
            height="330"
          />
        </div>
      </div>
    </div>

    <div class="view-all-container">
      <a href="/troubleshooting/" class="view-all-btn font-outfit">
        <span>Все разборы</span>
        <span class="view-all-arrow">→</span>
      </a>
    </div>
  </section>

  <!-- Latest Publications Section (SEO Boost) -->
  <section id="latest-publications" class="section-container latest-publications-section">
    <h2 class="section-title font-outfit"><span aria-hidden="true">⏱️</span> Свежие публикации</h2>
    <div class="section-divider"></div>
    <p class="section-desc">Новые материалы в нашей базе знаний. Раздел обновляется автоматически.</p>
    
    <div class="latest-cards-grid">
      {latestEntries.map(entry => {
        const isScenario = entry.data.category === 'scenario';
        const detailUrl = isScenario ? `/scenarios/${entry.id}/` : `/troubleshooting/${entry.id}/`;
        const categoryLabel = isScenario ? 'Сценарий' : 'Траблшутинг';
        const categoryClass = isScenario ? 'category-scenario' : 'category-troubleshooting';
        
        const dateStr = new Date(entry.data.publishDate).toLocaleDateString('ru-RU', {
          day: 'numeric',
          month: 'long',
          year: 'numeric'
        });
        
        return (
          <div class="latest-card glass">
            <div class="card-meta">
              <span class={`category-badge ${categoryClass}`}>{categoryLabel}</span>
              <span class="publish-date">{dateStr}</span>
            </div>
            <h3 class="card-title font-outfit">
              {entry.data.title}
            </h3>
            <p class="card-desc">{entry.data.description}</p>
            {entry.data.devices && entry.data.devices.length > 0 && (
              <div class="card-devices-list">
                {entry.data.devices.slice(0, 3).map(dev => (
                  <span class="device-tag-mini">{dev}</span>
                ))}
              </div>
            )}
            <div class="card-action-wrap">
              <a href={detailUrl} class="read-more-link font-outfit">
