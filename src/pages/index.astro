    const devicesContainer = document.getElementById('dash-devices');
    const dashLink = document.getElementById('dash-link');
    
    if (steps.length === 0) return;
    
    // Проверка инициализации для предотвращения повторной навески слушателей
    const firstStep = steps[0];
    if (firstStep.dataset.initialized) return;
    firstStep.dataset.initialized = 'true';

    const sceneData = {
      morning: {
        title: 'Утреннее пробуждение',
        if: 'Датчик движения зафиксировал активность',
        and: 'Время суток с 07:00 до 09:00',
        then: 'Сварить кофе, включить лампу, запустить утренний плейлист',
        devices: [
          { name: 'Датчик движения Aqara', protocol: 'Zigbee 3.0', icon: '🚶‍♂️' },
          { name: 'Яндекс Станция', protocol: 'Wi-Fi', icon: '🔊' },
          { name: 'Умная розетка Tuya', protocol: 'Zigbee', icon: '☕' },
          { name: 'Умная лампа Яндекс', protocol: 'Wi-Fi / Matter', icon: '💡' }
        ],
        link: '/scenarios/morning-coffee/'
      },
      away: {
        title: 'Все ушли (Режим охраны)',
        if: 'Датчик двери закрылся и замок заблокирован',
        and: null,
        then: 'Активировать камеру, запустить пылесос, выключить все приборы',
        devices: [
          { name: 'Датчик открытия Aqara', protocol: 'Zigbee 3.0', icon: '🚪' },
          { name: 'Умная камера Яндекс', protocol: 'Wi-Fi', icon: '📹' },
          { name: 'Робот-пылесос Roborock', protocol: 'Wi-Fi', icon: '🧹' }
        ],
        link: '/scenarios/leaving-home-scenario/'
      },
      cinema: {
        title: 'Вечерний уют (Кинотеатр)',
        if: 'Сказано Алисе: "Время кино"',
        and: null,
        then: 'Закрыть шторы, включить подсветку, запустить телевизор',
        devices: [
          { name: 'Яндекс Станция', protocol: 'Wi-Fi', icon: '🔊' },
          { name: 'Умные шторы Aqara', protocol: 'Zigbee 3.0 / Matter', icon: '⛺' },
          { name: 'Светодиодная лента Tuya', protocol: 'Zigbee', icon: '🌈' },
          { name: 'Умная лампа Яндекс', protocol: 'Wi-Fi', icon: '💡' }
        ],
        link: '/scenarios/light-alarm-clock/'
      }
    };
    
    steps.forEach(step => {
      step.dataset.initialized = 'true';
      
      step.addEventListener('click', () => {
        const scene = step.getAttribute('data-scene');
        
        steps.forEach(s => {
          s.classList.remove('active');
          s.setAttribute('aria-selected', 'false');
        });
        step.classList.add('active');
        step.setAttribute('aria-selected', 'true');
        
        // Обновляем дашборд
        const data = sceneData[scene];
        if (data) {
          if (dashTitle) dashTitle.textContent = data.title;
          if (valIf) valIf.textContent = data.if;
          if (valThen) valThen.textContent = data.then;
          
          if (data.and) {
            if (valAnd) valAnd.textContent = data.and;
            if (blockAnd) blockAnd.style.display = 'flex';
          } else {
            if (blockAnd) blockAnd.style.display = 'none';
          }
          
          // Обновляем список устройств
          if (devicesContainer) {
            devicesContainer.innerHTML = data.devices.map(dev => `
              <div class="device-item-row">
                <span class="device-item-icon">${dev.icon}</span>
                <div class="device-item-info">
                  <span class="device-item-name">${dev.name}</span>
                  <span class="device-item-protocol">${dev.protocol}</span>
                </div>
              </div>
            `).join('');
          }
          
          // Обновляем ссылку
          if (dashLink) {
            dashLink.setAttribute('href', data.link);
          }
        }
      });
    });
  }

  // Запуск при первой загрузке
  initHomepageInteractive();
  // Запуск при переходах View Transitions
  document.addEventListener('astro:page-load', initHomepageInteractive);
</script>

