<script>
  function initHomepageInteractive() {
    // 1. Инициализация слайдера сценариев
    const slider = document.getElementById('scenarios-slider');
    const prevBtn = document.querySelector('.slider-wrapper .slider-nav.prev');
    const nextBtn = document.querySelector('.slider-wrapper .slider-nav.next');
    
    if (slider && prevBtn && nextBtn) {
      // Предотвращаем повторное навешивание слушателей
      if (!prevBtn.dataset.initialized) {
        prevBtn.dataset.initialized = 'true';
        nextBtn.dataset.initialized = 'true';
        
        const cardWidth = 360;
        const gap = 24; // 1.5rem
        const scrollAmount = cardWidth + gap;
        
        prevBtn.addEventListener('click', () => {
          slider.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
        });
        
        nextBtn.addEventListener('click', () => {
          slider.scrollBy({ left: scrollAmount, behavior: 'smooth' });
        });
      }
    }

    // 2. Инициализация аккордеона траблшутинга
    const accordionItems = document.querySelectorAll('.trouble-accordion-item');
    
    accordionItems.forEach(item => {
      const header = item.querySelector('.accordion-header');
      const content = item.querySelector('.accordion-content');
      
      if (!header || !content) return;
      
      // Предотвращаем повторное навешивание слушателей
      if (!header.dataset.initialized) {
        header.dataset.initialized = 'true';
        
        header.addEventListener('click', () => {
          const isOpen = item.classList.contains('active');
          
          // Закрываем остальные
          accordionItems.forEach(otherItem => {
            if (otherItem !== item && otherItem.classList.contains('active')) {
              otherItem.classList.remove('active');
              const otherContent = otherItem.querySelector('.accordion-content');
              const otherHeader = otherItem.querySelector('.accordion-header');
              if (otherContent) {
                otherContent.style.maxHeight = null;
                otherContent.setAttribute('aria-hidden', 'true');
              }
              if (otherHeader) {
                otherHeader.setAttribute('aria-expanded', 'false');
              }
            }
          });
          
          // Переключаем текущий
          if (isOpen) {
            item.classList.remove('active');
            content.style.maxHeight = null;
            header.setAttribute('aria-expanded', 'false');
            content.setAttribute('aria-hidden', 'true');
          } else {
            item.classList.add('active');
            content.style.maxHeight = content.scrollHeight + 'px';
            header.setAttribute('aria-expanded', 'true');
            content.setAttribute('aria-hidden', 'false');
          }
        });
      }
    });
  }

  // Запуск при первой загрузке
  initHomepageInteractive();
  // Запуск при переходах View Transitions
  document.addEventListener('astro:page-load', initHomepageInteractive);
</script>

