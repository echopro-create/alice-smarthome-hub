---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { getDifficultyLabel } from '../utils/difficulty';
import heroImage from '../assets/images/hero-main.png';
import deviceNotRespondingImg from '../assets/images/steps/device-not-responding-1.png';
import wifiDropImg from '../assets/images/steps/wifi-drop-1.png';
import batteryDrainImg from '../assets/images/steps/battery-drain-1.png';

const allEntries = await getCollection('scenarios');

// Разделяем записи по категориям и сортируем по дате (самые свежие первые)
const scenarios = allEntries
  .filter(entry => entry.data.category === 'scenario')
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());
const troubleshooting = allEntries
  .filter(entry => entry.data.category === 'troubleshooting')
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());

const scenariosToShow = scenarios.slice(0, 6);
const troubleshootingToShow = troubleshooting.slice(0, 6);

const latestEntries = allEntries
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime())
  .slice(0, 3);
---

<Layout 
  title="Пошаговые сценарии автоматизации и инструкции по настройке" 
  description="Библиотека пошаговых сценариев и руководств по траблшутингу для вашего Умного Дома с Алисой. Систематизируем опыт закрытых сообществ."
>
  <!-- Hero Section -->
  <section class="hero-section bento-grid">
    <!-- Main Card (Text & Actions) -->
    <div class="bento-card bento-card-main glass">
      <div class="hero-badge font-outfit">База знаний Умного Дома</div>
      <h1 class="hero-title font-outfit">
        Сделайте ваш дом действительно <span class="accent-title-word">Умным</span> с Алисой
      </h1>
      <p class="hero-subtitle">
        Пошаговые руководства, детальные схемы интеграции и готовые решения проблем. Мы задокументировали и структурировали хаотичный опыт сотен технических сообществ и форумов.
      </p>
      <div class="hero-actions">
        <a href="/scenarios/" class="btn btn-primary font-outfit">
          Изучить сценарии
          <span class="btn-arrow" aria-hidden="true">→</span>
        </a>
        <a href="/troubleshooting/" class="btn btn-secondary font-outfit">База траблшутинга</a>
      </div>
    </div>

    <!-- Image Card -->
    <div class="bento-card bento-card-image">
      <img 
        src={heroImage.src} 
        alt="Премиальный умный дом с Яндекс Станцией и датчиками" 
        class="hero-image"
        loading="lazy"
        decoding="async"
        width="600"
        height="450"
      />
    </div>

    <!-- Feature Card 1: Local Automation -->
    <div class="bento-card bento-card-feature glass">
      <div class="feature-icon" aria-hidden="true">⚡</div>
      <div class="feature-content">
        <div class="feature-title font-outfit">Локальность</div>
        <p class="feature-desc">Настройка сценариев автоматизации, работающих локально без интернета.</p>
      </div>
    </div>

    <!-- Feature Card 2: Compatibility -->
    <div class="bento-card bento-card-feature glass">
      <div class="feature-icon" aria-hidden="true">🔌</div>
      <div class="feature-content">
        <div class="feature-title font-outfit">Совместимость</div>
        <p class="feature-desc">Интеграция Zigbee, Matter и Wi-Fi устройств от разных брендов в единую сеть.</p>
      </div>
    </div>

    <!-- Feature Card 3: Troubleshooting -->
    <div class="bento-card bento-card-feature glass">
      <div class="feature-icon" aria-hidden="true">🔧</div>
      <div class="feature-content">
        <div class="feature-title font-outfit">Решение проблем</div>
        <p class="feature-desc">Устранение задержек, отвалов беспроводных датчиков и радиопомех.</p>
      </div>
    </div>

    <div class="hero-glow"></div>
  </section>

  <!-- Scenarios Slider Section -->
  <!-- Scenarios Section: Anatomy of Automation -->
  <section id="scenarios" class="section-container automation-anatomy-section">
    <h2 class="section-title font-outfit"><span aria-hidden="true">🔮</span> Анатомия автоматизации</h2>
    <div class="section-divider"></div>
    <p class="section-desc">Посмотрите по шагам, как взаимодействуют устройства в сценарии «Умное пробуждение» при вашей утренней активности.</p>
    
    <div class="anatomy-grid glass">
      <!-- Left: Interactive steps (tabs) -->
      <div class="anatomy-steps" role="tablist" aria-label="Шаги автоматизации">
        <button class="anatomy-step-btn active" data-step="1" aria-selected="true" role="tab" id="step-tab-1" aria-controls="step-panel-1">
          <span class="step-num font-outfit">1</span>
          <div class="step-text">
            <h3 class="step-title font-outfit">Триггер: Датчик движения</h3>
            <p class="step-desc">Сенсор движения в спальне фиксирует ваше первое перемещение (с 7:00 до 9:00).</p>
          </div>
        </button>
        <button class="anatomy-step-btn" data-step="2" aria-selected="false" role="tab" id="step-tab-2" aria-controls="step-panel-2">
          <span class="step-num font-outfit">2</span>
          <div class="step-text">
            <h3 class="step-title font-outfit">Хаб: Яндекс Станция</h3>
            <p class="step-desc">Колонка принимает сигнал, запускает розетку кофеварки и начинает готовить напиток.</p>
          </div>
        </button>
        <button class="anatomy-step-btn" data-step="3" aria-selected="false" role="tab" id="step-tab-3" aria-controls="step-panel-3">
          <span class="step-num font-outfit">3</span>
          <div class="step-text">
            <h3 class="step-title font-outfit">Действие: Свет и Музыка</h3>
            <p class="step-desc">Включается мягкий свет на кухне, а колонка Алисы начинает играть утренний плейлист.</p>
          </div>
        </button>
        
        <div class="anatomy-link-wrapper">
          <a href="/scenarios/morning-coffee/" class="card-link font-outfit">
            Читать полный гайд сценария <span class="arrow">→</span>
          </a>
        </div>
      </div>
      
      <!-- Right: Interactive Visual Scheme -->
      <div class="anatomy-visual">
        <div class="visual-container">
          <!-- Central Hub: Alice -->
          <div class="visual-node node-hub active" id="node-hub">
            <div class="node-icon" aria-hidden="true">🔊</div>
            <span class="node-label">Яндекс Станция</span>
          </div>
          
          <!-- Trigger Node: Motion Sensor -->
          <div class="visual-node node-trigger active" id="node-trigger">
            <div class="node-icon" aria-hidden="true">🚶‍♂️</div>
            <span class="node-label">Датчик движения</span>
          </div>
          
          <!-- Action Node 1: Coffee Maker -->
          <div class="visual-node node-action-1" id="node-action-1">
            <div class="node-icon" aria-hidden="true">☕</div>
            <span class="node-label">Умная розетка (Кофе)</span>
          </div>
          
          <!-- Action Node 2: Light -->
          <div class="visual-node node-action-2" id="node-action-2">
            <div class="node-icon" aria-hidden="true">💡</div>
            <span class="node-label">Умная лампа</span>
          </div>
          
          <!-- Connection lines (SVG) -->
          <svg class="visual-lines" width="100%" height="100%" viewBox="0 0 400 300" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- Line Trigger to Hub -->
            <path class="line line-trigger active" id="line-trigger" d="M80,150 L200,150" stroke="var(--text-muted)" stroke-width="2.5" stroke-dasharray="5,5" />
            <!-- Line Hub to Action 1 -->
            <path class="line line-action-1" id="line-action-1" d="M200,150 L320,75" stroke="var(--text-muted)" stroke-width="2.5" stroke-dasharray="5,5" />
            <!-- Line Hub to Action 2 -->
            <path class="line line-action-2" id="line-action-2" d="M200,150 L320,225" stroke="var(--text-muted)" stroke-width="2.5" stroke-dasharray="5,5" />
          </svg>
        </div>
      </div>
    </div>

    <div class="view-all-container">
      <a href="/scenarios/" class="view-all-btn font-outfit">
        <span>Все сценарии</span>
        <span class="view-all-arrow">→</span>
      </a>
    </div>
  </section>

  <!-- Troubleshooting Section: Feature Strips (Z-pattern) -->
  <section id="troubleshooting" class="section-container troubleshooting-strips-section">
    <div class="trouble-glow" aria-hidden="true"></div>
    <h2 class="section-title font-outfit"><span aria-hidden="true">🔧</span> База траблшутинга</h2>
    <div class="section-divider"></div>
    <p class="section-desc">Пошаговое решение критических сбоев, борьба с радиопомехами и отвалами беспроводных датчиков.</p>
    
    <div class="troubleshooting-strips-list">
      <!-- Strip 1: Device not responding (Text left, Image right) -->
      <div class="trouble-strip glass">
        <div class="strip-content">
          <div class="card-header">
            <span class="difficulty-badge easy">ЛЕГКО</span>
            <span class="date-badge">20 июня 2026</span>
          </div>
          <h3 class="strip-title font-outfit">Устройство не отвечает в Доме с Алисой: причины решения</h3>
          <p class="strip-desc">Подробный разбор причин отвала розеток, ламп и датчиков. Диагностика проблем питания, забитого радиоэфира и сбоев интеграции в облачных или локальных сценариях.</p>
          
          <div class="card-devices">
            <span class="device-tag">Яндекс Станция</span>
            <span class="device-tag">Умная розетка</span>
            <span class="device-tag">Датчик температуры</span>
          </div>
          
          <a href="/troubleshooting/device-not-responding/" class="trouble-link font-outfit">
            Решение проблемы <span class="arrow">→</span>
          </a>
        </div>
        <div class="strip-image-wrap">
          <img 
            src={deviceNotRespondingImg.src} 
            alt="Схема решения ошибки Устройство не отвечает в приложении Умный Дом с Алисой" 
            class="strip-image"
            loading="lazy"
            decoding="async"
            width="500"
            height="330"
          />
        </div>
      </div>

      <!-- Strip 2: Wifi drop (Image left, Text right) -->
      <div class="trouble-strip glass reverse">
        <div class="strip-content">
          <div class="card-header">
            <span class="difficulty-badge easy">ЛЕГКО</span>
            <span class="date-badge">18 июня 2026</span>
          </div>
          <h3 class="strip-title font-outfit">Яндекс Станция теряет Wi-Fi и отключается от сети</h3>
          <p class="strip-desc">Устранение постоянных обрывов Wi-Fi соединения на колонках Алиса. Оптимальная настройка домашнего роутера, выбор частоты 5 ГГц и свободных каналов для стабильной локальной автоматизации.</p>
          
          <div class="card-devices">
            <span class="device-tag">Яндекс Станция (все модели)</span>
            <span class="device-tag">Домашний роутер Wi-Fi</span>
          </div>
          
          <a href="/troubleshooting/yandex-station-wifi-drop/" class="trouble-link font-outfit">
            Решение проблемы <span class="arrow">→</span>
          </a>
        </div>
        <div class="strip-image-wrap">
          <img 
            src={wifiDropImg.src} 
            alt="Инструкция по настройке Wi-Fi роутера для Яндекс Станции" 
            class="strip-image"
            loading="lazy"
            decoding="async"
            width="500"
            height="330"
          />
        </div>
      </div>

      <!-- Strip 3: Battery drain (Text left, Image right) -->
      <div class="trouble-strip glass">
        <div class="strip-content">
          <div class="card-header">
            <span class="difficulty-badge medium">СРЕДНЕ</span>
            <span class="date-badge">15 июня 2026</span>
          </div>
          <h3 class="strip-title font-outfit">Быстрый разряд батареек в беспроводных датчиках</h3>
          <p class="strip-desc">Почему Zigbee датчики Aqara/Tuya разряжают элементы CR2032 за пару недель. Разбор причин: плохой линк с хабом, радиопомехи, неправильные настройки интервала опроса и как это исправить.</p>
          
          <div class="card-devices">
            <span class="device-tag">Датчики движения / открытия</span>
            <span class="device-tag">Zigbee репитеры</span>
            <span class="device-tag">Батарейки CR2032</span>
          </div>
          
          <a href="/troubleshooting/battery-drain-troubleshooting/" class="trouble-link font-outfit">
            Решение проблемы <span class="arrow">→</span>
          </a>
        </div>
        <div class="strip-image-wrap">
          <img 
            src={batteryDrainImg.src} 
            alt="Инструкция по экономии батареек в датчиках умного дома" 
            class="strip-image"
            loading="lazy"
            decoding="async"
            width="500"
            height="330"
          />
        </div>
      </div>
    </div>

    <div class="view-all-container">
      <a href="/troubleshooting/" class="view-all-btn font-outfit">
        <span>Все разборы</span>
        <span class="view-all-arrow">→</span>
      </a>
    </div>
  </section>

  <!-- Latest Publications Section (SEO Boost) -->
  <section id="latest-publications" class="section-container latest-publications-section">
    <h2 class="section-title font-outfit"><span aria-hidden="true">⏱️</span> Свежие публикации</h2>
    <div class="section-divider"></div>
    <p class="section-desc">Новые материалы в нашей базе знаний. Раздел обновляется автоматически.</p>
    
    <div class="latest-cards-grid">
      {latestEntries.map(entry => {
        const isScenario = entry.data.category === 'scenario';
        const detailUrl = isScenario ? `/scenarios/${entry.id}/` : `/troubleshooting/${entry.id}/`;
        const categoryLabel = isScenario ? 'Сценарий' : 'Траблшутинг';
        const categoryClass = isScenario ? 'category-scenario' : 'category-troubleshooting';
        
        const dateStr = new Date(entry.data.publishDate).toLocaleDateString('ru-RU', {
          day: 'numeric',
          month: 'long',
          year: 'numeric'
        });
        
        return (
          <div class="latest-card glass">
            <div class="card-meta">
              <span class={`category-badge ${categoryClass}`}>{categoryLabel}</span>
              <span class="publish-date">{dateStr}</span>
            </div>
            <h3 class="card-title font-outfit">
              {entry.data.title}
            </h3>
            <p class="card-desc">{entry.data.description}</p>
            {entry.data.devices && entry.data.devices.length > 0 && (
              <div class="card-devices-list">
                {entry.data.devices.slice(0, 3).map(dev => (
                  <span class="device-tag-mini">{dev}</span>
                ))}
              </div>
            )}
            <div class="card-action-wrap">
              <a href={detailUrl} class="read-more-link font-outfit">
                Читать далее <span class="arrow" aria-hidden="true">→</span>
              </a>
            </div>
          </div>
        );
      })}
    </div>
  </section>
</Layout>

<style>
  /* Hero Section (Bento Grid) */
  .hero-section.bento-grid {
    position: relative;
    padding: 2.5rem 0 2.5rem 0;
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-template-rows: auto;
    gap: 1.5rem;
  }

  .bento-card {
    border-radius: 2.25rem;
    overflow: hidden;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 2;
  }

  .bento-card.glass {
    background: var(--bg-card);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid var(--border-primary);
    box-shadow: var(--shadow-md);
  }

  .bento-card-main {
    grid-column: span 7;
    padding: 3rem 3rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 1.25rem;
    text-align: left;
  }

  .bento-card-main .hero-title,
  .bento-card-main .hero-subtitle,
  .bento-card-main .hero-badge {
    margin: 0;
  }

  .bento-card-image {
    grid-column: span 5;
    border: 1px solid var(--border-primary);
    box-shadow: var(--shadow-md);
    position: relative;
    display: flex;
  }

  .bento-card-image .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 70%;
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .bento-card-image::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0) 60%, rgba(0, 0, 0, 0.2) 100%);
    z-index: 1;
    pointer-events: none;
  }

  .bento-card-feature {
    grid-column: span 4;
    padding: 2.25rem 2rem;
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    text-align: left;
  }

  /* Bento Hover Effects */
  .bento-card:hover {
    transform: translateY(-5px);
  }

  .bento-card.glass:hover {
    border-color: var(--border-hover);
    box-shadow: var(--shadow-lg), 0 0 25px var(--accent-alice-trans);
    background: var(--bg-hover);
  }

  .bento-card-image:hover {
    box-shadow: var(--shadow-lg), 0 0 35px var(--accent-cyan-glow);
  }

  .bento-card-image:hover .hero-image {
    transform: scale(1.03);
  }

  /* Text & Elements Inside Bento */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.45rem 1.15rem;
    background: var(--bg-surface);
    border: 1px solid var(--border-primary);
    color: var(--text-secondary);
    font-size: 0.8rem;
    font-weight: 700;
    border-radius: 99px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    box-shadow: var(--shadow-sm);
  }

  .hero-badge::before {
    content: '';
    width: 6px;
    height: 6px;
    background-color: var(--accent-emerald);
    border-radius: 50%;
    display: inline-block;
    box-shadow: 0 0 8px var(--accent-emerald);
    animation: badge-pulse 2s infinite;
  }

  @keyframes badge-pulse {
    0% {
      transform: scale(0.95);
      box-shadow: 0 0 0 0 rgba(5, 150, 105, 0.7);
    }
    70% {
      transform: scale(1.1);
      box-shadow: 0 0 0 6px rgba(5, 150, 105, 0);
    }
    100% {
      transform: scale(0.95);
      box-shadow: 0 0 0 0 rgba(5, 150, 105, 0);
    }
  }

  .hero-title {
    font-size: 3.25rem;
    line-height: 1.1;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--text-primary);
  }

  .accent-title-word {
    background: linear-gradient(135deg, var(--accent-alice) 0%, var(--accent-cyan) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    display: inline-block;
  }

  .hero-subtitle {
    font-size: 1.05rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .btn {
    padding: 0.9rem 2rem;
    border-radius: 99px;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .btn-primary {
    background: #0f172a;
    color: #ffffff;
    border: none;
    box-shadow: 0 4px 20px rgba(15, 23, 42, 0.1);
  }

  :global(.dark) .btn-primary {
    background: #f8fafc;
    color: #0f172a;
    box-shadow: 0 4px 20px rgba(255, 255, 255, 0.05);
  }

  .btn-primary:hover {
    transform: translateY(-2px) scale(1.02);
    box-shadow: 0 8px 30px rgba(15, 23, 42, 0.2);
    filter: brightness(1.05);
  }

  :global(.dark) .btn-primary:hover {
    box-shadow: 0 8px 30px rgba(255, 255, 255, 0.12);
  }

  .btn-arrow {
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .btn-primary:hover .btn-arrow {
    transform: translateX(4px);
  }

  .btn-secondary {
    background: var(--bg-surface);
    color: var(--text-primary);
    border: 1px solid var(--border-primary);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    box-shadow: var(--shadow-sm);
  }

  .btn-secondary:hover {
    background: var(--bg-hover);
    transform: translateY(-2px) scale(1.02);
    border-color: var(--border-hover);
  }

  /* Feature Card Inner Styles */
  .feature-icon {
    font-size: 1.85rem;
    padding: 0.75rem;
    background: var(--bg-hover);
    border-radius: 1.25rem;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border-item);
    transition: transform 0.3s ease;
  }

  .bento-card-feature:hover .feature-icon {
    transform: scale(1.15) rotate(5deg);
  }

  .feature-content {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .feature-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .feature-desc {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.45;
  }

  .hero-glow {
