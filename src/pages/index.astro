<script>
  function initHomepageInteractive() {
    const steps = document.querySelectorAll('.anatomy-step-btn');
    const nodes = document.querySelectorAll('.visual-node');
    const lines = document.querySelectorAll('.visual-lines .line');
    
    if (steps.length === 0) return;
    
    // Проверка инициализации для предотвращения повторной навески слушателей
    const firstStep = steps[0];
    if (firstStep.dataset.initialized) return;
    firstStep.dataset.initialized = 'true';
    
    steps.forEach(step => {
      // Инициализируем флаг для всех шагов
      step.dataset.initialized = 'true';
      
      step.addEventListener('click', () => {
        const stepNum = step.getAttribute('data-step');
        
        // 1. Активируем кнопку шага, сбрасываем остальные
        steps.forEach(s => {
          s.classList.remove('active');
          s.setAttribute('aria-selected', 'false');
        });
        step.classList.add('active');
        step.setAttribute('aria-selected', 'true');
        
        // 2. Сбрасываем активность со всех узлов и линий схемы
        nodes.forEach(node => node.classList.remove('active'));
        lines.forEach(line => line.classList.remove('active'));
        
        // Всегда подсвечиваем центральный хаб (Алису)
        const hubNode = document.getElementById('node-hub');
        if (hubNode) hubNode.classList.add('active');
        
        // 3. Подсвечиваем узлы и линии в зависимости от шага
        if (stepNum === '1') {
          // Шаг 1: Датчик движения -> Алиса
          const triggerNode = document.getElementById('node-trigger');
          const triggerLine = document.getElementById('line-trigger');
          if (triggerNode) triggerNode.classList.add('active');
          if (triggerLine) triggerLine.classList.add('active');
        } else if (stepNum === '2') {
          // Шаг 2: Алиса -> Кофемашина
          const action1Node = document.getElementById('node-action-1');
          const action1Line = document.getElementById('line-action-1');
          if (action1Node) action1Node.classList.add('active');
          if (action1Line) action1Line.classList.add('active');
        } else if (stepNum === '3') {
          // Шаг 3: Алиса -> Свет
          const action2Node = document.getElementById('node-action-2');
          const action2Line = document.getElementById('line-action-2');
          if (action2Node) action2Node.classList.add('active');
          if (action2Line) action2Line.classList.add('active');
        }
      });
    });
  }

  // Запуск при первой загрузке
  initHomepageInteractive();
  // Запуск при переходах View Transitions
  document.addEventListener('astro:page-load', initHomepageInteractive);
</script>

