<script>
  function initHomepageInteractive() {
    const steps = document.querySelectorAll('.anatomy-step-btn');
    const container = document.querySelector('.visual-container');
    const valIf = document.getElementById('logic-val-if');
    const valAnd = document.getElementById('logic-val-and');
    const valThen = document.getElementById('logic-val-then');
    const blockAnd = document.getElementById('logic-block-and');
    
    if (steps.length === 0 || !container) return;
    
    // Проверка инициализации для предотвращения повторной навески слушателей
    const firstStep = steps[0];
    if (firstStep.dataset.initialized) return;
    firstStep.dataset.initialized = 'true';

    const sceneData = {
      morning: {
        if: 'Датчик движения зафиксировал активность',
        and: 'Время суток с 07:00 до 09:00',
        then: 'Сварить кофе, включить лампу, запустить утренний плейлист'
      },
      away: {
        if: 'Датчик двери закрылся и замок заблокирован',
        and: null,
        then: 'Активировать камеру, запустить пылесос, выключить все приборы'
      },
      cinema: {
        if: 'Сказано Алисе: "Время кино"',
        and: null,
        then: 'Закрыть шторы, включить подсветку, запустить телевизор'
      }
    };
    
    steps.forEach(step => {
      step.dataset.initialized = 'true';
      
      step.addEventListener('click', () => {
        const scene = step.getAttribute('data-scene');
        
        steps.forEach(s => {
          s.classList.remove('active');
          s.setAttribute('aria-selected', 'false');
        });
        step.classList.add('active');
        step.setAttribute('aria-selected', 'true');
        
        // Переключаем активную сцену на контейнере
        container.setAttribute('data-active-scene', scene);
        
        // Обновляем логическую схему
        const data = sceneData[scene];
        if (data) {
          if (valIf) valIf.textContent = data.if;
          if (valThen) valThen.textContent = data.then;
          
          if (data.and) {
            if (valAnd) valAnd.textContent = data.and;
            if (blockAnd) blockAnd.style.display = 'flex';
          } else {
            if (blockAnd) blockAnd.style.display = 'none';
          }
        }
      });
    });
  }

  // Запуск при первой загрузке
  initHomepageInteractive();
  // Запуск при переходах View Transitions
  document.addEventListener('astro:page-load', initHomepageInteractive);
</script>

