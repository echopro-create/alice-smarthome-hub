---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import heroImage from "../assets/images/hero-main.png";
import batteryDrainImg from "../assets/images/steps/battery-drain-1.png";
import deviceNotRespondingImg from "../assets/images/steps/device-not-responding-1.png";
import wifiDropImg from "../assets/images/steps/wifi-drop-1.png";
import Layout from "../layouts/Layout.astro";
import { getDifficultyLabel } from "../utils/difficulty";

const allEntries = await getCollection("scenarios");

// Разделяем записи по категориям и сортируем по дате (самые свежие первые)
const scenarios = allEntries
	.filter((entry) => entry.data.category === "scenario")
	.sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());
const troubleshooting = allEntries
	.filter((entry) => entry.data.category === "troubleshooting")
	.sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());

const scenariosToShow = scenarios.slice(0, 6);
const troubleshootingToShow = troubleshooting.slice(0, 6);

const latestEntries = allEntries
	.sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime())
	.slice(0, 3);
---

<Layout 
  title="Пошаговые сценарии автоматизации и инструкции по настройке" 
  description="Библиотека пошаговых сценариев и руководств по траблшутингу для вашего Умного Дома с Алисой. Систематизируем опыт закрытых сообществ."
>
  <!-- Hero Section -->
  <section class="hero-section bento-grid">
    <!-- Main Card (Text & Actions) -->
    <div class="bento-card bento-card-main card-elevated">
      <div class="hero-badge font-outfit">База знаний Умного Дома</div>
      <h1 class="hero-title font-outfit">
        Сделайте ваш дом действительно <span class="accent-title-word">Умным</span> с Алисой
      </h1>
      <p class="hero-subtitle">
        Пошаговые руководства, детальные схемы интеграции и готовые решения проблем. Мы задокументировали и структурировали хаотичный опыт сотен технических сообществ и форумов.
      </p>
      <div class="hero-actions">
        <a href="/scenarios/" class="btn btn-primary font-outfit">
          Изучить сценарии
          <span class="btn-arrow" aria-hidden="true">→</span>
        </a>
        <a href="/troubleshooting/" class="btn btn-secondary font-outfit">База траблшутинга</a>
      </div>
    </div>

    <!-- Image Card -->
    <div class="bento-card bento-card-image">
      <Image 
        src={heroImage} 
        alt="Премиальный умный дом с Яндекс Станцией и датчиками" 
        class="hero-image"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        format="webp"
        width={634}
        height={476}
        sizes="(max-width: 768px) 100vw, 634px"
      />
    </div>

    <!-- Feature Card 1: Local Automation -->
    <div class="bento-card bento-card-feature card-outlined">
      <div class="feature-icon" aria-hidden="true">
        <svg class="feature-svg-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
      </div>
      <div class="feature-content">
        <div class="feature-title font-outfit">Локальность</div>
        <p class="feature-desc">Настройка сценариев автоматизации, работающих локально без интернета.</p>
      </div>
    </div>

    <!-- Feature Card 2: Compatibility -->
    <div class="bento-card bento-card-feature card-outlined">
      <div class="feature-icon" aria-hidden="true">
        <svg class="feature-svg-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m21 2-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0 3 3L22 7l-3-3m-3.5 3.5L19 4"></path></svg>
      </div>
      <div class="feature-content">
        <div class="feature-title font-outfit">Совместимость</div>
        <p class="feature-desc">Интеграция Zigbee, Matter и Wi-Fi устройств от разных брендов в единую сеть.</p>
      </div>
    </div>

    <!-- Feature Card 3: Troubleshooting -->
    <div class="bento-card bento-card-feature card-outlined">
      <div class="feature-icon" aria-hidden="true">
        <svg class="feature-svg-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path></svg>
      </div>
      <div class="feature-content">
        <div class="feature-title font-outfit">Решение проблем</div>
        <p class="feature-desc">Устранение задержек, отвалов беспроводных датчиков и радиопомех.</p>
      </div>
    </div>

    <div class="hero-glow"></div>
  </section>

  <!-- Stats Counters Section -->
  <section class="section-container stats-container">
    <div class="stats-grid">
      <div class="stat-card card-outlined">
        <span class="stat-number font-outfit" data-target="69">0</span>
        <span class="stat-label font-outfit">Инструкций и гайдов</span>
        <p class="stat-desc">Пошаговые руководства по автоматизации и решению проблем с Алисой.</p>
      </div>
      <div class="stat-card card-outlined">
        <span class="stat-number font-outfit" data-target="150">0</span>
        <span class="stat-label font-outfit">Устройств в базе</span>
        <p class="stat-desc">Проверенные на совместимость датчики, реле, лампы и приводы.</p>
      </div>
      <div class="stat-card card-outlined">
        <span class="stat-number font-outfit" data-target="12">0</span>
        <span class="stat-label font-outfit">Кластеров автоматизации</span>
        <p class="stat-desc">Тематические направления от климата до комплексной безопасности.</p>
      </div>
    </div>
  </section>

  <!-- Scenarios Section: Anatomy of Automation -->
  <section id="scenarios" class="section-container automation-anatomy-section">
    <h2 class="section-title font-outfit">
      <svg class="heading-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
      Один день с Алисой
    </h2>
    <div class="section-divider"></div>
    <p class="section-desc">Выберите сценарий, чтобы увидеть работу датчиков и устройств умного дома в реальном времени.</p>
    
    <div class="anatomy-grid card-elevated">
      <!-- Left: Interactive steps (tabs) -->
      <div class="anatomy-steps" role="tablist" aria-label="Сценарии автоматизации">
        <button class="anatomy-step-btn active" data-scene="morning" aria-selected="true" role="tab" id="scene-tab-morning" aria-controls="anatomy-dashboard">
          <span class="step-num font-outfit">
            <svg class="step-svg-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2"></path><path d="M12 20v2"></path><path d="M4.93 4.93l1.41 1.41"></path><path d="M17.66 17.66l1.41 1.41"></path><path d="M2 12h2"></path><path d="M20 12h2"></path><path d="M6.34 17.66l-1.41 1.41"></path><path d="M19.07 4.93l-1.41 1.41"></path></svg>
          </span>
          <div class="step-text">
            <h3 class="step-title font-outfit">07:30 — Утреннее пробуждение</h3>
            <p class="step-desc">Мягкий старт дня: плавное включение света, свежий кофе и утреннее шоу Алисы.</p>
          </div>
        </button>
        <button class="anatomy-step-btn" data-scene="away" aria-selected="false" role="tab" id="scene-tab-away" aria-controls="anatomy-dashboard">
          <span class="step-num font-outfit">
            <svg class="step-svg-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
          </span>
          <div class="step-text">
            <h3 class="step-title font-outfit">09:00 — Все ушли (Охрана)</h3>
            <p class="step-desc">Автоматическое сбережение энергии, активация видеокамер и запуск уборки.</p>
          </div>
        </button>
        <button class="anatomy-step-btn" data-scene="cinema" aria-selected="false" role="tab" id="scene-tab-cinema" aria-controls="anatomy-dashboard">
          <span class="step-num font-outfit">
            <svg class="step-svg-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="15" x="2" y="3" rx="2"></rect><path d="M12 18v4"></path><path d="M8 22h8"></path></svg>
          </span>
          <div class="step-text">
            <h3 class="step-title font-outfit">20:00 — Вечерний уют</h3>
            <p class="step-desc">Создание идеальной атмосферы: закрытие штор, приглушенный неон и включение кино.</p>
          </div>
        </button>
      </div>
      <div class="anatomy-link-wrapper">
        <a href="/scenarios/" class="card-link font-outfit">
          Все сценарии автоматизации <span class="arrow">→</span>
        </a>
      </div>
      
      <!-- Right: Minimalist Dashboard -->
      <div class="anatomy-dashboard card-flat" id="anatomy-dashboard" role="tabpanel" aria-label="Описание сценария">
        <h3 class="dashboard-title font-outfit" id="dash-title">Утреннее пробуждение</h3>
        
        <!-- Logic Builder Panel -->
        <div class="logic-scheme">
          <div class="logic-block logic-if">
            <span class="logic-label font-outfit">ЕСЛИ</span>
            <span class="logic-value" id="logic-val-if">Датчик движения зафиксировал активность</span>
          </div>
          <div class="logic-block logic-and" id="logic-block-and">
            <span class="logic-label font-outfit">И</span>
            <span class="logic-value" id="logic-val-and">Время суток с 07:00 до 09:00</span>
          </div>
          <div class="logic-block logic-then">
            <span class="logic-label font-outfit">ТО</span>
            <span class="logic-value" id="logic-val-then">Сварить кофе, включить лампу, запустить утренний плейлист</span>
          </div>
        </div>

        <!-- Devices Section -->
        <div class="dashboard-devices-section">
          <h4 class="devices-section-title font-outfit">Необходимое оборудование</h4>
          <div class="dashboard-devices-list" id="dash-devices">
            <div class="device-item-row">
              <span class="device-item-icon">🚶‍♂️</span>
              <div class="device-item-info">
                <span class="device-item-name">Датчик движения Aqara</span>
                <span class="device-item-protocol">Zigbee 3.0</span>
              </div>
            </div>
            <div class="device-item-row">
              <span class="device-item-icon">🔊</span>
              <div class="device-item-info">
                <span class="device-item-name">Яндекс Станция</span>
                <span class="device-item-protocol">Wi-Fi</span>
              </div>
            </div>
            <div class="device-item-row">
              <span class="device-item-icon">☕</span>
              <div class="device-item-info">
                <span class="device-item-name">Умная розетка Tuya</span>
                <span class="device-item-protocol">Zigbee</span>
              </div>
            </div>
            <div class="device-item-row">
              <span class="device-item-icon">💡</span>
              <div class="device-item-info">
                <span class="device-item-name">Умная лампа Яндекс</span>
                <span class="device-item-protocol">Wi-Fi / Matter</span>
              </div>
            </div>
          </div>
        </div>

        <div class="dashboard-action-wrap">
          <a href="/scenarios/morning-coffee/" class="btn btn-secondary font-outfit" id="dash-link">
            Читать гайд по настройке <span class="arrow">→</span>
          </a>
        </div>
      </div>
    </div>

    <div class="view-all-container">
      <a href="/scenarios/" class="view-all-btn font-outfit">
        <span>Все сценарии</span>
        <span class="view-all-arrow">→</span>
      </a>
    </div>
  </section>

  <!-- Troubleshooting Section: Feature Strips (Z-pattern) -->
  <section id="troubleshooting" class="section-container troubleshooting-strips-section">
    <div class="trouble-glow" aria-hidden="true"></div>
    <h2 class="section-title font-outfit">
      <svg class="heading-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path></svg>
      База траблшутинга
    </h2>
    <div class="section-divider"></div>
    <p class="section-desc">Пошаговое решение критических сбоев, борьба с радиопомехами и отвалами беспроводных датчиков.</p>
    
    <div class="troubleshooting-strips-list">
      <!-- Strip 1: Device not responding (Text left, Image right) -->
      <div class="trouble-strip card-elevated">
        <div class="strip-content">
          <div class="card-header">
            <span class="difficulty-badge easy">ЛЕГКО</span>
            <span class="date-badge">20 июня 2026</span>
          </div>
          <h3 class="strip-title font-outfit">Устройство не отвечает в Доме с Алисой: причины решения</h3>
          <p class="strip-desc">Подробный разбор причин отвала розеток, ламп и датчиков. Диагностика проблем питания, забитого радиоэфира и сбоев интеграции в облачных или локальных сценариях.</p>
          
          <div class="card-devices">
            <span class="device-tag">Яндекс Станция</span>
            <span class="device-tag">Умная розетка</span>
            <span class="device-tag">Датчик температуры</span>
          </div>
          
          <a href="/troubleshooting/device-not-responding/" class="trouble-link font-outfit">
            Решение проблемы <span class="arrow">→</span>
          </a>
        </div>
        <div class="strip-image-wrap">
          <Image 
            src={deviceNotRespondingImg} 
            alt="Схема решения ошибки Устройство не отвечает в приложении Умный Дом с Алисой" 
            class="strip-image"
            loading="lazy"
            format="webp"
            sizes="(max-width: 992px) 100vw, 420px"
            width={500}
            height={330}
          />
        </div>
      </div>

      <!-- Strip 2: Wifi drop (Image left, Text right) -->
      <div class="trouble-strip card-elevated reverse">
        <div class="strip-content">
          <div class="card-header">
            <span class="difficulty-badge easy">ЛЕГКО</span>
            <span class="date-badge">18 июня 2026</span>
          </div>
          <h3 class="strip-title font-outfit">Яндекс Станция теряет Wi-Fi и отключается от сети</h3>
          <p class="strip-desc">Устранение постоянных обрывов Wi-Fi соединения на колонках Алиса. Оптимальная настройка домашнего роутера, выбор частоты 5 ГГц и свободных каналов для стабильной локальной автоматизации.</p>
          
          <div class="card-devices">
            <span class="device-tag">Яндекс Станция (все модели)</span>
            <span class="device-tag">Домашний роутер Wi-Fi</span>
          </div>
          
          <a href="/troubleshooting/yandex-station-wifi-drop/" class="trouble-link font-outfit">
            Решение проблемы <span class="arrow">→</span>
          </a>
        </div>
        <div class="strip-image-wrap">
          <Image 
            src={wifiDropImg} 
            alt="Инструкция по настройке Wi-Fi роутера для Яндекс Станции" 
            class="strip-image"
            loading="lazy"
            format="webp"
            sizes="(max-width: 992px) 100vw, 420px"
            width={500}
            height={330}
          />
        </div>
      </div>

      <!-- Strip 3: Battery drain (Text left, Image right) -->
      <div class="trouble-strip card-elevated">
        <div class="strip-content">
          <div class="card-header">
            <span class="difficulty-badge medium">СРЕДНЕ</span>
            <span class="date-badge">15 июня 2026</span>
          </div>
          <h3 class="strip-title font-outfit">Быстрый разряд батареек в беспроводных датчиках</h3>
          <p class="strip-desc">Почему Zigbee датчики Aqara/Tuya разряжают элементы CR2032 за пару недель. Разбор причин: плохой линк с хабом, радиопомехи, неправильные настройки интервала опроса и как это исправить.</p>
          
          <div class="card-devices">
            <span class="device-tag">Датчики движения / открытия</span>
            <span class="device-tag">Zigbee репитеры</span>
            <span class="device-tag">Батарейки CR2032</span>
          </div>
          
          <a href="/troubleshooting/battery-drain-troubleshooting/" class="trouble-link font-outfit">
            Решение проблемы <span class="arrow">→</span>
          </a>
        </div>
        <div class="strip-image-wrap">
          <Image 
            src={batteryDrainImg} 
            alt="Инструкция по экономии батареек в датчиках умного дома" 
            class="strip-image"
            loading="lazy"
            format="webp"
            sizes="(max-width: 992px) 100vw, 420px"
            width={500}
            height={330}
          />
        </div>
      </div>
    </div>

    <div class="view-all-container">
      <a href="/troubleshooting/" class="view-all-btn font-outfit">
        <span>Все разборы</span>
        <span class="view-all-arrow">→</span>
      </a>
    </div>
  </section>

  <!-- Latest Publications Section (SEO Boost) -->
  <section id="latest-publications" class="section-container latest-publications-section">
    <h2 class="section-title font-outfit">
      <svg class="heading-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      Свежие публикации
    </h2>
    <div class="section-divider"></div>
    <p class="section-desc">Новые материалы в нашей базе знаний. Раздел обновляется автоматически.</p>
    
    <div class="latest-cards-grid">
      {latestEntries.map(entry => {
        const isScenario = entry.data.category === 'scenario';
        const detailUrl = isScenario ? `/scenarios/${entry.id}/` : `/troubleshooting/${entry.id}/`;
        const categoryLabel = isScenario ? 'Сценарий' : 'Траблшутинг';
        const categoryClass = isScenario ? 'category-scenario' : 'category-troubleshooting';
        
        const dateStr = new Date(entry.data.publishDate).toLocaleDateString('ru-RU', {
          day: 'numeric',
          month: 'long',
          year: 'numeric'
        });
        
        return (
          <div class="latest-card card-outlined">
            <div class="card-meta">
              <span class={`category-badge ${categoryClass}`}>{categoryLabel}</span>
              <span class="publish-date">{dateStr}</span>
            </div>
            <h3 class="card-title font-outfit">
              {entry.data.title}
            </h3>
            <p class="card-desc">{entry.data.description}</p>
            {entry.data.devices && entry.data.devices.length > 0 && (
              <div class="card-devices-list">
                {entry.data.devices.slice(0, 3).map(dev => (
                  <span class="device-tag-mini">{dev}</span>
                ))}
              </div>
            )}
            <div class="card-action-wrap">
              <a href={detailUrl} class="read-more-link font-outfit">
                Читать далее <span class="arrow" aria-hidden="true">→</span>
              </a>
            </div>
          </div>
        );
      })}
    </div>
  </section>
</Layout>

<style>
  /* Hero Section (Bento Grid) */
  .hero-section.bento-grid {
    position: relative;
    padding: 2.5rem 0 2.5rem 0;
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-template-rows: auto;
    gap: 1.5rem;
  }

  .bento-card {
    border-radius: 2.25rem;
    overflow: hidden;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 2;
  }

  .bento-card-main {
    grid-column: span 7;
    padding: 3rem 3rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 1.25rem;
    text-align: left;
  }

  .bento-card-main .hero-title,
  .bento-card-main .hero-subtitle,
  .bento-card-main .hero-badge {
    margin: 0;
  }

  .bento-card-image {
    grid-column: span 5;
    position: relative;
    display: flex;
  }

