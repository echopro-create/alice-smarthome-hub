---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import heroImage from "../assets/images/hero-main.png";
import Layout from "../layouts/Layout.astro";

const allEntries = await getCollection("scenarios");

// Сортируем все записи по дате (самые свежие первые)
const sortedEntries = allEntries.sort(
	(a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime()
);

// Разделяем на сценарии и траблшутинг
const scenarios = sortedEntries.filter((e) => e.data.category === "scenario").slice(0, 5);
const troubleshooting = sortedEntries.filter((e) => e.data.category === "troubleshooting").slice(0, 3);

// Функция расчета времени чтения
const getReadingTime = (item: (typeof allEntries)[number]) => {
	const descWords = item.data.description ? item.data.description.split(/\s+/).length : 0;
	const stepsWords = item.data.steps
		? item.data.steps.reduce((sum: number, s) => sum + (s.text ? s.text.split(/\s+/).length : 0), 0)
		: 0;
	const wordsPerMinute = 180;
	return Math.ceil((descWords + stepsWords) / wordsPerMinute) || 2;
};
---

<Layout 
  title="Пошаговые сценарии автоматизации и инструкции по настройке" 
  description="Библиотека пошаговых сценариев и руководств по траблшутингу для вашего Умного Дома с Алисой. Систематизируем опыт закрытых сообществ."
>
  <section class="hero-section">
    <div class="hero-text">
      <div class="hero-badge font-mono">
        <span class="badge-dot"></span>
        <span>Интерактивный хаб</span>
      </div>
      <h1 class="hero-title font-outfit">База знаний <span class="hero-brand-gradient">«Умный Дом с Алисой»</span></h1>
      <p class="hero-desc">
        Пошаговые руководства, схемы интеграции и готовые решения. Опыт сотен технических сообществ — в структурированных инструкциях.
      </p>
      <div class="hero-actions">
        <a href="/scenarios/" class="hero-btn primary-btn font-outfit">Каталог сценариев</a>
        <a href="/troubleshooting/" class="hero-btn secondary-btn font-outfit">Решение неполадок</a>
      </div>
    </div>
    
    <div class="hero-search">
      <button id="hero-search-trigger" class="hero-search-box" aria-label="Поиск по базе знаний">
        <svg class="search-icon-svg" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <span class="hero-search-placeholder">Название устройства, бренд или неисправность...</span>
        <kbd class="hero-search-shortcut">⌘K</kbd>
      </button>
      <p class="hero-brands"><span class="brands-label">Искать по брендам:</span> <a href="/compatibility/?search=aqara" class="brand-link">Aqara</a>, <a href="/compatibility/?search=tuya" class="brand-link">Tuya</a>, <a href="/compatibility/?search=яндекс" class="brand-link">Яндекс</a>, <a href="/compatibility/?search=yeelight" class="brand-link">Yeelight</a>, <a href="/compatibility/?search=sonoff" class="brand-link">Sonoff</a>, <a href="/compatibility/?search=xiaomi" class="brand-link">Xiaomi</a></p>
    </div>

    <div style="display: none;">
      <Image 
        src={heroImage} 
        alt="Схема Умного Дома с Алисой" 
        class="hero-image"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
    </div>
  </section>

  <!-- Stats Section (Minimalist) -->
  <section class="stats-section-minimal">
    <div class="stats-grid-minimal">
      <div class="stat-item-minimal">
        <span class="stat-number font-outfit" data-target="69">0</span>
        <span class="stat-label-minimal font-outfit">Инструкций и гайдов</span>
      </div>
      <div class="stat-item-minimal">
        <span class="stat-number font-outfit" data-target="150">0</span>
        <span class="stat-label-minimal font-outfit">Устройств в базе</span>
      </div>
      <div class="stat-item-minimal">
        <span class="stat-number font-outfit" data-target="12">0</span>
        <span class="stat-label-minimal font-outfit">Направлений автоматизации</span>
      </div>
    </div>
  </section>

  <!-- Troubleshooting strips section (instead of terminal) -->
  <section id="troubleshooting-strips" class="troubleshooting-strips-section">
    <header class="section-header">
      <span class="section-label font-mono">01 / Траблшутинг</span>
      <h2 class="section-title font-outfit">Решения неисправностей</h2>
      <p class="section-desc">Пошаговое устранение сбоев, борьба с радиопомехами и отвалами беспроводных датчиков.</p>
    </header>
    
    <div class="trouble-strips-container">
      {troubleshooting.map((item) => {
        const url = `/troubleshooting/${item.id}/`;
        return (
          <div class="trouble-strip card-elevated">
            <div class="strip-content">
              <div class="strip-meta">
                <span class={`difficulty-badge font-mono ${item.data.difficulty || 'easy'}`}>{item.data.difficulty || 'easy'}</span>
                <span class="strip-date font-mono">{new Date(item.data.publishDate).toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
              </div>
              <a href={url} class="strip-title-link">
                <h3 class="strip-title">{item.data.title}</h3>
              </a>
              <p class="strip-desc">{item.data.description}</p>
              {item.data.devices && item.data.devices.length > 0 && (
                <div class="strip-devices font-mono">
                  {item.data.devices.slice(0, 3).map(dev => (
                    <a href={`/compatibility/?search=${encodeURIComponent(dev.toLowerCase())}`} class="device-tag">{dev}</a>
                  ))}
                </div>
              )}
            </div>
            <a href={url} class="strip-action-link font-mono">Решение проблемы →</a>
          </div>
        );
      })}
    </div>
  </section>

  <!-- Chronological Articles List (Scenarios Only) -->
  <section id="latest-publications" class="articles-list-section">
    <header class="section-header">
      <span class="section-label font-mono">02 / Автоматизация</span>
      <h2 class="articles-section-title font-outfit">Последние сценарии автоматизации</h2>
      <p class="articles-section-desc">Новые пошаговые сценарии для настройки вашего Умного Дома.</p>
    </header>
    
    <div class="scenarios-container">
      <ul class="scenario-flat-list">
        {scenarios.map(item => {
          const url = `/scenarios/${item.id}/`;
          const dateStr = new Date(item.data.publishDate)
            .toLocaleDateString('ru-RU', { month: 'short', day: 'numeric' })
            .replace('.', '');
          const readingTime = getReadingTime(item);
          
          return (
            <li class="scenario-flat-item">
              <div class="scenario-item-meta font-mono">
                <span class="scenario-item-date">{dateStr}</span>
                <span class="scenario-item-category">сценарий</span>
                <span class="scenario-item-time">⚡ {readingTime} мин</span>
              </div>
              <div class="scenario-item-content">
                <a href={url} class="scenario-item-link">
                  <h3 class="scenario-item-title">{item.data.title}</h3>
                </a>
                <p class="scenario-item-desc">{item.data.description}</p>
                {item.data.devices && item.data.devices.length > 0 && (
                  <div class="scenario-item-devices font-mono">
                    <span class="devices-label">Оборудование:</span>
                    {item.data.devices.slice(0, 4).map(dev => (
                      <a href={`/compatibility/?search=${encodeURIComponent(dev.toLowerCase())}`} class="device-tag">{dev}</a>
                    ))}
                  </div>
                )}
              </div>
            </li>
          );
        })}
      </ul>
    </div>

    <div class="archive-links font-mono">
      <a href="/scenarios/" class="archive-link">Все сценарии автоматизации →</a>
      <a href="/troubleshooting/" class="archive-link">Все решения неисправностей →</a>
    </div>
  </section>
</Layout>

<style>
  /* Hero Section */
  .hero-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    padding: 3rem 0 2.5rem 0;
    border-bottom: 1px solid var(--border-primary);
    margin-bottom: 0;
  }
  .hero-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.75rem;
    background: var(--bg-hover);
    border: 1px solid var(--border-primary);
    border-radius: 99px;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--accent-signature);
    margin-bottom: 0.25rem;
  }
  .badge-dot {
    width: 6px;
    height: 6px;
    background: var(--accent-signature);
    border-radius: 50%;
    display: inline-block;
    box-shadow: 0 0 8px var(--accent-signature);
  }
  .hero-title {
    font-size: clamp(2rem, 3.5vw, 2.75rem);
    font-weight: 900;
    line-height: 1.15;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    text-wrap: balance;
  }
  .hero-brand-gradient {
    background: linear-gradient(135deg, var(--accent-signature) 0%, #8b5cf6 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    display: inline-block;
  }
  .hero-desc {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 500px;
    text-wrap: pretty;
  }
  .hero-actions {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }
  .hero-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.6rem 1.5rem;
    font-size: 0.9rem;
    font-weight: 700;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: all 0.2s ease;
  }
  .primary-btn {
    background: var(--accent-signature);
    color: var(--text-white);
    border: 1px solid var(--accent-signature);
  }
  .primary-btn:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }
  .secondary-btn {
    background: transparent;
    color: var(--text-primary);
    border: 1px solid var(--border-primary);
  }
  .secondary-btn:hover {
    background: var(--bg-hover);
    border-color: var(--border-hover);
  }
  .hero-search {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    max-width: 580px;
    margin: 0 auto;
  }
  .hero-search-box {
    display: flex;
    align-items: center;
    width: 100%;
    height: 52px;
    padding: 0 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-md);
    color: var(--text-secondary);
    cursor: pointer;
    text-align: left;
    transition: all 0.2s ease;
    gap: 0.75rem;
  }
  .hero-search-box:hover {
    border-color: var(--border-hover);
    background: var(--bg-hover);
  }
  .search-icon-svg {
    color: var(--text-muted);
    flex-shrink: 0;
  }
  .hero-search-box:hover .search-icon-svg {
    color: var(--accent-signature);
  }
  .hero-search-placeholder {
    font-size: 0.9rem;
    color: var(--text-muted);
    flex-grow: 1;
    user-select: none;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
  }
  .hero-search-shortcut {
    font-size: 0.75rem;
    background: var(--bg-hover);
    border: 1px solid var(--border-primary);
    padding: 0.1rem 0.35rem;
    border-radius: 4px;
    color: var(--text-muted);
    font-weight: 600;
    font-family: monospace;
    flex-shrink: 0;
  }
  .hero-brands {
    margin: 0.75rem 0 0 0;
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.6;
    text-align: center;
  }
  .brands-label {
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.7rem;
    margin-right: 0.35rem;
  }
  .brand-link {
    color: var(--text-muted);
    text-decoration: none;
    font-weight: 500;
  }
  .brand-link:hover {
    color: var(--accent-signature);
  }

  /* Minimalist Stats Section */
  .stats-section-minimal {
    border-bottom: 1px solid var(--border-primary);
    padding: 1.5rem 0;
    margin: 0 0 2rem 0;
  }
  .stats-grid-minimal {
    display: flex;
    justify-content: center;
    gap: 4rem;
    flex-wrap: wrap;
  }
  .stat-item-minimal {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.25rem;
  }
  .stat-item-minimal .stat-number {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--accent-signature);
    line-height: 1.2;
  }
  .stat-label-minimal {
    font-size: 0.85rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Troubleshooting Strips */
  .troubleshooting-strips-section {
    margin: 4rem 0 5rem 0;
    scroll-margin-top: 5.5rem;
  }
  .articles-list-section {
    margin: 0 0 5rem 0;
    scroll-margin-top: 5.5rem;
  }
  .section-header {
    position: relative;
    margin-bottom: 2.5rem;
    padding: 0.85rem 1.75rem;
    border: 1px solid var(--border-primary);
    border-left: 4px solid var(--accent-signature);
    background: var(--bg-hover);
    border-radius: 12px;
  }
  .section-label {
    display: block;
    font-size: 0.7rem;
    color: var(--accent-signature);
    letter-spacing: 0.15em;
    margin: 0 0 0.35rem 0;
    text-transform: uppercase;
    font-weight: 700;
  }
  .section-title {
    font-size: 1.8rem;
    font-weight: 800;
    margin: 0 0 0.5rem 0;
    color: var(--text-primary);
    line-height: 1.15;
    letter-spacing: -0.02em;
  }
  .section-desc {
    font-size: 0.95rem;
    color: var(--text-secondary);
    margin: 0;
    line-height: 1.5;
    max-width: 600px;
  }
  .trouble-strips-container {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .trouble-strip {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    border: 1px solid var(--border-primary);
    background: transparent;
    border-radius: var(--radius-md);
    transition: border-color 0.25s ease, background-color 0.25s ease;
    box-shadow: var(--shadow-sm);
    padding: 2rem;
    text-decoration: none;
  }
  .trouble-strip:hover {
    border-color: var(--border-hover);
  }
  .strip-content {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
    min-width: 0;
  }
  .strip-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }
  .difficulty-badge {
    text-transform: uppercase;
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    padding: 0.1rem 0.4rem;
    border-radius: var(--radius-sm);
  }
  .difficulty-badge.easy {
    background: var(--diff-easy-bg);
    color: var(--diff-easy-text);
    border: 1px solid var(--diff-easy-border);
  }
  .difficulty-badge.medium {
    background: var(--diff-medium-bg);
    color: var(--diff-medium-text);
    border: 1px solid var(--diff-medium-border);
  }
  .difficulty-badge.hard {
    background: var(--diff-hard-bg);
    color: var(--diff-hard-text);
    border: 1px solid var(--diff-hard-border);
  }
  .strip-title-link {
    text-decoration: none;
    min-width: 0;
  }
  .strip-title {
    font-size: 1.35rem;
    font-weight: 800;
    margin: 0;
    color: var(--text-primary);
    transition: color 0.2s ease;
    line-height: 1.3;
  }
  .strip-title-link:hover .strip-title {
    color: var(--accent-signature);
  }
  .strip-desc {
    font-size: 0.95rem;
    color: var(--text-secondary);
    margin: 0;
    line-height: 1.5;
    max-width: 800px; /* Удобная ширина строки для чтения */
  }
  .strip-devices {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .device-tag {
    font-size: 0.75rem;
    color: var(--text-secondary);
    background: var(--bg-hover);
    border: 1px solid var(--border-primary);
    padding: 0.2rem 0.6rem;
    border-radius: 99px; /* Скругленные теги */
    text-decoration: none;
    transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease;
    font-weight: 500;
  }
  .device-tag:hover {
    background: var(--accent-alice-trans);
    border-color: var(--border-hover);
    color: var(--accent-alice);
  }
  .strip-action-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background: var(--bg-hover);
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-sm);
    color: var(--accent-signature);
    font-weight: 600;
    text-decoration: none;
    transition: all 0.25s ease;
    white-space: nowrap;
    font-size: 0.9rem;
  }
  .strip-action-link:hover {
    background: var(--accent-signature);
    color: var(--bg-main);
    border-color: var(--accent-signature);
    box-shadow: 0 4px 10px var(--accent-signature-glow);
  }

  /* Flat lists timeline & archives */
  .articles-section-title {
    font-size: 1.8rem;
    font-weight: 800;
    margin: 0 0 0.5rem 0;
    color: var(--text-primary);
    line-height: 1.15;
    letter-spacing: -0.02em;
  }
  .articles-section-desc {
    font-size: 0.95rem;
    color: var(--text-secondary);
    margin: 0;
    line-height: 1.5;
    max-width: 600px;
  }
  .archive-links {
    margin-top: 2.5rem;
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    border-top: 1px solid var(--border-primary);
    padding-top: 1.5rem;
  }
  .archive-link {
    font-size: 0.95rem;
    color: var(--accent-signature);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }
  .archive-link:hover {
    opacity: 0.8;
    text-decoration: underline;
  }

  /* Scenario Flat List (Two-column layout) */
  .scenario-flat-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }
  .scenario-flat-item {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border-primary);
  }
  .scenario-flat-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
  .scenario-item-meta {
    width: 120px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  .scenario-item-date {
    font-size: 0.85rem;
    color: var(--text-muted);
  }
  .scenario-item-category {
    color: var(--accent-signature);
    text-transform: uppercase;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.05em;
  }
  .scenario-item-time {
    color: var(--text-muted);
  }
  .scenario-item-content {
    flex-grow: 1;
    min-width: 0;
  }
  .scenario-item-link {
    text-decoration: none;
  }
  .scenario-item-title {
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--text-primary);
    transition: color 0.2s ease;
  }
  .scenario-item-link:hover .scenario-item-title {
    color: var(--accent-signature);
  }
  .scenario-item-desc {
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--text-secondary);
    margin-bottom: 0.75rem;
  }
  .scenario-item-devices {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  .devices-label {
    margin-right: 0.25rem;
  }

  @media (max-width: 768px) {
    .hero-section {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      padding: 2rem 0 2rem 0;
    }
    .hero-title {
      font-size: 1.75rem;
    }
    .hero-actions {
      flex-direction: column;
    }
    .hero-btn {
      width: 100%;
    }
    .page-heading {
      font-size: 2rem;
    }
  }

  @media (max-width: 992px) {
    .trouble-strip {
      flex-direction: column;
      align-items: stretch;
      gap: 1.5rem;
      padding: 1.5rem;
    }
    .strip-action-link {
      width: 100%;
      justify-content: center;
    }
    .scenario-flat-item {
      flex-direction: column;
      gap: 0.75rem;
    }
    .scenario-item-meta {
      width: 100%;
      flex-direction: row;
      align-items: center;
      gap: 1rem;
      border-bottom: 1px dashed var(--border-primary);
      padding-bottom: 0.35rem;
    }
  }

  @media (max-width: 640px) {
    .stats-grid-minimal {
      flex-direction: column;
      gap: 1.5rem;
    }
  }

</style>

<script>
  function initHomepageInteractive() {
    // Hero Search Trigger
    const heroTrigger = document.getElementById('hero-search-trigger');
    const mainTrigger = document.getElementById('search-trigger');
    if (heroTrigger && mainTrigger) {
      heroTrigger.addEventListener('click', () => {
        mainTrigger.click();
      });
    }

    // Stats Counters Animation
    const stats = document.querySelectorAll('.stat-number');
    if (stats.length > 0) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const target = entry.target;
            const targetVal = parseInt(target.getAttribute('data-target') || '0', 10);
            let current = 0;
            const step = Math.ceil(targetVal / 40) || 1;
            const interval = setInterval(() => {
              current += step;
              if (current >= targetVal) {
                current = targetVal;
                clearInterval(interval);
                target.textContent = targetVal + (targetVal === 150 ? '+' : '');
              } else {
                target.textContent = current.toString();
              }
            }, 30);
            observer.unobserve(target);
          }
        });
      }, { threshold: 0.1 });

      stats.forEach(stat => observer.observe(stat));
    }
  }

  // Запуск при первой загрузке
  initHomepageInteractive();
  // Запуск при переходах View Transitions
  document.addEventListener('astro:page-load', initHomepageInteractive);
</script>
