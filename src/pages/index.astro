---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { getDifficultyLabel } from '../utils/difficulty';
import heroImage from '../assets/images/hero-main.png';

const allEntries = await getCollection('scenarios');

// Разделяем записи по категориям и сортируем по дате (самые свежие первые)
const scenarios = allEntries
  .filter(entry => entry.data.category === 'scenario')
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());
const troubleshooting = allEntries
  .filter(entry => entry.data.category === 'troubleshooting')
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());

const scenariosToShow = scenarios.slice(0, 6);
const troubleshootingToShow = troubleshooting.slice(0, 6);
---

<Layout 
  title="Пошаговые сценарии автоматизации и инструкции по настройке" 
  description="Библиотека пошаговых сценариев и руководств по траблшутингу для вашего Умного Дома с Алисой. Систематизируем опыт закрытых сообществ."
>
  <!-- Hero Section -->
  <section class="hero-section bento-grid">
    <!-- Main Card (Text & Actions) -->
    <div class="bento-card bento-card-main glass">
      <div class="hero-badge font-outfit">База знаний Умного Дома</div>
      <h1 class="hero-title font-outfit">
        Сделайте ваш дом действительно <span class="accent-title-word">Умным</span> с Алисой
      </h1>
      <p class="hero-subtitle">
        Пошаговые руководства, детальные схемы интеграции и готовые решения проблем. Мы задокументировали и структурировали хаотичный опыт сотен технических сообществ и форумов.
      </p>
      <div class="hero-actions">
        <a href="/scenarios/" class="btn btn-primary font-outfit">
          Изучить сценарии
          <span class="btn-arrow" aria-hidden="true">→</span>
        </a>
        <a href="/troubleshooting/" class="btn btn-secondary font-outfit">База траблшутинга</a>
      </div>
    </div>

    <!-- Image Card -->
    <div class="bento-card bento-card-image">
      <img 
        src={heroImage.src} 
        alt="Премиальный умный дом с Яндекс Станцией и датчиками" 
        class="hero-image"
        loading="lazy"
        decoding="async"
        width="600"
        height="450"
      />
    </div>

    <!-- Feature Card 1: Local Automation -->
    <div class="bento-card bento-card-feature glass">
      <div class="feature-icon" aria-hidden="true">⚡</div>
      <div class="feature-content">
        <div class="feature-title font-outfit">Локальность</div>
        <p class="feature-desc">Настройка сценариев автоматизации, работающих локально без интернета.</p>
      </div>
    </div>

    <!-- Feature Card 2: Compatibility -->
    <div class="bento-card bento-card-feature glass">
      <div class="feature-icon" aria-hidden="true">🔌</div>
      <div class="feature-content">
        <div class="feature-title font-outfit">Совместимость</div>
        <p class="feature-desc">Интеграция Zigbee, Matter и Wi-Fi устройств от разных брендов в единую сеть.</p>
      </div>
    </div>

    <!-- Feature Card 3: Troubleshooting -->
    <div class="bento-card bento-card-feature glass">
      <div class="feature-icon" aria-hidden="true">🔧</div>
      <div class="feature-content">
        <div class="feature-title font-outfit">Решение проблем</div>
        <p class="feature-desc">Устранение задержек, отвалов беспроводных датчиков и радиопомех.</p>
      </div>
    </div>

    <div class="hero-glow"></div>
  </section>

  <!-- Scenarios Grid Section -->
  <section id="scenarios" class="section-container">
    <h2 class="section-title font-outfit"><span aria-hidden="true">🔮</span> Библиотека сценариев</h2>
    <div class="section-divider"></div>
    <p class="section-desc">Готовые алгоритмы автоматизации: от утренних рутин до комплексных систем безопасности.</p>
    
    <div class="scenarios-grid">
      {scenariosToShow.map((scenario) => (
        <a href={`/scenarios/${scenario.id}`} class="scenario-card glass">
          <div class="card-header">
            <span class={`difficulty-badge ${scenario.data.difficulty}`}>
              {getDifficultyLabel(scenario.data.difficulty)}
            </span>
            <span class="date-badge">
              {new Date(scenario.data.publishDate).toLocaleDateString('ru-RU', { year: 'numeric', month: 'long', day: 'numeric' })}
            </span>
          </div>
          <h3 class="card-title font-outfit">{scenario.data.title}</h3>
          <p class="card-desc">{scenario.data.description}</p>
          
          {scenario.data.devices && (
            <div class="card-devices">
              {scenario.data.devices.slice(0, 3).map((device) => (
                <span class="device-tag">{device}</span>
              ))}
              {scenario.data.devices.length > 3 && (
                <span class="device-tag-more">+{scenario.data.devices.length - 3}</span>
              )}
            </div>
          )}
          
          <span class="card-link font-outfit">
            Читать гайд <span class="arrow">→</span>
          </span>
        </a>
      ))}
    </div>

    {scenarios.length > 6 && (
      <div class="view-all-container">
        <a href="/scenarios/" class="view-all-btn font-outfit">
          <span>Все сценарии</span>
          <span class="view-all-arrow">→</span>
        </a>
      </div>
    )}
  </section>

  <!-- Troubleshooting Grid Section -->
  <section id="troubleshooting" class="section-container troubleshooting-section">
    <div class="trouble-glow"></div>
    <h2 class="section-title font-outfit"><span aria-hidden="true">🔧</span> Разборы и Траблшутинг</h2>
    <div class="section-divider"></div>
    <p class="section-desc">Устранение неполадок, борьба с радиопомехами и отвалами беспроводных датчиков.</p>
    
    <div class="troubleshooting-grid">
      {troubleshootingToShow.map((article) => (
        <a href={`/troubleshooting/${article.id}`} class="trouble-card glass">
          <div class="card-header">
            {article.data.difficulty && (
              <span class={`difficulty-badge ${article.data.difficulty}`}>
                {getDifficultyLabel(article.data.difficulty)}
              </span>
            )}
            <span class="date-badge">
              {new Date(article.data.publishDate).toLocaleDateString('ru-RU', { year: 'numeric', month: 'long', day: 'numeric' })}
            </span>
          </div>
          
          <h3 class="trouble-title font-outfit">
            <span class="trouble-title-icon" aria-hidden="true">⚠️</span>
            {article.data.title}
          </h3>
          <p class="trouble-desc">{article.data.description}</p>
          
          {article.data.devices && (
            <div class="card-devices">
              {article.data.devices.slice(0, 3).map((device) => (
                <span class="device-tag">{device}</span>
              ))}
              {article.data.devices.length > 3 && (
                <span class="device-tag-more">+{article.data.devices.length - 3}</span>
              )}
            </div>
          )}
          
          <span class="trouble-link font-outfit">
            Решение <span class="arrow">→</span>
          </span>
        </a>
      ))}
    </div>

    {troubleshooting.length > 6 && (
      <div class="view-all-container">
        <a href="/troubleshooting/" class="view-all-btn font-outfit">
          <span>Все разборы</span>
          <span class="view-all-arrow">→</span>
        </a>
      </div>
    )}
  </section>
</Layout>

<style>
  /* Hero Section (Bento Grid) */
  .hero-section.bento-grid {
    position: relative;
    padding: 5rem 0 3rem 0;
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-template-rows: auto;
    gap: 1.5rem;
  }

  .bento-card {
    border-radius: 2.25rem;
    overflow: hidden;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 2;
  }

  .bento-card.glass {
    background: var(--bg-card);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid var(--border-primary);
    box-shadow: var(--shadow-md);
  }

  .bento-card-main {
    grid-column: span 7;
    padding: 4rem 3.5rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 1.75rem;
    text-align: left;
  }

  .bento-card-image {
    grid-column: span 5;
    border: 1px solid var(--border-primary);
    box-shadow: var(--shadow-md);
    position: relative;
    display: flex;
  }

  .bento-card-image .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .bento-card-image::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0) 60%, rgba(0, 0, 0, 0.2) 100%);
    z-index: 1;
    pointer-events: none;
  }

  .bento-card-feature {
    grid-column: span 4;
    padding: 2.25rem 2rem;
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    text-align: left;
  }

  /* Bento Hover Effects */
  .bento-card:hover {
    transform: translateY(-5px);
  }

  .bento-card.glass:hover {
    border-color: var(--border-hover);
    box-shadow: var(--shadow-lg), 0 0 25px var(--accent-alice-trans);
    background: var(--bg-hover);
  }

  .bento-card-image:hover {
    box-shadow: var(--shadow-lg), 0 0 35px var(--accent-cyan-glow);
  }

  .bento-card-image:hover .hero-image {
    transform: scale(1.03);
  }

  /* Text & Elements Inside Bento */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.45rem 1.15rem;
    background: var(--bg-surface);
    border: 1px solid var(--border-primary);
    color: var(--text-secondary);
    font-size: 0.8rem;
    font-weight: 700;
    border-radius: 99px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    box-shadow: var(--shadow-sm);
  }

  .hero-badge::before {
    content: '';
    width: 6px;
    height: 6px;
    background-color: var(--accent-emerald);
    border-radius: 50%;
    display: inline-block;
    box-shadow: 0 0 8px var(--accent-emerald);
    animation: badge-pulse 2s infinite;
  }

  @keyframes badge-pulse {
    0% {
      transform: scale(0.95);
      box-shadow: 0 0 0 0 rgba(5, 150, 105, 0.7);
    }
    70% {
      transform: scale(1.1);
      box-shadow: 0 0 0 6px rgba(5, 150, 105, 0);
    }
    100% {
      transform: scale(0.95);
      box-shadow: 0 0 0 0 rgba(5, 150, 105, 0);
    }
  }

  .hero-title {
    font-size: 3.25rem;
    line-height: 1.1;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--text-primary);
  }

  .accent-title-word {
    background: linear-gradient(135deg, var(--accent-alice) 0%, var(--accent-cyan) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    display: inline-block;
  }

  .hero-subtitle {
    font-size: 1.05rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .btn {
    padding: 0.9rem 2rem;
    border-radius: 99px;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .btn-primary {
    background: #0f172a;
    color: #ffffff;
    border: none;
    box-shadow: 0 4px 20px rgba(15, 23, 42, 0.1);
  }

  :global(.dark) .btn-primary {
    background: #f8fafc;
    color: #0f172a;
    box-shadow: 0 4px 20px rgba(255, 255, 255, 0.05);
  }

  .btn-primary:hover {
    transform: translateY(-2px) scale(1.02);
    box-shadow: 0 8px 30px rgba(15, 23, 42, 0.2);
    filter: brightness(1.05);
  }

  :global(.dark) .btn-primary:hover {
    box-shadow: 0 8px 30px rgba(255, 255, 255, 0.12);
  }

  .btn-arrow {
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .btn-primary:hover .btn-arrow {
    transform: translateX(4px);
  }

  .btn-secondary {
    background: var(--bg-surface);
    color: var(--text-primary);
    border: 1px solid var(--border-primary);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    box-shadow: var(--shadow-sm);
  }

  .btn-secondary:hover {
    background: var(--bg-hover);
    transform: translateY(-2px) scale(1.02);
    border-color: var(--border-hover);
  }

  /* Feature Card Inner Styles */
  .feature-icon {
    font-size: 1.85rem;
    padding: 0.75rem;
    background: var(--bg-hover);
    border-radius: 1.25rem;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border-item);
    transition: transform 0.3s ease;
  }

  .bento-card-feature:hover .feature-icon {
    transform: scale(1.15) rotate(5deg);
  }

  .feature-content {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .feature-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .feature-desc {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.45;
  }

  .hero-glow {
    position: absolute;
    top: -15%;
    left: -10%;
    width: 600px;
    height: 400px;
    background: radial-gradient(circle, var(--accent-alice-glow) 0%, transparent 70%);
    z-index: -1;
    filter: blur(50px);
    pointer-events: none;
    opacity: 0.8;
  }


  /* Section Common */
  .section-container {
    padding: 5rem 0 2rem 0;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .section-title {
    font-size: 2.25rem;
    margin-bottom: 0.25rem;
    background: linear-gradient(135deg, var(--text-primary) 50%, var(--accent-cyan) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .section-divider {
    width: 50px;
    height: 4px;
    background: linear-gradient(90deg, var(--accent-cyan) 0%, var(--accent-cyan-semi) 100%);
    border-radius: 99px;
    margin: 0.5rem 0 0.8rem 0;
  }

  .section-desc {
    color: var(--text-secondary);
    font-size: 1.05rem;
    margin-bottom: 3rem;
    max-width: 600px;
  }

  /* Scenarios Grid */
  .scenarios-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 2rem;
  }

  .scenario-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 2rem;
    border-radius: var(--radius-md);
    background: var(--bg-surface);
    border: 1px solid var(--border-primary);
    text-decoration: none;
    color: inherit;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1), background-color 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    text-align: left;
  }

  .scenario-card:hover {
    border-color: var(--accent-cyan-semi);
    box-shadow: var(--shadow-md), var(--glow-cyan);
    transform: translateY(-4px);
    background: var(--bg-hover);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .difficulty-badge {
    padding: 0.25rem 0.75rem;
    border-radius: 99px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .difficulty-badge.easy {
    background: var(--diff-easy-bg);
    color: var(--diff-easy-text);
    border: 1px solid var(--diff-easy-border);
  }

  .difficulty-badge.medium {
    background: var(--diff-medium-bg);
    color: var(--diff-medium-text);
    border: 1px solid var(--diff-medium-border);
  }

  .difficulty-badge.hard {
    background: var(--diff-hard-bg);
    color: var(--diff-hard-text);
    border: 1px solid var(--diff-hard-border);
  }

  .date-badge {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .card-title {
    font-size: 1.4rem;
    line-height: 1.3;
    transition: color 0.3s ease;
  }

  .scenario-card:hover .card-title {
    color: var(--accent-cyan);
  }

  .card-desc {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.5;
    flex: 1;
  }

  .card-devices {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0.5rem 0;
  }

  .device-tag {
    background: var(--bg-item);
    border: 1px solid var(--border-item);
    color: var(--text-secondary);
    font-size: 0.75rem;
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-sm);
  }

  .device-tag-more {
    font-size: 0.75rem;
    color: var(--accent-cyan);
    font-weight: 600;
    align-self: center;
  }

  .card-link {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--accent-cyan);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    align-self: flex-start;
  }

  .card-link .arrow {
    transition: transform 0.2s ease;
  }

  .scenario-card:hover .card-link .arrow {
    transform: translateX(4px);
  }

  /* Troubleshooting Section */
  .troubleshooting-section {
    position: relative;
  }

  .trouble-glow {
    position: absolute;
    bottom: -10%;
    right: 5%;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, var(--accent-cyan-glow) 0%, transparent 75%);
    z-index: -1;
    filter: blur(50px);
    pointer-events: none;
  }

  .troubleshooting-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 2rem;
    width: 100%;
  }

  .trouble-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 2rem;
    border-radius: var(--radius-md);
    background: var(--bg-surface);
    border: 1px solid var(--border-primary);
    text-decoration: none;
    color: inherit;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), 
                border-color 0.4s cubic-bezier(0.16, 1, 0.3, 1), 
                box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1), 
                background-color 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    text-align: left;
  }

  .trouble-card:hover {
    border-color: var(--accent-cyan-semi);
    box-shadow: var(--shadow-md), var(--glow-cyan);
    transform: translateY(-4px);
    background: var(--bg-hover);
  }

  .trouble-title {
    font-size: 1.4rem;
    line-height: 1.3;
    font-weight: 700;
    color: var(--text-primary);
    transition: color 0.3s ease;
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .trouble-title-icon {
    flex-shrink: 0;
    margin-top: 0.1rem;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .trouble-card:hover .trouble-title-icon {
    transform: scale(1.15) rotate(-5deg);
  }

  .trouble-card:hover .trouble-title {
    color: var(--accent-cyan);
  }

  .trouble-desc {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.5;
    flex: 1;
  }

  .trouble-link {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--accent-cyan);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    align-self: flex-start;
  }

  .trouble-link .arrow {
    transition: transform 0.2s ease;
  }

  .trouble-card:hover .trouble-link .arrow {
    transform: translateX(4px);
  }

  /* View All Button */
  .view-all-container {
    display: flex;
    justify-content: center;
    padding: 3rem 0 1rem 0;
    width: 100%;
  }

  .view-all-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.9rem 2.5rem;
    background: var(--bg-card);
    border: 1px solid rgba(14, 165, 233, 0.25);
    border-radius: 12px;
    color: var(--accent-cyan);
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 4px 15px rgba(14, 165, 233, 0.05);
  }

  .view-all-btn:hover {
    transform: translateY(-2px);
    background: var(--accent-cyan);
    color: var(--bg-main);
    border-color: var(--accent-cyan);
    box-shadow: 0 8px 24px rgba(14, 165, 233, 0.3);
  }

  .view-all-arrow {
    transition: transform 0.2s ease;
  }

  .view-all-btn:hover .view-all-arrow {
    transform: translateX(4px);
  }

  @media (max-width: 992px) {
    .hero-section.bento-grid {
