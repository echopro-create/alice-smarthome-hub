---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ScenarioSteps from '../../components/ScenarioSteps.astro';
import DeviceList from '../../components/DeviceList.astro';
import { getDifficultyLabel } from '../../utils/difficulty';

// Генерация путей для каждой записи в коллекции scenarios с категорией troubleshooting
export async function getStaticPaths() {
  const entries = await getCollection('scenarios');
  const troubleshooting = entries.filter(entry => entry.data.category === 'troubleshooting');
  return troubleshooting.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Выборка связанных статей из коллекции scenarios (стандарты перелинковки 2026)
const allEntries = await getCollection('scenarios');
const relatedEntries = allEntries
  .filter(e => e.id !== entry.id && e.data.category === entry.data.category)
  .slice(0, 3);

// Если в текущей категории мало связанных статей, добираем из другой категории (fallback)
if (relatedEntries.length < 3) {
  const fallbackEntries = allEntries
    .filter(e => e.id !== entry.id && e.data.category !== entry.data.category)
    .slice(0, 3 - relatedEntries.length);
  relatedEntries.push(...fallbackEntries);
}

// Формирование JSON-LD схем (BreadcrumbList + TechArticle + опционально HowTo)
const host = Astro.site?.href || 'https://alice-smarthome.ru';
const cleanPath = Astro.url.pathname.replace(/\/$/, "");
const canonicalURL = cleanPath === "" 
  ? `${host}/` 
  : `${host}${cleanPath.toLowerCase()}`;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Главная",
      "item": host
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Траблшутинг",
      "item": `${host}/troubleshooting/`
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": entry.data.title,
      "item": canonicalURL
    }
  ]
};

const schemas: any[] = [breadcrumbSchema];

// TechArticle для технических разборов (E-E-A-T сигнал для YMYL)
const techArticleSchema = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  "headline": entry.data.title,
  "description": entry.data.description,
  "datePublished": entry.data.publishDate.toISOString(),
  ...(entry.data.updatedDate ? { "dateModified": entry.data.updatedDate.toISOString() } : {}),
  "image": entry.data.steps && entry.data.steps[0]?.image 
    ? new URL(entry.data.steps[0].image.src, host).href 
    : new URL('/og-image.png', host).href,
  "author": {
    "@type": "Person",
    "name": "Илья Кузнецов"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Умный Дом с Алисой",
    "logo": {
      "@type": "ImageObject",
      "url": `${host}/favicon.svg`
    }
  }
};
schemas.push(techArticleSchema);

// Если есть шаги — дополнительно включаем HowTo (dual schema = лучшие сниппеты)
if (entry.data.steps) {
  const howToSchema = {
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": entry.data.title,
    "description": entry.data.description,
    "datePublished": entry.data.publishDate.toISOString(),
    ...(entry.data.updatedDate ? { "dateModified": entry.data.updatedDate.toISOString() } : {}),
    "step": entry.data.steps.map((step, index) => ({
      "@type": "HowToStep",
      "position": index + 1,
      "name": step.title,
      "text": step.text,
      "url": `${canonicalURL}#step-${index + 1}`,
      ...(step.image ? { "image": new URL(step.image.src, host).href } : {})
    }))
  };
  schemas.push(howToSchema);
}

const jsonLdString = JSON.stringify(schemas);
---

<Layout 
  title={entry.data.title} 
  description={entry.data.description}
  jsonLd={jsonLdString}
>

  <!-- article:published_time / article:modified_time for search engines -->
  {entry.data.publishDate && <meta property="article:published_time" content={entry.data.publishDate.toISOString()} />}
  {entry.data.updatedDate && <meta property="article:modified_time" content={entry.data.updatedDate.toISOString()} />}

  <article class="article-container">
    <!-- Breadcrumbs -->
    <nav class="breadcrumbs font-outfit" aria-label="Хлебные крошки">
      <a href="/">Главная</a>
      <span class="separator">/</span>
      <a href="/troubleshooting/">Траблшутинг</a>
      <span class="separator">/</span>
      <span class="current" title={entry.data.title}>{entry.data.title}</span>
    </nav>

    <!-- Header info banner -->
    <header class="article-hero-banner glass">
      <div class="banner-meta">
        <span class="category-badge">Разбор и траблшутинг</span>
        {entry.data.difficulty && (
          <span class={`difficulty-badge ${entry.data.difficulty}`}>
            Сложность: {getDifficultyLabel(entry.data.difficulty)}
          </span>
        )}
      </div>
      <h1 class="article-title font-outfit">{entry.data.title}</h1>
      <div class="article-meta-info">
        <div class="meta-item">
          <svg class="meta-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"></rect><line x1="16" x2="16" y1="2" y2="6"></line><line x1="8" x2="8" y1="2" y2="6"></line><line x1="3" x2="21" y1="10" y2="10"></line></svg>
          <span>Опубликовано: {new Date(entry.data.publishDate).toLocaleDateString('ru-RU', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
        </div>
        {entry.data.updatedDate && (
          <div class="meta-item">
            <svg class="meta-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"></path></svg>
            <span>Обновлено: {new Date(entry.data.updatedDate).toLocaleDateString('ru-RU', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
          </div>
        )}
      </div>
      <div class="banner-glow" aria-hidden="true"></div>
    </header>

    <!-- Main Content Layout -->
    <div class="article-grid">
      <div class="article-main">
        <!-- Rendered MD body (theory, gotchas, advanced notes) -->
        <div class="markdown-body">
          <Content />
        </div>

        <!-- Render visual steps if present -->
        {entry.data.steps && (
          <div class="steps-section">
            <h2 class="steps-section-title font-outfit"><span aria-hidden="true">📋</span> Инструкция по устранению</h2>
            <ScenarioSteps steps={entry.data.steps} />
          </div>
        )}
      </div>

      <!-- Sidebar -->
      <aside class="article-sidebar">
        <!-- Required Devices widget -->
        {entry.data.devices && <DeviceList devices={entry.data.devices} />}

        <!-- Yandex Share Scenario CTA -->
        {entry.data.yandexShareUrl && (
          <div class="share-cta-box glass">
            <div class="share-icon" aria-hidden="true">✨</div>
            <h3 class="share-title font-outfit">Добавить в один клик</h3>
            <p class="share-text">Вы можете мгновенно скопировать этот настроенный и протестированный сценарий в свое приложение «Дом с Алисой».</p>
            <a 
              href={entry.data.yandexShareUrl} 
              target="_blank" 
              rel="noopener noreferrer" 
              class="share-btn font-outfit"
            >
              Импортировать в Алису
            </a>
          </div>
        )}
      </aside>
    </div>

    <!-- Related articles (Topic Clusters Link Graph) -->
    {relatedEntries.length > 0 && (
      <div class="related-section">
        <h2 class="related-title font-outfit"><span aria-hidden="true">🔮</span> Читайте также в этом разделе</h2>
        <div class="related-grid">
          {relatedEntries.map(related => (
            <a href={related.data.category === 'scenario' ? `/scenarios/${related.id}` : `/troubleshooting/${related.id}`} class="related-card glass">
              <span class="related-card-category">
                {related.data.category === 'scenario' ? 'Сценарий' : 'Траблшутинг'}
              </span>
              <h3 class="related-card-title font-outfit">{related.data.title}</h3>
              <p class="related-card-desc">{related.data.description}</p>
              <span class="related-card-link font-outfit">Читать гайд →</span>
            </a>
          ))}
        </div>
      </div>
    )}
  </article>
</Layout>

<style>
  .article-container {
    max-width: 1100px;
    margin: 0 auto;
    padding-top: 1rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-bottom: 2rem;
    font-weight: 500;
  }

  .back-link:hover {
    color: var(--accent-alice);
  }

  /* Premium Hero Banner */
  .article-hero-banner {
    position: relative;
    padding: 3rem 2.5rem;
    border-radius: var(--radius-lg);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.5rem;
    margin-bottom: 3.5rem;
    overflow: hidden;
  }

  .banner-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .category-badge {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--accent-alice);
    background: var(--accent-alice-trans);
    border: 1px solid var(--accent-alice-semi);
    padding: 0.25rem 0.75rem;
    border-radius: 99px;
    letter-spacing: 0.05em;
  }

  .difficulty-badge {
    padding: 0.25rem 0.75rem;
    border-radius: 99px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .difficulty-badge.easy {
    background: var(--diff-easy-bg);
    color: var(--diff-easy-text);
    border: 1px solid var(--diff-easy-border);
  }

  .difficulty-badge.medium {
    background: var(--diff-medium-bg);
    color: var(--diff-medium-text);
    border: 1px solid var(--diff-medium-border);
  }

  .difficulty-badge.hard {
    background: var(--diff-hard-bg);
    color: var(--diff-hard-text);
    border: 1px solid var(--diff-hard-border);
  }

  .article-title {
    font-size: 2.8rem;
    line-height: 1.25;
    background: linear-gradient(135deg, var(--text-primary) 30%, var(--accent-alice) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    max-width: 850px;
    font-weight: 800;
  }

  .article-meta-info {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    color: var(--text-muted);
    font-size: 0.85rem;
    font-weight: 500;
    flex-wrap: wrap;
    justify-content: center;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .meta-icon {
    color: var(--accent-alice);
    opacity: 0.8;
  }

  .banner-glow {
    position: absolute;
    top: -50%;
    left: 50%;
    transform: translateX(-50%);
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, var(--accent-alice-glow) 0%, transparent 70%);
    pointer-events: none;
    z-index: -1;
    filter: blur(30px);
  }

  /* Grid Layout for article and sidebar */
  .article-grid {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 3rem;
    align-items: start;
  }

  .article-main {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .steps-section {
    border-top: 1px solid var(--border-primary);
    padding-top: 2rem;
  }

  .steps-section-title {
    font-size: 1.75rem;
    margin-bottom: 1rem;
  }

  .article-sidebar {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    position: sticky;
    top: 5rem;
  }

  /* Yandex Share Box */
  .share-cta-box {
    padding: 1.5rem;
    border-radius: var(--radius-md);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    border: 1px solid var(--border-share);
    box-shadow: var(--shadow-share);
  }

  .share-icon {
    font-size: 2rem;
    filter: drop-shadow(var(--text-shadow-alice));
  }

  .share-title {
    font-size: 1.2rem;
    color: var(--text-primary);
  }

  .share-text {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .share-btn {
    width: 100%;
    margin-top: 0.5rem;
    padding: 0.75rem;
    background: linear-gradient(135deg, var(--accent-alice) 0%, var(--accent-secondary-blue) 100%);
    color: var(--text-white);
    font-weight: 600;
    border-radius: var(--radius-sm);
    box-shadow: var(--glow-alice);
    transition: all 0.2s ease;
  }

  .share-btn:hover {
    transform: translateY(-2px);
    box-shadow: var(--glow-alice-heavy);
    filter: brightness(1.1);
  }

  /* Markdown body overrides */
  .markdown-body {
    line-height: 1.7;
    font-size: 1.05rem;
    color: var(--text-primary);
  }

  .markdown-body :global(h2), .markdown-body :global(h3) {
    margin-top: 2.5rem;
    margin-bottom: 1.25rem;
    color: var(--text-primary);
  }

  .markdown-body :global(h2) {
    font-size: 1.7rem;
    padding-left: 1rem;
    border-left: 4px solid var(--accent-alice);
    background: linear-gradient(135deg, var(--text-primary) 60%, var(--accent-alice) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-weight: 700;
  }

  .markdown-body :global(h3) {
    font-size: 1.35rem;
    font-weight: 600;
    margin-top: 2rem;
    border-bottom: 1px solid var(--border-primary);
    padding-bottom: 0.4rem;
  }

  .markdown-body :global(p) {
    margin-bottom: 1.25rem;
    color: var(--text-secondary);
  }

  .markdown-body :global(ul), .markdown-body :global(ol) {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
    color: var(--text-secondary);
  }

  .markdown-body :global(li) {
    margin-bottom: 0.5rem;
  }

  .markdown-body :global(strong) {
    color: var(--text-primary);
  }

  @media (max-width: 900px) {
    .article-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    
    .article-sidebar {
      position: static;
    }
  }

  @media (max-width: 640px) {
    .article-title {
      font-size: 2.2rem;
    }
  }
  /* Breadcrumbs */
  .breadcrumbs {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-bottom: 2rem;
    font-weight: 500;
  }

  .breadcrumbs a {
    color: var(--text-secondary);
    transition: color 0.2s ease;
  }

  .breadcrumbs a:hover {
    color: var(--accent-alice);
  }

  .breadcrumbs .separator {
    color: var(--text-muted);
  }

  .breadcrumbs .current {
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 300px;
  }

  /* Related Articles Section */
  .related-section {
    margin-top: 5rem;
    border-top: 1px solid var(--border-primary);
    padding-top: 3rem;
  }

  .related-title {
    font-size: 1.8rem;
    margin-bottom: 2rem;
    color: var(--text-primary);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .related-card {
    padding: 1.5rem;
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    text-decoration: none;
    color: inherit;
  }

  .related-card:hover {
    transform: translateY(-4px);
    border-color: var(--border-hover);
    box-shadow: var(--glow-alice);
  }

  .related-card:hover .related-card-title {
    color: var(--accent-alice);
  }

  .related-card-category {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--accent-alice);
  }

  .related-card-title {
    font-size: 1.2rem;
    color: var(--text-primary);
    line-height: 1.4;
    transition: color 0.3s ease;
  }

  .related-card-desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.5;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .related-card-link {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--accent-alice);
    margin-top: auto;
  }
</style>
