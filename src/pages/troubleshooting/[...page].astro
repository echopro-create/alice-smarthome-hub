---
import { getCollection } from "astro:content";
import ListingFilters from "../../components/ListingFilters.astro";
import Layout from "../../layouts/Layout.astro";
import { getDifficultyLabel } from "../../utils/difficulty";

// Получаем все разборы неисправностей на одну страницу,
// где фильтрация и пагинация будут происходить на стороне клиента для плавности 2026 года.
export async function getStaticPaths() {
	const allEntries = await getCollection("scenarios");
	const troubleshooting = allEntries.filter((entry) => entry.data.category === "troubleshooting");

	// Сортировка по дате публикации (свежие сверху)
	troubleshooting.sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());

	return [{ params: { page: undefined }, props: { troubleshooting } }];
}

const { troubleshooting } = Astro.props;

// Получаем уникальные устройства для фильтра
const allDevices = Array.from(new Set(troubleshooting.flatMap((s) => s.data.devices || []))).sort();

// Вспомогательная функция для определения протокола сценария
const getProtocols = (devices: string[]) => {
	const p = [];
	const ds = devices.join(" ").toLowerCase();
	if (ds.includes("zigbee")) p.push("zigbee");
	if (ds.includes("wi-fi") || ds.includes("wifi") || ds.includes("станция") || ds.includes("колонка")) p.push("wifi");
	if (ds.includes("matter") || ds.includes("thread")) p.push("matter");
	if (p.length === 0) p.push("wifi"); // fallback
	return p.join(",");
};

const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	itemListElement: [
		{ "@type": "ListItem", position: 1, name: "Главная", item: "https://smart-hub.info/" },
		{ "@type": "ListItem", position: 2, name: "Траблшутинг", item: "https://smart-hub.info/troubleshooting/" },
	],
};
const jsonLdString = JSON.stringify([breadcrumbSchema]);
---

<Layout title="Разборы и траблшутинг умного дома" description="Технические разборы частых проблем умного дома с Алисой: отвалы датчиков, радиопомехи Zigbee, совместимость устройств. Пошаговые инструкции по решению." jsonLd={jsonLdString}>
  <section class="page-section">
    <div class="page-header">
      <h1 class="page-heading font-outfit">Разборы и траблшутинг</h1>
      <div class="section-divider"></div>
      <p class="page-desc">Технические расследования и пошаговые инструкции по устранению неполадок в экосистеме умного дома Яндекса.</p>
    </div>

    <!-- Filter Panel -->
    <div class="filter-panel card-outlined" id="filter-panel">
      <div class="filter-row">
        <!-- Difficulty filters (pills) -->
        <div class="filter-group">
          <span class="filter-label font-outfit">Сложность:</span>
          <div class="filter-pills" id="difficulty-pills">
            <button class="pill-btn active" data-difficulty="all">Все</button>
            <button class="pill-btn" data-difficulty="easy">Легко</button>
            <button class="pill-btn" data-difficulty="medium">Средне</button>
            <button class="pill-btn" data-difficulty="hard">Сложно</button>
          </div>
        </div>
        
        <!-- Protocol filter -->
        <div class="filter-group">
          <label for="protocol-select" class="filter-label font-outfit">Протокол:</label>
          <select id="protocol-select" class="filter-select">
            <option value="all">Все протоколы</option>
            <option value="zigbee">Zigbee</option>
            <option value="wifi">Wi-Fi</option>
            <option value="matter">Matter / Thread</option>
          </select>
        </div>

        <!-- Device filter -->
        <div class="filter-group">
          <label for="device-select" class="filter-label font-outfit">Устройство:</label>
          <select id="device-select" class="filter-select">
            <option value="all">Все устройства</option>
            {allDevices.map(device => (
              <option value={device}>{device}</option>
            ))}
          </select>
        </div>

        <!-- Sort filter -->
        <div class="filter-group">
          <label for="sort-select" class="filter-label font-outfit">Сортировка:</label>
          <select id="sort-select" class="filter-select">
            <option value="newest">Сначала новые</option>
            <option value="oldest">Сначала старые</option>
          </select>
        </div>
      </div>
    </div>
    
    <!-- Troubleshooting List Container -->
    <div class="trouble-list" id="trouble-list">
      {troubleshooting.map((article) => (
        <a 
          href={`/troubleshooting/${article.id}/`} 
          class="trouble-card card-outlined"
          data-difficulty={article.data.difficulty || 'easy'}
          data-protocols={getProtocols(article.data.devices || [])}
          data-devices={JSON.stringify(article.data.devices || [])}
          data-date={new Date(article.data.publishDate).getTime()}
        >
          <div class="trouble-icon-wrap" aria-hidden="true">
            <svg class="trouble-icon-svg" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path>
            </svg>
          </div>
          <div class="trouble-content">
            <div class="trouble-meta">
              {article.data.difficulty && (
                <span class={`difficulty-badge ${article.data.difficulty}`}>
                  {getDifficultyLabel(article.data.difficulty)}
                </span>
              )}
              <span class="trouble-date">
                {new Date(article.data.publishDate).toLocaleDateString('ru-RU', { year: 'numeric', month: 'long', day: 'numeric' })}
              </span>
            </div>
            <h2 class="trouble-title font-outfit">{article.data.title}</h2>
            <p class="trouble-desc">{article.data.description}</p>
            {article.data.devices && (
              <div class="trouble-devices">
                {article.data.devices.map((device) => (
                  <span class="device-tag">{device}</span>
                ))}
              </div>
            )}
          </div>
          <span class="trouble-link font-outfit">
            <span>Решение</span>
            <span class="arrow">→</span>
          </span>
        </a>
      ))}
    </div>

    <!-- Empty State -->
    <div class="empty-state card-outlined" id="empty-state" style="display: none;">
      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="empty-icon" style="color: var(--text-muted); margin-bottom: 1rem;"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
      <p class="empty-text">Ничего не найдено по выбранным фильтрам.</p>
    </div>

    <!-- Client-side Pagination -->
    <nav class="pagination" id="pagination-nav" aria-label="Навигация по страницам">
      <button class="pagination-arrow prev" id="btn-prev" aria-label="Предыдущая страница">
        ← <span>Назад</span>
      </button>

      <div class="pagination-pages" id="pagination-numbers">
        <!-- Генерируется динамически -->
      </div>

      <button class="pagination-arrow next" id="btn-next" aria-label="Следующая страница">
        <span>Вперед</span> →
      </button>
    </nav>
  </section>
  <ListingFilters gridId="trouble-list" cardClass="trouble-card" difficultyPillsId="difficulty-pills" />
</Layout>


<style>
  /* Troubleshooting Cards List */
  .trouble-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 2rem;
  }

  .trouble-card {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    height: 100%;
  }

  .trouble-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent-signature-semi);
    box-shadow: 0 10px 30px var(--accent-signature-glow);
    background: var(--bg-hover);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .difficulty-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.25rem 0.75rem;
    border-radius: 99px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    line-height: 1;
  }

  .trouble-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .difficulty-badge.easy {
    background: var(--diff-easy-bg);
    color: var(--diff-easy-text);
    border: 1px solid var(--diff-easy-border);
  }

  .difficulty-badge.medium {
    background: var(--diff-medium-bg);
    color: var(--diff-medium-text);
    border: 1px solid var(--diff-medium-border);
  }

  .difficulty-badge.hard {
    background: var(--diff-hard-bg);
    color: var(--diff-hard-text);
    border: 1px solid var(--diff-hard-border);
  }

  .trouble-icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: var(--bg-item);
    border: 1px solid var(--border-item);
    border-radius: var(--radius-md);
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
    transition: all 0.3s ease;
  }

  .trouble-card:hover .trouble-icon-wrap {
    background: var(--accent-signature-trans);
    border-color: var(--accent-signature-semi);
    transform: scale(1.1) rotate(-3deg);
  }

  .trouble-icon-svg {
    transition: all 0.3s ease;
  }

  .trouble-card:hover .trouble-icon-svg {
    color: var(--accent-signature);
    transform: rotate(-3deg);
  }

  .date-badge {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .trouble-title {
    font-size: 1.4rem;
    line-height: 1.3;
    transition: color 0.3s ease;
    color: var(--text-primary);
  }

  .trouble-card:hover .trouble-title {
    color: var(--accent-signature, #f97316);
  }

  .trouble-desc {
    color: var(--text-primary);
    font-size: 1rem;
    line-height: 1.6;
    flex: 1;
  }

  .trouble-devices {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0.5rem 0;
  }

  .device-tag {
    background: var(--bg-item);
    border: 1px solid var(--border-item);
    color: var(--text-secondary);
    font-size: 0.8rem;
    padding: 0.25rem 0.65rem;
    border-radius: var(--radius-sm);
  }

  .device-tag-more {
    font-size: 0.75rem;
    color: var(--accent-signature);
    font-weight: 600;
    align-self: center;
  }

  .trouble-link {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--accent-signature);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    align-self: flex-start;
  }

  .trouble-link .arrow {
    transition: transform 0.2s ease;
  }

  .trouble-card:hover .trouble-link .arrow {
    transform: translateX(4px);
  }

  @media (max-width: 768px) {
    .trouble-list {
      grid-template-columns: 1fr;
    }
  }
</style>
