---
import Layout from "../layouts/Layout.astro";

// SEO метаданные для страницы контактов
const title = "Контакты — обратная связь и FAQ";
const description = "Свяжитесь с командой «Умный Дом с Алисой». Интерактивная форма обратной связи, идеи для сценариев, Telegram-канал и частые вопросы.";

const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	itemListElement: [
		{
			"@type": "ListItem",
			position: 1,
			name: "Главная",
			item: "https://smart-hub.info/",
		},
		{
			"@type": "ListItem",
			position: 2,
			name: "Контакты",
			item: "https://smart-hub.info/contacts/",
		},
	],
};

const jsonLdString = JSON.stringify([breadcrumbSchema]);
---

<Layout title={title} description={description} jsonLd={jsonLdString}>
  <div class="contacts-container">
    <!-- Breadcrumbs -->
    <nav class="breadcrumbs font-outfit" aria-label="Хлебные крошки">
      <a href="/">Главная</a>
      <span class="separator">/</span>
      <span class="current">Контакты</span>
    </nav>

    <!-- Header Banner -->
    <header class="contacts-hero card-elevated">
      <span class="category-badge">Связь</span>
      <h1 class="page-title font-outfit">Обратная связь и поддержка</h1>
      <p class="hero-desc">
        Хотите предложить идею для нового гайда, сообщить об ошибке или обсудить партнерство? Заполните форму или напишите нам в Telegram.
      </p>
      <div class="banner-glow" aria-hidden="true"></div>
    </header>

    <!-- Contacts Main Grid -->
    <div class="contacts-grid">
      <!-- Left: Contact info & FAQ -->
      <div class="contacts-info-column">
        <!-- Quick Cards -->
        <div class="quick-contact-cards">
          <!-- Email card -->
          <div class="contact-card card-outlined">
            <div class="contact-card-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
            </div>
            <div class="contact-card-content">
              <span class="contact-card-label">Электронная почта</span>
              <a href="mailto:hello@smart-hub.info" class="contact-card-link font-outfit">hello@smart-hub.info</a>
            </div>
          </div>

          <!-- Telegram Card -->
          <div class="contact-card card-outlined highlight">
            <div class="contact-card-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><line x1="22" x2="11" y1="2" y2="13"/></svg>
            </div>
            <div class="contact-card-content">
              <span class="contact-card-label">Канал в Telegram</span>
              <a href="https://t.me/yandex_alice_smarthome" target="_blank" rel="noopener noreferrer" class="contact-card-link font-outfit">@alice_smarthome</a>
            </div>
          </div>
        </div>

        <!-- FAQ Accordion -->
        <div class="faq-box card-outlined">
          <h2 class="faq-title font-outfit">Часто задаваемые вопросы</h2>
          
          <details class="faq-item">
            <summary class="faq-summary font-outfit">Принимаете ли вы гостевые статьи?</summary>
            <div class="faq-content">
              <p>Да! Если у вас есть уникальный опыт интеграции редких Zigbee-устройств, автоматизации сложных систем или разработки кастомных скриптов, напишите нам. Мы опубликуем вашу инструкцию с сохранением авторства.</p>
            </div>
          </details>

          <details class="faq-item">
            <summary class="faq-summary font-outfit">Как быстро вы отвечаете на сообщения?</summary>
            <div class="faq-content">
              <p>Мы стараемся обрабатывать все письма и формы в течение 24 часов по будням. Запросы в Telegram обычно получают ответ быстрее.</p>
            </div>
          </details>

          <details class="faq-item">
            <summary class="faq-summary font-outfit">Как отправить вам лог ошибки умного дома для диагностики?</summary>
            <div class="faq-content">
              <p>Вы можете заполнить форму обратной связи, детально описав проблему, шаги воспроизведения, модели хаба и датчиков. Это поможет нам быстрее локализовать сбой.</p>
            </div>
          </details>
        </div>
      </div>

      <!-- Right: Interactive feedback form -->
      <aside class="feedback-form-box card-outlined">
        <h2 class="form-title font-outfit">Отправить сообщение</h2>
        
        <form id="contact-form" class="feedback-form" action="#" method="POST" novalidate>
          <div class="form-group">
            <label class="form-label" for="form-name">Ваше имя</label>
            <input type="text" id="form-name" name="name" class="form-input" required placeholder="Иван Иванов" />
            <span class="form-error-msg">Пожалуйста, введите имя</span>
          </div>

          <div class="form-group">
            <label class="form-label" for="form-email">Электронная почта</label>
            <input type="email" id="form-email" name="email" class="form-input" required placeholder="name@domain.com" />
            <span class="form-error-msg">Пожалуйста, введите корректный адрес почты</span>
          </div>

          <div class="form-group">
            <label class="form-label" for="form-subject">Тема обращения</label>
            <div class="select-wrapper">
              <select id="form-subject" name="subject" class="form-select" required>
                <option value="" disabled selected>Выберите тему...</option>
                <option value="feedback">Обратная связь по гайду</option>
                <option value="idea">Идея для нового сценария</option>
                <option value="bug">Сообщение об ошибке в инструкции</option>
                <option value="business">Сотрудничество / Обзоры</option>
              </select>
            </div>
            <span class="form-error-msg">Пожалуйста, выберите тему</span>
          </div>

          <div class="form-group">
            <label class="form-label" for="form-message">Сообщение</label>
            <textarea id="form-message" name="message" class="form-textarea" required minlength="10" placeholder="Подробно опишите вашу идею или вопрос..."></textarea>
            <span class="form-error-msg">Сообщение должно содержать не менее 10 символов</span>
          </div>

          <button type="submit" class="form-submit-btn font-outfit">
            <span>Отправить сообщение</span>
            <svg class="submit-btn-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" x2="11" y1="2" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
          </button>
        </form>

        <!-- Form Success State Overlay -->
        <div id="form-success-state" class="form-success-overlay hidden">
          <div class="success-content">
            <div class="success-icon-circle">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            </div>
            <h3 class="success-title font-outfit">Сообщение отправлено!</h3>
            <p class="success-desc">Спасибо за обращение. Мы изучим материалы и ответим вам в течение 24 часов.</p>
            <button id="reset-form-btn" class="reset-btn font-outfit">Отправить еще одно сообщение</button>
          </div>
        </div>
      </aside>
    </div>
  </div>
</Layout>

<script>
  function initContactsForm() {
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const successOverlay = document.getElementById('form-success-state');
    const resetBtn = document.getElementById('reset-form-btn');

    if (!form || !successOverlay || !resetBtn) return;

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      // Запускаем валидацию
      let isValid = true;
      const inputs = form.querySelectorAll('input, select, textarea');

      inputs.forEach(input => {
        const targetInput = input as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement;
        
        // Сбрасываем старый класс
        targetInput.classList.remove('is-invalid');
        
        if (!targetInput.checkValidity()) {
          isValid = false;
          targetInput.classList.add('is-invalid');
        }
      });

      if (isValid) {
        // Показываем оверлей успешной отправки
        successOverlay.classList.remove('hidden');
        form.reset();
      }
    });

    // Сброс формы и возврат в обычное состояние
    resetBtn.addEventListener('click', () => {
      successOverlay.classList.add('hidden');
      const inputs = form.querySelectorAll('input, select, textarea');
      inputs.forEach(input => {
        input.classList.remove('is-invalid');
      });
    });
  }

  // Запуск скриптов при первой загрузке и смене страниц Astro
  initContactsForm();
  document.addEventListener('astro:page-load', initContactsForm);
</script>

<style>
  .contacts-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 1rem 1rem 4rem 1rem;
  }

  /* Breadcrumbs */
  .breadcrumbs {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-bottom: 2rem;
    font-weight: 500;
  }

  .breadcrumbs a {
    color: var(--text-secondary);
    transition: color 0.2s ease;
  }

  .breadcrumbs a:hover {
    color: var(--accent-signature, #f97316);
  }

  .breadcrumbs .separator {
    color: var(--text-muted);
  }

  .breadcrumbs .current {
    color: var(--text-primary);
  }

  /* Hero Banner */
  .contacts-hero {
    position: relative;
    padding: 3rem 2.5rem;
    margin-bottom: 3rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    overflow: hidden;
  }

  .category-badge {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--accent-signature, #f97316);
    background: var(--accent-signature-trans);
    border: 1px solid var(--accent-signature-semi);
    padding: 0.25rem 0.75rem;
    border-radius: 99px;
    letter-spacing: 0.05em;
  }

  .page-title {
    font-size: 2.8rem;
    line-height: 1.25;
    background: linear-gradient(135deg, var(--text-primary) 30%, var(--accent-signature, #f97316) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    max-width: 800px;
    font-weight: 800;
  }

  .hero-desc {
    font-size: 1.1rem;
    color: var(--text-secondary);
    max-width: 650px;
    line-height: 1.6;
  }

  .banner-glow {
    position: absolute;
    top: -50%;
    left: 50%;
    transform: translateX(-50%);
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, var(--accent-signature-glow) 0%, transparent 70%);
    pointer-events: none;
    z-index: -1;
    filter: blur(30px);
  }

  /* Grid Layout */
  .contacts-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  /* Left Column: Cards & FAQ */
  .contacts-info-column {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .quick-contact-cards {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .contact-card {
    padding: 1.5rem;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.3s ease;
  }

  .contact-card:hover {
    transform: translateY(-2px);
    border-color: var(--border-hover);
  }

  .contact-card.highlight {
    border-color: var(--accent-signature-semi);
    background-color: var(--accent-signature-trans);
  }

  .contact-card-icon {
    font-size: 1.5rem;
    color: var(--accent-signature, #f97316);
    background-color: var(--bg-surface);
    border: 1px solid var(--border-primary);
    padding: 0.6rem;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-sm);
  }

  .contact-card.highlight .contact-card-icon {
    background-color: var(--accent-signature);
    color: var(--text-white);
    border-color: var(--accent-signature);
  }

  .contact-card-content {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .contact-card-label {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }

  .contact-card-link {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text-primary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .contact-card-link:hover {
    color: var(--accent-signature);
  }

  /* FAQ Accordion */
  .faq-box {
    padding: 2.25rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .faq-title {
    font-size: 1.4rem;
    color: var(--text-primary);
    border-bottom: 1px solid var(--border-primary);
    padding-bottom: 0.75rem;
    margin: 0;
  }

  .faq-item {
    border-bottom: 1px solid var(--border-primary);
    padding-bottom: 1rem;
  }

  .faq-item:last-of-type {
    border-bottom: none;
    padding-bottom: 0;
  }

  .faq-summary {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
    padding: 0.5rem 0;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: color 0.2s ease;
  }

  .faq-summary::-webkit-details-marker {
    display: none;
  }

  .faq-summary::after {
    content: "+";
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--accent-signature, #f97316);
    transition: transform 0.3s ease;
  }

  .faq-item[open] .faq-summary::after {
    transform: rotate(45deg);
  }

  .faq-summary:hover {
    color: var(--accent-signature, #f97316);
  }

  .faq-content {
    padding: 0.75rem 0 0.25rem 0;
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .faq-content p {
    margin: 0;
  }

  /* Feedback Form Column */
  .feedback-form-box {
    padding: 2.5rem;
    position: relative;
    overflow: hidden;
  }

  .form-title {
    font-size: 1.4rem;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
    margin-top: 0;
  }

  .feedback-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-label {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--text-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .form-input, .form-textarea, .form-select {
    width: 100%;
    padding: 0.75rem 1rem;
    background-color: var(--bg-surface);
    color: var(--text-primary);
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-sm);
    font-size: 0.9rem;
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .form-input:focus, .form-textarea:focus, .form-select:focus {
    border-color: var(--accent-signature);
    box-shadow: 0 0 0 3px var(--accent-signature-glow);
  }

  .form-textarea {
    min-height: 120px;
    resize: vertical;
  }

  .select-wrapper {
    position: relative;
  }

  .select-wrapper::after {
    content: "▼";
    font-size: 0.65rem;
    color: var(--text-muted);
    position: absolute;
    right: 1rem;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
  }

  .form-select {
    appearance: none;
    cursor: pointer;
  }

  /* Form Error Styling */
  .form-error-msg {
    display: none;
    font-size: 0.75rem;
    font-weight: 600;
    color: #ef4444;
    margin-top: 0.25rem;
  }

  .form-input.is-invalid, .form-textarea.is-invalid, .form-select.is-invalid {
    border-color: #ef4444;
    box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.15);
  }

  .form-input.is-invalid ~ .form-error-msg,
  .form-textarea.is-invalid ~ .form-error-msg,
  .form-select.is-invalid ~ .form-error-msg {
    display: block;
  }

  /* Submit Button */
  .form-submit-btn {
    width: 100%;
    padding: 0.9rem;
    font-size: 0.95rem;
    font-weight: 700;
    border-radius: var(--radius-sm);
    background: linear-gradient(135deg, var(--accent-signature) 0%, #ff7a30 100%);
    color: var(--text-white);
    border: none;
    cursor: pointer;
    box-shadow: 0 4px 10px var(--accent-signature-glow);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    transition: all 0.2s ease;
  }

  .form-submit-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px var(--accent-signature-semi);
    filter: brightness(1.05);
  }

  .submit-btn-icon {
    flex-shrink: 0;
  }

  /* Success State Overlay */
  .form-success-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: var(--bg-surface);
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .success-content {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    max-width: 320px;
    animation: success-appear 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @keyframes success-appear {
    0% { opacity: 0; transform: scale(0.95); }
    100% { opacity: 1; transform: scale(1); }
  }

  .success-icon-circle {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background-color: rgba(34, 197, 94, 0.1);
    color: #22c55e;
    border: 2px solid rgba(34, 197, 94, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .success-title {
    font-size: 1.4rem;
    color: var(--text-primary);
    margin: 0;
  }

  .success-desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0;
  }

  .reset-btn {
    width: 100%;
    padding: 0.75rem;
    font-size: 0.9rem;
    font-weight: 700;
    border-radius: var(--radius-sm);
    background-color: var(--bg-surface);
    border: 1px solid var(--border-primary);
    color: var(--text-primary);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .reset-btn:hover {
    border-color: var(--accent-signature);
    color: var(--accent-signature);
  }

  .hidden {
    display: none !important;
  }

  /* Responsive Grid */
  @media (max-width: 900px) {
    .contacts-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  @media (max-width: 768px) {
    .contacts-hero {
      padding: 2.5rem 1.5rem;
    }

    .page-title {
      font-size: 2.2rem;
    }

    .feedback-form-box {
      padding: 2rem 1.5rem;
    }
  }
</style>
