---
import { getCollection } from "astro:content";
import ListingFilters from "../../components/ListingFilters.astro";
import Layout from "../../layouts/Layout.astro";
import { getDifficultyLabel } from "../../utils/difficulty";

// Мы получаем все сценарии и передаем их на одну страницу,
// где фильтрация и пагинация будут происходить на стороне клиента для плавности 2026 года.
export async function getStaticPaths() {
	const allEntries = await getCollection("scenarios");
	const scenarios = allEntries.filter((entry) => entry.data.category === "scenario");

	// Сортировка по дате публикации (свежие сверху)
	scenarios.sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());

	return [{ params: { page: undefined }, props: { scenarios } }];
}

const { scenarios } = Astro.props;

// Получаем уникальные устройства для фильтра
const allDevices = Array.from(new Set(scenarios.flatMap((s) => s.data.devices || []))).sort();

// Вспомогательная функция для определения протокола сценария
const getProtocols = (devices: string[]) => {
	const p = [];
	const ds = devices.join(" ").toLowerCase();
	if (ds.includes("zigbee")) p.push("zigbee");
	if (ds.includes("wi-fi") || ds.includes("wifi") || ds.includes("станция") || ds.includes("колонка")) p.push("wifi");
	if (ds.includes("matter") || ds.includes("thread")) p.push("matter");
	if (p.length === 0) p.push("wifi"); // fallback
	return p.join(",");
};

const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	itemListElement: [
		{ "@type": "ListItem", position: 1, name: "Главная", item: "https://smart-hub.info/" },
		{ "@type": "ListItem", position: 2, name: "Сценарии", item: "https://smart-hub.info/scenarios/" },
	],
};
const jsonLdString = JSON.stringify([breadcrumbSchema]);
---

<Layout title="Пошаговые сценарии автоматизации" description="Полный каталог пошаговых сценариев умного дома с Алисой: от утренних рутин до комплексной безопасности. Пошаговые инструкции с иллюстрациями." jsonLd={jsonLdString}>
  <section class="page-section">
    <div class="page-header">
      <h1 class="page-heading font-outfit">Сценарии автоматизации</h1>
      <div class="section-divider"></div>
      <p class="page-desc">Готовые алгоритмы для вашего умного дома: каждый сценарий содержит пошаговую инструкцию, список оборудования и скриншоты приложения «Дом с Алисой».</p>
    </div>

    <!-- Filter Panel -->
    <div class="filter-panel card-outlined" id="filter-panel">
      <div class="filter-row">
        <!-- Difficulty filters (pills) -->
        <div class="filter-group">
          <span class="filter-label font-outfit">Сложность:</span>
          <div class="filter-pills" id="difficulty-pills">
            <button class="pill-btn active" data-difficulty="all">Все</button>
            <button class="pill-btn" data-difficulty="easy">Легко</button>
            <button class="pill-btn" data-difficulty="medium">Средне</button>
            <button class="pill-btn" data-difficulty="hard">Сложно</button>
          </div>
        </div>
        
        <!-- Protocol filter -->
        <div class="filter-group">
          <label for="protocol-select" class="filter-label font-outfit">Протокол:</label>
          <select id="protocol-select" class="filter-select">
            <option value="all">Все протоколы</option>
            <option value="zigbee">Zigbee</option>
            <option value="wifi">Wi-Fi</option>
            <option value="matter">Matter / Thread</option>
          </select>
        </div>

        <!-- Device filter -->
        <div class="filter-group">
          <label for="device-select" class="filter-label font-outfit">Устройство:</label>
          <select id="device-select" class="filter-select">
            <option value="all">Все устройства</option>
            {allDevices.map(device => (
              <option value={device}>{device}</option>
            ))}
          </select>
        </div>

        <!-- Sort filter -->
        <div class="filter-group">
          <label for="sort-select" class="filter-label font-outfit">Сортировка:</label>
          <select id="sort-select" class="filter-select">
            <option value="newest">Сначала новые</option>
            <option value="oldest">Сначала старые</option>
          </select>
        </div>
      </div>
    </div>
    
    <!-- Scenarios Grid Container -->
    <div class="scenarios-grid" id="scenarios-grid">
      {scenarios.map((scenario) => (
        <a 
          href={`/scenarios/${scenario.id}/`} 
          class="scenario-card card-outlined"
          data-difficulty={scenario.data.difficulty || 'easy'}
          data-protocols={getProtocols(scenario.data.devices || [])}
          data-devices={JSON.stringify(scenario.data.devices || [])}
          data-date={new Date(scenario.data.publishDate).getTime()}
        >
          <div class="card-header">
            <span class={`difficulty-badge ${scenario.data.difficulty}`}>
              {getDifficultyLabel(scenario.data.difficulty)}
            </span>
            <span class="date-badge">
              {new Date(scenario.data.publishDate).toLocaleDateString('ru-RU', { year: 'numeric', month: 'long', day: 'numeric' })}
            </span>
          </div>
          <h2 class="card-title font-outfit">{scenario.data.title}</h2>
          <p class="card-desc">{scenario.data.description}</p>
          
          {scenario.data.devices && (
            <div class="card-devices">
              {scenario.data.devices.slice(0, 3).map((device) => (
                <span class="device-tag">{device}</span>
              ))}
              {scenario.data.devices.length > 3 && (
                <span class="device-tag-more">+{scenario.data.devices.length - 3}</span>
              )}
            </div>
          )}
          
          <span class="card-link font-outfit">
            Читать гайд <span class="arrow">→</span>
          </span>
        </a>
      ))}
    </div>

    <!-- Empty State -->
    <div class="empty-state card-outlined" id="empty-state" style="display: none;">
      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="empty-icon" style="color: var(--text-muted); margin-bottom: 1rem;"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
      <p class="empty-text">Ничего не найдено по выбранным фильтрам.</p>
    </div>

    <!-- Client-side Pagination -->
    <nav class="pagination" id="pagination-nav" aria-label="Навигация по страницам">
      <button class="pagination-arrow prev" id="btn-prev" aria-label="Предыдущая страница">
        ← <span>Назад</span>
      </button>

      <div class="pagination-pages" id="pagination-numbers">
        <!-- Будет генерироваться динамически -->
      </div>

      <button class="pagination-arrow next" id="btn-next" aria-label="Следующая страница">
        <span>Вперед</span> →
      </button>
    </nav>
  </section>
  <ListingFilters gridId="scenarios-grid" cardClass="scenario-card" difficultyPillsId="difficulty-pills" />
</Layout>


<style>
  /* Scenario Cards Grid */
  .scenarios-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 2rem;
  }

  .scenario-card {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    text-decoration: none;
    color: inherit;
    text-align: left;
    height: 100%;
  }

  .scenario-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent-signature-semi);
    box-shadow: 0 10px 30px var(--accent-signature-glow);
    background: var(--bg-hover);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .difficulty-badge {
    padding: 0.25rem 0.75rem;
    border-radius: 99px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .difficulty-badge.easy {
    background: var(--diff-easy-bg);
    color: var(--diff-easy-text);
    border: 1px solid var(--diff-easy-border);
  }

  .difficulty-badge.medium {
    background: var(--diff-medium-bg);
    color: var(--diff-medium-text);
    border: 1px solid var(--diff-medium-border);
  }

  .difficulty-badge.hard {
    background: var(--diff-hard-bg);
    color: var(--diff-hard-text);
    border: 1px solid var(--diff-hard-border);
  }

  .date-badge {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .card-title {
    font-size: 1.35rem;
    line-height: 1.3;
    transition: color 0.3s ease;
    color: var(--text-primary);
  }

  .scenario-card:hover .card-title {
    color: var(--accent-signature, #f97316);
  }

  .card-desc {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.5;
    flex: 1;
  }

  .card-devices {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0.5rem 0;
  }

  .device-tag {
    background: var(--bg-item);
    border: 1px solid var(--border-item);
    color: var(--text-secondary);
    font-size: 0.75rem;
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-sm);
  }

  .device-tag-more {
    font-size: 0.75rem;
    color: var(--accent-signature);
    font-weight: 600;
    align-self: center;
  }

  .card-link {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--accent-signature);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    align-self: flex-start;
  }

  .card-link .arrow {
    transition: transform 0.2s ease;
  }

  .scenario-card:hover .card-link .arrow {
    transform: translateX(4px);
  }

  @media (max-width: 768px) {
    .scenarios-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
