---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { getDifficultyLabel } from "../../utils/difficulty";

// Мы получаем все сценарии и передаем их на одну страницу,
// где фильтрация и пагинация будут происходить на стороне клиента для плавности 2026 года.
export async function getStaticPaths() {
	const allEntries = await getCollection("scenarios");
	const scenarios = allEntries.filter((entry) => entry.data.category === "scenario");

	// Сортировка по дате публикации (свежие сверху)
	scenarios.sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());

	return [
		{ params: { page: undefined }, props: { scenarios } }
	];
}

const { scenarios } = Astro.props;

// Получаем уникальные устройства для фильтра
const allDevices = Array.from(
	new Set(scenarios.flatMap((s) => s.data.devices || []))
).sort();

// Вспомогательная функция для определения протокола сценария
const getProtocols = (devices: string[]) => {
	const p = [];
	const ds = devices.join(" ").toLowerCase();
	if (ds.includes("zigbee")) p.push("zigbee");
	if (ds.includes("wi-fi") || ds.includes("wifi") || ds.includes("станция") || ds.includes("колонка")) p.push("wifi");
	if (ds.includes("matter") || ds.includes("thread")) p.push("matter");
	if (p.length === 0) p.push("wifi"); // fallback
	return p.join(",");
};
---

<Layout title="Пошаговые сценарии автоматизации" description="Полный каталог пошаговых сценариев умного дома с Алисой: от утренних рутин до комплексной безопасности. Пошаговые инструкции с иллюстрациями.">
  <section class="page-section">
    <div class="page-header">
      <h1 class="page-heading font-outfit">Сценарии автоматизации</h1>
      <div class="section-divider"></div>
      <p class="page-desc">Готовые алгоритмы для вашего умного дома: каждый сценарий содержит пошаговую инструкцию, список оборудования и скриншоты приложения «Дом с Алисой».</p>
    </div>

    <!-- Filter Panel -->
    <div class="filter-panel card-outlined" id="filter-panel">
      <div class="filter-row">
        <!-- Difficulty filters (pills) -->
        <div class="filter-group">
          <span class="filter-label font-outfit">Сложность:</span>
          <div class="filter-pills" id="difficulty-pills">
            <button class="pill-btn active" data-difficulty="all">Все</button>
            <button class="pill-btn" data-difficulty="easy">Легко</button>
            <button class="pill-btn" data-difficulty="medium">Средне</button>
            <button class="pill-btn" data-difficulty="hard">Сложно</button>
          </div>
        </div>
        
        <!-- Protocol filter -->
        <div class="filter-group">
          <label for="protocol-select" class="filter-label font-outfit">Протокол:</label>
          <select id="protocol-select" class="filter-select">
            <option value="all">Все протоколы</option>
            <option value="zigbee">Zigbee</option>
            <option value="wifi">Wi-Fi</option>
            <option value="matter">Matter / Thread</option>
          </select>
        </div>

        <!-- Device filter -->
        <div class="filter-group">
          <label for="device-select" class="filter-label font-outfit">Устройство:</label>
          <select id="device-select" class="filter-select">
            <option value="all">Все устройства</option>
            {allDevices.map(device => (
              <option value={device}>{device}</option>
            ))}
          </select>
        </div>

        <!-- Sort filter -->
        <div class="filter-group">
          <label for="sort-select" class="filter-label font-outfit">Сортировка:</label>
          <select id="sort-select" class="filter-select">
            <option value="newest">Сначала новые</option>
            <option value="oldest">Сначала старые</option>
          </select>
        </div>
      </div>
    </div>
    
    <!-- Scenarios Grid Container -->
    <div class="scenarios-grid" id="scenarios-grid">
      {scenarios.map((scenario) => (
        <a 
          href={`/scenarios/${scenario.id}/`} 
          class="scenario-card card-outlined"
          data-difficulty={scenario.data.difficulty || 'easy'}
          data-protocols={getProtocols(scenario.data.devices || [])}
          data-devices={JSON.stringify(scenario.data.devices || [])}
          data-date={new Date(scenario.data.publishDate).getTime()}
        >
          <div class="card-header">
            <span class={`difficulty-badge ${scenario.data.difficulty}`}>
              {getDifficultyLabel(scenario.data.difficulty)}
            </span>
            <span class="date-badge">
              {new Date(scenario.data.publishDate).toLocaleDateString('ru-RU', { year: 'numeric', month: 'long', day: 'numeric' })}
            </span>
          </div>
          <h2 class="card-title font-outfit">{scenario.data.title}</h2>
          <p class="card-desc">{scenario.data.description}</p>
          
          {scenario.data.devices && (
            <div class="card-devices">
              {scenario.data.devices.slice(0, 3).map((device) => (
                <span class="device-tag">{device}</span>
              ))}
              {scenario.data.devices.length > 3 && (
                <span class="device-tag-more">+{scenario.data.devices.length - 3}</span>
              )}
            </div>
          )}
          
          <span class="card-link font-outfit">
            Читать гайд <span class="arrow">→</span>
          </span>
        </a>
      ))}
    </div>

    <!-- Empty State -->
    <div class="empty-state card-outlined" id="empty-state" style="display: none;">
      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="empty-icon" style="color: var(--text-muted); margin-bottom: 1rem;"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
      <p class="empty-text">Ничего не найдено по выбранным фильтрам.</p>
    </div>

    <!-- Client-side Pagination -->
    <nav class="pagination" id="pagination-nav" aria-label="Навигация по страницам">
      <button class="pagination-arrow prev" id="btn-prev" aria-label="Предыдущая страница">
        ← <span>Назад</span>
      </button>

      <div class="pagination-pages" id="pagination-numbers">
        <!-- Будет генерироваться динамически -->
      </div>

      <button class="pagination-arrow next" id="btn-next" aria-label="Следующая страница">
        <span>Вперед</span> →
      </button>
    </nav>
  </section>
</Layout>

<script>
  let filteredCards: HTMLElement[] = [];
  let currentPage = 1;
  const cardsPerPage = 9;

  function initFilters() {
    const grid = document.getElementById('scenarios-grid');
    const emptyState = document.getElementById('empty-state');
    const cards = Array.from(document.querySelectorAll('.scenario-card')) as HTMLElement[];
    if (cards.length === 0 || !grid) return;

    // Элементы управления
    const diffPills = document.querySelectorAll('#difficulty-pills .pill-btn');
    const protocolSelect = document.getElementById('protocol-select') as HTMLSelectElement;
    const deviceSelect = document.getElementById('device-select') as HTMLSelectElement;
    const sortSelect = document.getElementById('sort-select') as HTMLSelectElement;
    
    const btnPrev = document.getElementById('btn-prev') as HTMLButtonElement;
    const btnNext = document.getElementById('btn-next') as HTMLButtonElement;
    const numbersContainer = document.getElementById('pagination-numbers');

    let currentDifficulty = 'all';

    // Считываем параметры из URL
    const parseUrlParams = () => {
      const params = new URLSearchParams(window.location.search);
      const difficulty = params.get('difficulty');
      const protocol = params.get('protocol');
      const device = params.get('device');
      const sort = params.get('sort');

      if (difficulty) {
        currentDifficulty = difficulty;
        diffPills.forEach(pill => {
          const pillDiff = pill.getAttribute('data-difficulty');
          if (pillDiff === difficulty) {
            pill.classList.add('active');
          } else {
            pill.classList.remove('active');
          }
        });
      }
      if (protocol && protocolSelect) protocolSelect.value = protocol;
      if (device && deviceSelect) deviceSelect.value = device;
      if (sort && sortSelect) sortSelect.value = sort;
    };

    // Обновляем параметры в URL
    const updateUrlParams = () => {
      const params = new URLSearchParams();
      if (currentDifficulty !== 'all') params.set('difficulty', currentDifficulty);
      if (protocolSelect && protocolSelect.value !== 'all') params.set('protocol', protocolSelect.value);
      if (deviceSelect && deviceSelect.value !== 'all') params.set('device', deviceSelect.value);
      if (sortSelect && sortSelect.value !== 'newest') params.set('sort', sortSelect.value);

      const newRelativePathQuery = window.location.pathname + (params.toString() ? '?' + params.toString() : '');
      window.history.pushState(null, '', newRelativePathQuery);
    };

    const filterAndSort = () => {
      const activeProtocol = protocolSelect ? protocolSelect.value : 'all';
      const activeDevice = deviceSelect ? deviceSelect.value : 'all';
      const activeSort = sortSelect ? sortSelect.value : 'newest';

      // 1. Фильтрация
      filteredCards = cards.filter(card => {
        const diff = card.getAttribute('data-difficulty');
        const protocols = (card.getAttribute('data-protocols') || '').split(',');
        const devices = JSON.parse(card.getAttribute('data-devices') || '[]');

        const matchDiff = currentDifficulty === 'all' || diff === currentDifficulty;
        const matchProtocol = activeProtocol === 'all' || protocols.includes(activeProtocol);
        const matchDevice = activeDevice === 'all' || devices.includes(activeDevice);

        return matchDiff && matchProtocol && matchDevice;
      });

      // 2. Сортировка
      filteredCards.sort((a, b) => {
        const dateA = parseInt(a.getAttribute('data-date') || '0');
        const dateB = parseInt(b.getAttribute('data-date') || '0');
        return activeSort === 'newest' ? dateB - dateA : dateA - dateB;
      });

      // 3. Отображение пустого состояния
      if (emptyState && grid) {
        if (filteredCards.length === 0) {
          emptyState.style.display = 'flex';
          grid.style.display = 'none';
        } else {
          emptyState.style.display = 'none';
          grid.style.display = 'grid';
        }
      }

      currentPage = 1;
      updatePagination();
      updateUrlParams();
    };

    const updatePagination = () => {
      const totalPages = Math.ceil(filteredCards.length / cardsPerPage);
      
      // Скрываем/показываем всю пагинацию, если страниц <= 1
      const paginationNav = document.getElementById('reading-progress'); // wait, page-navigation is #pagination-nav
      const pagNav = document.getElementById('pagination-nav');
      if (pagNav) {
        pagNav.style.display = totalPages <= 1 ? 'none' : 'flex';
      }

      // Скрываем все карточки
      cards.forEach(card => card.style.display = 'none');

      // Показываем карточки текущей страницы
      const startIdx = (currentPage - 1) * cardsPerPage;
      const endIdx = startIdx + cardsPerPage;
      const cardsToDisplay = filteredCards.slice(startIdx, endIdx);
      cardsToDisplay.forEach(card => {
        card.style.display = 'flex';
      });

      // Обновляем кнопки вперед/назад
      if (btnPrev) {
        if (currentPage === 1) {
          btnPrev.classList.add('disabled');
          btnPrev.disabled = true;
        } else {
          btnPrev.classList.remove('disabled');
          btnPrev.disabled = false;
        }
      }

      if (btnNext) {
        if (currentPage === totalPages || totalPages === 0) {
          btnNext.classList.add('disabled');
          btnNext.disabled = true;
        } else {
          btnNext.classList.remove('disabled');
          btnNext.disabled = false;
        }
      }

      // Генерируем номера страниц
      if (numbersContainer) {
        numbersContainer.innerHTML = '';
        for (let i = 1; i <= totalPages; i++) {
          const btn = document.createElement('button');
          btn.className = `pagination-number ${currentPage === i ? 'active' : ''}`;
          btn.textContent = String(i);
          btn.addEventListener('click', () => {
            currentPage = i;
            updatePagination();
            window.scrollTo({ top: 300, behavior: 'smooth' });
          });
          numbersContainer.appendChild(btn);
        }
      }
    };

    // Слушатели событий сложности
    diffPills.forEach(pill => {
      pill.addEventListener('click', () => {
        diffPills.forEach(p => p.classList.remove('active'));
        pill.classList.add('active');
        currentDifficulty = pill.getAttribute('data-difficulty') || 'all';
        filterAndSort();
      });
    });

    // Слушатели остальных селектов
    if (protocolSelect) protocolSelect.addEventListener('change', filterAndSort);
    if (deviceSelect) deviceSelect.addEventListener('change', filterAndSort);
    if (sortSelect) sortSelect.addEventListener('change', filterAndSort);

    // Слушатели кнопок пагинации
    if (btnPrev) {
      btnPrev.addEventListener('click', () => {
        if (currentPage > 1) {
          currentPage--;
          updatePagination();
          window.scrollTo({ top: 300, behavior: 'smooth' });
        }
      });
    }

    if (btnNext) {
      btnNext.addEventListener('click', () => {
        const totalPages = Math.ceil(filteredCards.length / cardsPerPage);
        if (currentPage < totalPages) {
          currentPage++;
          updatePagination();
          window.scrollTo({ top: 300, behavior: 'smooth' });
        }
      });
    }

    // Инициализация
    parseUrlParams();
    filterAndSort();
  }

  // Запуск при первой загрузке и при переходе на новые страницы
  initFilters();
  document.addEventListener('astro:page-load', initFilters);
</script>

<style>
  .page-section {
    padding: 2rem 0 4rem 0;
  }

  .page-header {
    text-align: center;
    margin-bottom: 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .page-heading {
    font-size: 2.5rem;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .section-divider {
    width: 50px;
    height: 4px;
    background: var(--accent-signature, #f97316);
    border-radius: 99px;
    margin: 0.75rem 0 1rem 0;
  }

  .page-desc {
    color: var(--text-secondary);
    font-size: 1.05rem;
    max-width: 600px;
    line-height: 1.6;
  }

  /* Filter Panel styling */
  .filter-panel {
    padding: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .filter-row {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    align-items: center;
    justify-content: space-between;
  }

  .filter-group {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .filter-label {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text-primary);
    white-space: nowrap;
  }

  .filter-pills {
    display: flex;
    gap: 0.5rem;
  }

  .pill-btn {
    background: var(--bg-hover);
    border: 1px solid var(--border-primary);
    color: var(--text-secondary);
    padding: 0.4rem 1rem;
    font-size: 0.85rem;
    font-weight: 600;
    border-radius: 99px;
    cursor: pointer;
    transition: all 0.25s ease;
  }

  .pill-btn:hover {
    color: var(--text-primary);
    border-color: var(--border-hover);
  }

  .pill-btn.active {
    background: var(--accent-signature, #f97316);
    color: var(--text-white);
    border-color: var(--accent-signature);
    box-shadow: 0 4px 10px var(--accent-signature-glow);
  }

  .filter-select {
    padding: 0.5rem 2rem 0.5rem 1rem;
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-sm);
    background: var(--bg-card-opaque);
    color: var(--text-primary);
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    outline: none;
    transition: border-color 0.2s ease;
    appearance: none;
    background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
    background-repeat: no-repeat;
    background-position: right 0.75rem center;
    background-size: 0.85em;
  }

  .filter-select:focus-visible {
    border-color: var(--accent-signature);
  }

  /* Scenarios Grid */
  .scenarios-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 2rem;
  }

  .scenario-card {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    text-decoration: none;
    color: inherit;
    text-align: left;
    height: 100%;
  }

  .scenario-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent-signature-semi);
    box-shadow: 0 10px 30px var(--accent-signature-glow);
    background: var(--bg-hover);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .difficulty-badge {
    padding: 0.25rem 0.75rem;
    border-radius: 99px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .difficulty-badge.easy {
    background: var(--diff-easy-bg);
    color: var(--diff-easy-text);
    border: 1px solid var(--diff-easy-border);
  }

  .difficulty-badge.medium {
    background: var(--diff-medium-bg);
    color: var(--diff-medium-text);
    border: 1px solid var(--diff-medium-border);
  }

  .difficulty-badge.hard {
    background: var(--diff-hard-bg);
    color: var(--diff-hard-text);
    border: 1px solid var(--diff-hard-border);
  }

  .date-badge {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .card-title {
    font-size: 1.35rem;
    line-height: 1.3;
    transition: color 0.3s ease;
    color: var(--text-primary);
  }

  .scenario-card:hover .card-title {
    color: var(--accent-signature, #f97316);
  }

  .card-desc {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.5;
    flex: 1;
  }

  .card-devices {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0.5rem 0;
  }

  .device-tag {
    background: var(--bg-item);
    border: 1px solid var(--border-item);
    color: var(--text-secondary);
    font-size: 0.75rem;
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-sm);
  }

  .device-tag-more {
    font-size: 0.75rem;
    color: var(--accent-signature);
    font-weight: 600;
    align-self: center;
  }

  .card-link {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--accent-signature);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    align-self: flex-start;
  }

  .card-link .arrow {
    transition: transform 0.2s ease;
  }

  .scenario-card:hover .card-link .arrow {
    transform: translateX(4px);
  }

  /* Empty state */
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
    text-align: center;
  }

  .empty-text {
    color: var(--text-secondary);
    font-size: 1.1rem;
    font-weight: 600;
  }

  /* Pagination */
  .pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.75rem;
    margin-top: 4rem;
    padding: 0.5rem;
    background: var(--bg-surface);
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-md);
    width: fit-content;
    margin-left: auto;
    margin-right: auto;
    box-shadow: var(--shadow-sm);
    backdrop-filter: blur(8px);
  }

  .pagination-arrow {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1.25rem;
    border-radius: var(--radius-sm);
    color: var(--text-primary);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    background: transparent;
    border: none;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .pagination-arrow:not(.disabled):hover {
    background: var(--bg-hover);
    color: var(--accent-signature);
  }

  .pagination-arrow.disabled {
    color: var(--text-muted);
    opacity: 0.5;
    cursor: not-allowed;
  }

  .pagination-pages {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  :global(.pagination-number) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 40px;
    height: 40px;
    padding: 0 0.5rem;
    border-radius: var(--radius-sm);
    color: var(--text-secondary);
    background: transparent;
    border: none;
    cursor: pointer;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  :global(.pagination-number:hover) {
    background: var(--bg-hover);
    color: var(--accent-signature);
  }

  :global(.pagination-number.active) {
    background: var(--accent-signature, #f97316);
    color: var(--text-white);
    box-shadow: 0 4px 10px var(--accent-signature-glow);
  }

  @media (max-width: 992px) {
    .filter-row {
      flex-direction: column;
      align-items: stretch;
      gap: 1.25rem;
    }
    
    .filter-group {
      justify-content: space-between;
    }
  }

  @media (max-width: 768px) {
    .scenarios-grid {
      grid-template-columns: 1fr;
    }
    
    .page-heading {
      font-size: 2rem;
    }
  }

  @media (max-width: 576px) {
    .pagination {
      gap: 0.4rem;
      padding: 0.4rem;
    }
    
    .pagination-arrow span {
      display: none;
    }
    
    .pagination-arrow {
      padding: 0.6rem 0.9rem;
    }
    
    :global(.pagination-number) {
      min-width: 36px;
      height: 36px;
      font-size: 0.9rem;
    }
  }
</style>
