  function renderDevices() {
    const hubSelector = document.getElementById("hub-selector") as HTMLSelectElement;
    const protocolRadios = document.getElementsByName("protocol") as NodeListOf<HTMLInputElement>;
    const searchInput = document.getElementById("device-search") as HTMLInputElement;
    const devicesContainer = document.getElementById("devices-container");
    const emptyState = document.getElementById("empty-state");
    const matchCountSpan = document.getElementById("match-count");

    if (!devicesContainer || !hubSelector || !searchInput || !emptyState || !matchCountSpan) return;

    // Получаем текущие значения фильтров
    const selectedHub = hubSelector.value;
    
    let selectedProtocol = "all";
    for (const radio of protocolRadios) {
      if (radio.checked) {
        selectedProtocol = radio.value;
        // Обновляем визуальный класс active
        radio.closest(".protocol-radio-card")?.classList.add("active");
      } else {
        radio.closest(".protocol-radio-card")?.classList.remove("active");
      }
    }

    const searchQuery = searchInput.value.toLowerCase().trim();

    // Получаем активный фильтр по статусу совместимости
    const activeStatusFilterBtn = document.querySelector(".status-filter-btn.active");
    const statusFilter = activeStatusFilterBtn ? activeStatusFilterBtn.getAttribute("data-filter") : "all";

    // Фильтруем устройства
    const filteredDevices = devicesDb.filter(device => {
      // 1. Фильтр по протоколу
      if (selectedProtocol !== "all" && device.protocol !== selectedProtocol) {
        return false;
      }

      // 2. Фильтр по поисковому запросу
      if (searchQuery) {
        const nameMatch = device.name.toLowerCase().includes(searchQuery);
        const brandMatch = device.brand.toLowerCase().includes(searchQuery);
        const categoryMatch = device.category.toLowerCase().includes(searchQuery);
        if (!nameMatch && !brandMatch && !categoryMatch) {
          return false;
        }
      }

      // 3. Получаем статус для выбранного хаба
      const hubData = device.compatibility[selectedHub as keyof typeof device.compatibility];
      const status = hubData ? hubData.status : "incompatible";

      // 4. Фильтр по статусу совместимости
      if (statusFilter !== "all" && status !== statusFilter) {
        return false;
      }

      return true;
    });

    // Очищаем контейнер
    devicesContainer.innerHTML = "";
    matchCountSpan.textContent = filteredDevices.length.toString();

    if (filteredDevices.length === 0) {
      emptyState.classList.remove("hidden");
      return;
    }

    emptyState.classList.add("hidden");

    // Рендерим карточки
    filteredDevices.forEach(device => {
      const hubData = device.compatibility[selectedHub as keyof typeof device.compatibility];
      const status = hubData ? hubData.status : "incompatible";
      const notes = hubData ? hubData.notes : "Устройства не совместимы в данной конфигурации.";

      let statusBadgeClass = "";
      let statusText = "";
      let statusIcon = "";

      if (status === "direct") {
        statusBadgeClass = "status-direct";
        statusText = "Напрямую";
        statusIcon = `<svg class="status-svg" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
      } else if (status === "bridge") {
        statusBadgeClass = "status-bridge";
        statusText = "Через шлюз";
        statusIcon = `<svg class="status-svg" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>`;
      } else {
        statusBadgeClass = "status-incompatible";
        statusText = "Несовместимо";
        statusIcon = `<svg class="status-svg" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" x2="6" y1="6" y2="18"></line><line x1="6" x2="18" y1="6" y2="18"></line></svg>`;
      }

      // Получаем красивый бейдж протокола
      let protocolBadge = "";
      if (device.protocol === "zigbee") {
        protocolBadge = '<span class="protocol-badge protocol-zigbee">Zigbee 3.0</span>';
      } else if (device.protocol === "wifi") {
        protocolBadge = '<span class="protocol-badge protocol-wifi">Wi-Fi 2.4G</span>';
      } else if (device.protocol === "matter-thread") {
        protocolBadge = '<span class="protocol-badge protocol-matter">Matter Thread</span>';
      }

      const card = document.createElement("div");
      card.className = "device-compat-card card-outlined";
      card.innerHTML = `
        <div class="device-card-header">
          <div class="device-info-left">
            <span class="device-brand">${device.brand}</span>
            <h3 class="device-title font-outfit">${device.name}</h3>
          </div>
          <div class="device-status-badge ${statusBadgeClass}">
            ${statusIcon}
            <span>${statusText}</span>
          </div>
        </div>
        
        <div class="device-card-body">
          <p class="device-specs">${device.specs}</p>
          <div class="device-compatibility-note">
            <strong>Совместимость:</strong> ${notes}
          </div>
        </div>

        <div class="device-card-footer">
          ${protocolBadge}
          <span class="device-category-badge">${device.category}</span>
        </div>
      `;
      devicesContainer.appendChild(card);
    });
  }

  function initCompatibilityChecker() {
    const hubSelector = document.getElementById("hub-selector");
    const protocolRadios = document.getElementsByName("protocol");
    const searchInput = document.getElementById("device-search");
    const statusFilterBtns = document.querySelectorAll(".status-filter-btn");

    if (hubSelector) {
      hubSelector.addEventListener("change", renderDevices);
    }

    if (protocolRadios) {
      protocolRadios.forEach(radio => {
        radio.addEventListener("change", renderDevices);
      });
    }

    if (searchInput) {
      searchInput.addEventListener("input", renderDevices);
    }

    if (statusFilterBtns) {
      statusFilterBtns.forEach(btn => {
        btn.addEventListener("click", (e) => {
          statusFilterBtns.forEach(b => b.classList.remove("active"));
          btn.classList.add("active");
          renderDevices();
        });
      });
    }

    renderDevices();
  }

  // Запуск скриптов при первой загрузке и смене страниц Astro
  initCompatibilityChecker();
  document.addEventListener("astro:page-load", initCompatibilityChecker);
</script>

