---
import Layout from "../layouts/Layout.astro";

// SEO метаданные для страницы совместимости
const title = "Совместимость устройств с Яндекс Алисой (Zigbee, Wi-Fi, Matter)";
const description = "Интерактивная таблица совместимости умного дома. Проверьте, какие датчики, реле и лампочки работают с вашей Яндекс Станцией напрямую или через шлюзы.";

const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	itemListElement: [
		{
			"@type": "ListItem",
			position: 1,
			name: "Главная",
			item: "https://smart-hub.info/",
		},
		{
			"@type": "ListItem",
			position: 2,
			name: "Совместимость",
			item: "https://smart-hub.info/compatibility/",
		},
	],
};

const jsonLdString = JSON.stringify([breadcrumbSchema]);
---

<Layout title={title} description={description} jsonLd={jsonLdString}>
  <div class="compatibility-container">
    <!-- Breadcrumbs -->
    <nav class="breadcrumbs font-outfit" aria-label="Хлебные крошки">
      <a href="/">Главная</a>
      <span class="separator">/</span>
      <span class="current">Совместимость устройств</span>
    </nav>

    <!-- Header Banner -->
    <header class="compatibility-hero card-elevated">
      <span class="category-badge">Интерактивный инструмент</span>
      <h1 class="page-title font-outfit">Проверка совместимости устройств</h1>
      <p class="hero-desc">
        Выберите вашу Яндекс Станцию или хаб, протокол связи и найдите совместимые датчики, лампочки и реле. База данных актуальна на 2026 год.
      </p>
      <div class="banner-glow" aria-hidden="true"></div>
    </header>

    <!-- Interactive Checker Grid -->
    <div class="checker-grid">
      <!-- Controls Panel -->
      <aside class="controls-panel card-outlined">
        <h2 class="panel-section-title font-outfit">
          <svg class="panel-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.1a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"></path><circle cx="12" cy="12" r="3"></circle></svg>
          Параметры конфигурации
        </h2>

        <!-- Step 1: Select Hub -->
        <div class="control-group">
          <label class="control-label font-outfit">1. Ваш умный хаб / колонка</label>
          <div class="custom-select-wrapper">
            <select id="hub-selector" class="custom-select font-outfit">
              <option value="yandex-midi" selected>Яндекс Станция Миди (встроенный Zigbee)</option>
              <option value="yandex-max-2">Яндекс Станция Макс с Zigbee</option>
              <option value="yandex-2">Яндекс Станция 2 (встроенный Zigbee)</option>
              <option value="yandex-mini-3">Яндекс Станция Мини 3 (только Wi-Fi)</option>
              <option value="yandex-hub">Яндекс Хаб (Zigbee + Wi-Fi + IR)</option>
              <option value="aqara-m2">Aqara Hub M2 (для сопряжения через навык Aqara)</option>
              <option value="tuya-hub">Tuya Zigbee Hub (для сопряжения через Smart Life)</option>
              <option value="no-hub">Нет хаба (только Wi-Fi и облачные интеграции)</option>
            </select>
          </div>
        </div>

        <!-- Step 2: Select Protocol -->
        <div class="control-group">
          <label class="control-label font-outfit">2. Протокол подключения</label>
          <div class="protocol-radio-group">
            <label class="protocol-radio-card active">
              <input type="radio" name="protocol" value="all" checked />
              <span class="protocol-name font-outfit">Все протоколы</span>
              <span class="protocol-desc">Показать полный список</span>
            </label>
            <label class="protocol-radio-card">
              <input type="radio" name="protocol" value="zigbee" />
              <span class="protocol-name font-outfit">Zigbee 3.0</span>
              <span class="protocol-desc">Энергоэффективная локальная сеть</span>
            </label>
            <label class="protocol-radio-card">
              <input type="radio" name="protocol" value="wifi" />
              <span class="protocol-name font-outfit">Wi-Fi</span>
              <span class="protocol-desc">Прямое подключение к роутеру</span>
            </label>
            <label class="protocol-radio-card">
              <input type="radio" name="protocol" value="matter-thread" />
              <span class="protocol-name font-outfit">Matter (Thread)</span>
              <span class="protocol-desc">Новый стандарт автоматизации 2026</span>
            </label>
          </div>
        </div>

        <!-- Filter & Search -->
        <div class="control-group search-group">
          <label class="control-label font-outfit" for="device-search">Быстрый поиск</label>
          <div class="search-input-wrapper">
            <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" x2="16.65" y1="21" y2="16.65"></line></svg>
            <input type="text" id="device-search" class="search-input" placeholder="Поиск по названию или бренду..." />
          </div>
        </div>
      </aside>

      <!-- Results Panel -->
      <main class="results-panel">
        <!-- Results Bar -->
        <div class="results-header card-flat">
          <div class="results-count font-outfit">
            Найдено устройств: <span id="match-count">0</span>
          </div>
          <div class="filter-badges-row">
            <button class="status-filter-btn active" data-filter="all">Все</button>
            <button class="status-filter-btn" data-filter="direct">Напрямую (Zigbee/Wi-Fi)</button>
            <button class="status-filter-btn" data-filter="bridge">Через шлюз бренда</button>
            <button class="status-filter-btn" data-filter="incompatible">Не совместимы</button>
          </div>
        </div>

        <!-- Grid of Devices -->
        <div class="devices-grid" id="devices-container">
          <!-- Dynamically populated via JS -->
        </div>

        <!-- Empty state -->
        <div class="empty-state card-flat hidden" id="empty-state">
          <svg class="empty-icon" xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="8" x2="12" y1="12" y2="12"></line></svg>
          <h3 class="empty-title font-outfit">Ничего не найдено</h3>
          <p class="empty-desc">Попробуйте изменить параметры поиска или выбрать другой протокол/хаб.</p>
        </div>
      </main>
    </div>

    <!-- FAQ Section -->
    <section class="compatibility-faq card-outlined">
      <h2 class="faq-title font-outfit">Особенности совместимости устройств</h2>
      
      <details class="faq-item">
        <summary class="faq-summary font-outfit">Как Яндекс Станция работает с Zigbee устройствами Aqara и Tuya?</summary>
        <div class="faq-content">
          <p>
            Яндекс Станции со встроенным Zigbee модулем (Миди, Макс с Zigbee, Станция 2, Хаб) могут сопрягать большинство датчиков Aqara, Tuya и Sonoff напрямую без сторонних шлюзов. Устройства будут работать локально, что гарантирует мгновенный отклик даже при отключении интернета. Если же у вас Станция без Zigbee (например, Лайт или Мини 3), вам понадобится фирменный шлюз Aqara/Tuya, который связывается с Алисой через «облако» (навык бренда).
          </p>
        </div>
      </details>

      <details class="faq-item">
        <summary class="faq-summary font-outfit">Что такое Matter и как это меняет работу Умного Дома в 2026 году?</summary>
        <div class="faq-content">
          <p>
            Matter — это единый прикладной протокол умного дома. Устройства с Matter (работающие по Wi-Fi или Thread) совместимы со всеми экосистемами (Яндекс, Apple Home, Google Home) одновременно. Больше нет необходимости подбирать конкретный бренд под Алису. Яндекс Станции второго поколения и Яндекс Хаб получили поддержку Matter, что позволяет подключать новые датчики и реле напрямую.
          </p>
        </div>
      </details>

      <details class="faq-item">
        <summary class="faq-summary font-outfit">Будут ли работать Wi-Fi устройства без хаба Яндекс?</summary>
        <div class="faq-content">
          <p>
            Да, абсолютно любые Wi-Fi лампочки, розетки и пылесосы подключаются напрямую к вашему домашнему роутеру (на частоте 2.4 ГГц) и не требуют никаких умных колонок Яндекса для своей работы. Алиса управляет ими через интернет, отправляя команды на сервера производителя.
          </p>
        </div>
      </details>
    </section>
  </div>
</Layout>

