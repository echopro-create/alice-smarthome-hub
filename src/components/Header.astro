---
import Search from "./Search.astro";
---
<header class="glass glass-header-nav">
  <div class="container header-container">
    <a href="/" class="logo">
      <span class="logo-icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="logo-svg-icon"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275Z"/><path d="m5 3 1 2.5L8.5 6 6 7 5 9.5 4 7 1.5 6 4 5.5Z"/><path d="m19 17 1 2.5 2.5.5-2.5 1-1 2.5-1-2.5-2.5-1 2.5-1Z"/></svg>
      </span>
      <span class="logo-text font-outfit">Умный Дом <span class="coral-highlight">Алисы</span></span>
    </a>

    <div class="header-actions">
      <nav class="nav-links" aria-label="Главное меню">
        <a href="/" class="nav-link">Главная</a>
        
        <div class="mega-menu-container">
          <button class="nav-link mega-trigger" aria-expanded="false" aria-controls="mega-menu">
            Категории <span class="chevron" aria-hidden="true">▼</span>
          </button>
          <div class="mega-menu-dropdown card-elevated" id="mega-menu">
            <div class="mega-menu-grid">
              <!-- Освещение -->
              <div class="mega-menu-col">
                <span class="mega-menu-title"><span class="mega-icon-wrap">💡</span> Освещение</span>
                <ul class="mega-menu-links">
                  <li><a href="/scenarios/light-alarm-clock/">Световой будильник</a></li>
                  <li><a href="/scenarios/night-light-motion/">Ночник по датчику</a></li>
                  <li><a href="/scenarios/smart-dimming-night-hallway/">Умное диммирование</a></li>
                  <li><a href="/scenarios/smart-switch-no-neutral/">Выключатель без нуля</a></li>
                </ul>
              </div>
              <!-- Климат -->
              <div class="mega-menu-col">
                <span class="mega-menu-title"><span class="mega-icon-wrap">🌡️</span> Климат</span>
                <ul class="mega-menu-links">
                  <li><a href="/scenarios/humidifier-automation/">Управление увлажнителем</a></li>
                  <li><a href="/scenarios/conditioner-smart-control/">Кондиционер по датчику</a></li>
                  <li><a href="/scenarios/bathroom-ventilation-humidity/">Вытяжка в ванной</a></li>
                  <li><a href="/scenarios/boiler-smart-heating/">Умное отопление котла</a></li>
                </ul>
              </div>
              <!-- Безопасность -->
              <div class="mega-menu-col">
                <span class="mega-menu-title"><span class="mega-icon-wrap">🛡️</span> Безопасность</span>
                <ul class="mega-menu-links">
                  <li><a href="/scenarios/leak-water-prevention/">Защита от протечек</a></li>
                  <li><a href="/scenarios/smoke-gas-alarm/">Датчик дыма и газа</a></li>
                  <li><a href="/scenarios/security-perimeter-check/">Охрана периметра</a></li>
                  <li><a href="/scenarios/kids-come-home/">Дети пришли домой</a></li>
                </ul>
              </div>
              <!-- Мультимедиа -->
              <div class="mega-menu-col">
                <span class="mega-menu-title"><span class="mega-icon-wrap">🔊</span> Мультимедиа</span>
                <ul class="mega-menu-links">
                  <li><a href="/scenarios/movie-time-scenario/">Режим домашнего кино</a></li>
                  <li><a href="/scenarios/welcome-home-station/">Приветствие Алисы</a></li>
                  <li><a href="/scenarios/doorbell-mute-audio/">Беззвучный звонок</a></li>
                  <li><a href="/troubleshooting/yandex-station-wifi-drop/">Отвалы Wi-Fi на Станции</a></li>
                </ul>
              </div>
              <!-- Энергия -->
              <div class="mega-menu-col">
                <span class="mega-menu-title"><span class="mega-icon-wrap">🔌</span> Энергия и хабы</span>
                <ul class="mega-menu-links">
                  <li><a href="/scenarios/iron-safety-off/">Безопасный утюг</a></li>
                  <li><a href="/scenarios/smart-plug-overload/">Защита от перегрузки</a></li>
                  <li><a href="/troubleshooting/battery-drain-troubleshooting/">Разряд батареек</a></li>
                  <li><a href="/compatibility/">Совместимость хабов</a></li>
                </ul>
              </div>
            </div>
          </div>
        </div>

        <a href="/scenarios/" class="nav-link">Сценарии</a>
        <a href="/troubleshooting/" class="nav-link">Траблшутинг</a>
      </nav>
      
      <Search />
      
      <button id="theme-toggle" class="theme-toggle-btn" aria-label="Переключить цветовую тему">
        <!-- Sun icon -->
        <svg class="sun-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2"></path>
          <path d="M12 20v2"></path>
          <path d="M4.93 4.93l1.41 1.41"></path>
          <path d="M17.66 17.66l1.41 1.41"></path>
          <path d="M2 12h2"></path>
          <path d="M20 12h2"></path>
          <path d="M6.34 17.66l-1.41 1.41"></path>
          <path d="M19.07 4.93l-1.41 1.41"></path>
        </svg>
        <!-- Moon icon -->
        <svg class="moon-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
        </svg>
      </button>

      <button id="menu-toggle" class="menu-toggle-btn hamburger-btn" aria-label="Открыть мобильное меню" aria-expanded="false" aria-controls="mobile-menu">
        <svg class="menu-icon-open" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
        <svg class="menu-icon-close" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: none;"><line x1="18" x2="6" y1="6" y2="18"/><line x1="6" x2="18" y1="6" y2="18"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile Navigation Drawer -->
  <div id="mobile-menu" class="mobile-drawer card-elevated" aria-hidden="true" style="display: none;">
    <div class="mobile-drawer-content">
      <a href="/" class="mobile-nav-link">Главная</a>
      <a href="/scenarios/" class="mobile-nav-link">Все сценарии</a>
      <a href="/troubleshooting/" class="mobile-nav-link">База неисправностей</a>
      <a href="/compatibility/" class="mobile-nav-link">Таблица совместимости</a>
      <a href="/about" class="mobile-nav-link">О проекте</a>
      <a href="/contacts" class="mobile-nav-link">Контакты</a>
    </div>
  </div>

  <!-- Reading Progress Bar -->
  <div class="reading-progress-bar" id="reading-progress" aria-hidden="true"></div>
</header>

<script>
  function initHeaderControls() {
    // 1. Theme toggle
    const toggleBtn = document.getElementById('theme-toggle');
    if (toggleBtn) {
      toggleBtn.replaceWith(toggleBtn.cloneNode(true));
      const newToggleBtn = document.getElementById('theme-toggle');
      if (newToggleBtn) {
        newToggleBtn.addEventListener('click', () => {
          const isDark = document.documentElement.classList.toggle('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
        });
      }
    }

    // 2. Mobile Menu Toggle
    const menuToggle = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    
    if (menuToggle && mobileMenu) {
      const openIcon = menuToggle.querySelector('.menu-icon-open') as HTMLElement;
      const closeIcon = menuToggle.querySelector('.menu-icon-close') as HTMLElement;
      
      const toggleDrawer = () => {
        const expanded = menuToggle.getAttribute('aria-expanded') === 'true';
        menuToggle.setAttribute('aria-expanded', String(!expanded));
        mobileMenu.setAttribute('aria-hidden', String(expanded));
        
        if (!expanded) {
          mobileMenu.style.display = 'block';
          setTimeout(() => mobileMenu.classList.add('open'), 10);
          if (openIcon) openIcon.style.display = 'none';
          if (closeIcon) closeIcon.style.display = 'block';
          document.body.style.overflow = 'hidden';
        } else {
          mobileMenu.classList.remove('open');
          setTimeout(() => { mobileMenu.style.display = 'none'; }, 300);
          if (openIcon) openIcon.style.display = 'block';
          if (closeIcon) closeIcon.style.display = 'none';
          document.body.style.overflow = '';
        }
      };

      menuToggle.addEventListener('click', toggleDrawer);

      // Clean up drawer state on page swap (Astro View Transitions)
      document.addEventListener('astro:before-swap', () => {
        document.body.style.overflow = '';
      }, { once: true });
    }

    // 3. Reading progress calculation
    const progressCalculated = () => {
      const bar = document.getElementById('reading-progress');
      if (!bar) return;
      const winScroll = document.documentElement.scrollTop || document.body.scrollTop;
      const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      const scrolled = height > 0 ? (winScroll / height) * 100 : 0;
      bar.style.width = scrolled + '%';
    };

    window.removeEventListener('scroll', progressCalculated);
    window.addEventListener('scroll', progressCalculated);
  }

  // Run on startup
  initHeaderControls();
  // Run on View Transitions page swap
  document.addEventListener('astro:page-load', initHeaderControls);
</script>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    padding: 1rem 0;
    margin-bottom: 2.5rem;
  }

  .glass-header-nav {
    background: var(--bg-surface);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border-primary);
  }

  .header-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--text-primary);
    text-decoration: none;
  }

  .logo-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent-signature, #f97316);
    filter: drop-shadow(0 0 6px var(--accent-signature-semi, rgba(249, 115, 22, 0.2)));
  }

  .coral-highlight {
    color: var(--accent-signature, #f97316);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .nav-link {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.25s ease;
    cursor: pointer;
    background: transparent;
    border: none;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.5rem 0;
  }

  .nav-link:hover, .nav-link:focus-visible {
    color: var(--text-primary);
  }

  .mega-trigger .chevron {
    font-size: 0.65rem;
    transition: transform 0.25s ease;
  }

  .mega-menu-container:hover .mega-trigger .chevron {
    transform: rotate(180deg);
    color: var(--accent-signature);
  }

  /* Mega-Menu drop-down styling */
  .mega-menu-container {
    position: relative;
  }

  .mega-menu-dropdown {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(10px);
    width: 820px;
    max-width: 90vw;
    padding: 2rem;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.2s ease, visibility 0.2s ease;
    z-index: 120;
    margin-top: 0.5rem;
  }

  .mega-menu-container:hover .mega-menu-dropdown,
  .mega-menu-container:focus-within .mega-menu-dropdown {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  .mega-menu-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1.5rem;
  }

  .mega-menu-col {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .mega-menu-title {
    font-size: 0.85rem;
    font-weight: 800;
    color: var(--text-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding-bottom: 0.35rem;
    border-bottom: 1px solid var(--border-primary);
  }

  .mega-icon-wrap {
    font-size: 1rem;
  }

  .mega-menu-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .mega-menu-links a {
    font-size: 0.85rem;
    color: var(--text-secondary);
    transition: color 0.2s ease, transform 0.2s ease;
    display: inline-block;
    line-height: 1.3;
  }

  .mega-menu-links a:hover {
    color: var(--accent-signature, #f97316);
    transform: translateX(2px);
  }

  /* Hamburger & Drawer button */
  .theme-toggle-btn, .hamburger-btn {
    background: transparent;
    border: 1px solid var(--border-primary);
    color: var(--text-secondary);
    padding: 0.5rem;
    border-radius: var(--radius-sm);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    min-width: 44px;
    min-height: 44px;
  }

  .theme-toggle-btn:hover, .hamburger-btn:hover {
    color: var(--text-primary);
    border-color: var(--border-hover);
    background: var(--bg-hover);
  }

  .hamburger-btn {
    display: none;
  }

  /* Mobile navigation drawer styling */
  .mobile-drawer {
    position: fixed;
    top: 64px;
    left: 0;
    width: 100vw;
    height: calc(100vh - 64px);
    background: var(--bg-card-opaque, #ffffff);
    z-index: 99;
    padding: 2rem 1.5rem;
    transform: translateY(-20px);
    opacity: 0;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease;
  }

  .mobile-drawer.open {
    transform: translateY(0);
    opacity: 1;
  }

  .mobile-drawer-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .mobile-nav-link {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text-primary);
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border-primary);
  }

  .mobile-nav-link:hover {
    color: var(--accent-signature);
  }

  /* Theme Toggle icons */
  .sun-icon {
    display: none;
  }
  .moon-icon {
    display: block;
  }

  :global(.dark) .sun-icon {
    display: block;
  }
  :global(.dark) .moon-icon {
    display: none;
  }

  /* Progress Bar styling */
  .reading-progress-bar {
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 0%;
    height: 2px;
    background: var(--accent-signature, #f97316);
    box-shadow: 0 0 8px var(--accent-signature-glow);
    z-index: 101;
    transition: width 0.1s ease;
  }

  @media (max-width: 992px) {
    .nav-links {
      display: none;
    }
    
    .hamburger-btn {
      display: flex;
    }
  }

  @media (max-width: 640px) {
    header {
      padding: 0.75rem 0;
    }
  }
</style>
