---
import Search from "./Search.astro";
---
<header class="glass glass-header-nav">
  <div class="container header-container">
    <a href="/" class="logo">
      <span class="logo-icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="logo-svg-icon"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275Z"/><path d="m5 3 1 2.5L8.5 6 6 7 5 9.5 4 7 1.5 6 4 5.5Z"/><path d="m19 17 1 2.5 2.5.5-2.5 1-1 2.5-1-2.5-2.5-1 2.5-1Z"/></svg>
      </span>
      <span class="logo-text font-outfit">Умный Дом <span class="coral-highlight">Алисы</span></span>
    </a>
    <nav class="nav-links" aria-label="Главное меню">
      <a href="/" class="nav-link">Главная</a>
      <a href="/scenarios/" class="nav-link">Сценарии</a>
      <a href="/troubleshooting/" class="nav-link">Траблшутинг</a>
      <a href="/compatibility/" class="nav-link">Совместимость</a>
      <a href="/about/" class="nav-link">О проекте</a>
    </nav>

    <div class="header-actions">
      
      <Search />
      
      <button id="theme-toggle" class="theme-toggle-btn" aria-label="Переключить цветовую тему">
        <!-- Sun icon -->
        <svg class="sun-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2"></path>
          <path d="M12 20v2"></path>
          <path d="M4.93 4.93l1.41 1.41"></path>
          <path d="M17.66 17.66l1.41 1.41"></path>
          <path d="M2 12h2"></path>
          <path d="M20 12h2"></path>
          <path d="M6.34 17.66l-1.41 1.41"></path>
          <path d="M19.07 4.93l-1.41 1.41"></path>
        </svg>
        <!-- Moon icon -->
        <svg class="moon-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
        </svg>
      </button>

      <button id="menu-toggle" class="menu-toggle-btn hamburger-btn" aria-label="Открыть мобильное меню" aria-expanded="false" aria-controls="mobile-menu">
        <svg class="menu-icon-open" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
        <svg class="menu-icon-close" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: none;"><line x1="18" x2="6" y1="6" y2="18"/><line x1="6" x2="18" y1="6" y2="18"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile Navigation Drawer -->
  <div id="mobile-menu" class="mobile-drawer card-elevated" aria-hidden="true" style="display: none;">
    <div class="mobile-drawer-content">
      <a href="/" class="mobile-nav-link">Главная</a>
      <a href="/scenarios/" class="mobile-nav-link">Все сценарии</a>
      <a href="/troubleshooting/" class="mobile-nav-link">База неисправностей</a>
      <a href="/compatibility/" class="mobile-nav-link">Таблица совместимости</a>
      <a href="/about/" class="mobile-nav-link">О проекте</a>
    </div>
  </div>

  <!-- Reading Progress Bar -->
  <div class="reading-progress-bar" id="reading-progress" aria-hidden="true"></div>
</header>

<script>
  function initHeaderControls() {
    // 1. Theme toggle
    const toggleBtn = document.getElementById('theme-toggle');
    if (toggleBtn) {
      toggleBtn.replaceWith(toggleBtn.cloneNode(true));
      const newToggleBtn = document.getElementById('theme-toggle');
      if (newToggleBtn) {
        newToggleBtn.addEventListener('click', () => {
          const isDark = document.documentElement.classList.toggle('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
        });
      }
    }

    // 2. Mobile Menu Toggle
    const menuToggle = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    
    if (menuToggle && mobileMenu) {
      const openIcon = menuToggle.querySelector('.menu-icon-open') as HTMLElement;
      const closeIcon = menuToggle.querySelector('.menu-icon-close') as HTMLElement;
      
      const toggleDrawer = () => {
        const expanded = menuToggle.getAttribute('aria-expanded') === 'true';
        menuToggle.setAttribute('aria-expanded', String(!expanded));
        mobileMenu.setAttribute('aria-hidden', String(expanded));
        
        if (!expanded) {
          mobileMenu.style.display = 'block';
          setTimeout(() => mobileMenu.classList.add('open'), 10);
          if (openIcon) openIcon.style.display = 'none';
          if (closeIcon) closeIcon.style.display = 'block';
          document.body.style.overflow = 'hidden';
        } else {
          mobileMenu.classList.remove('open');
          setTimeout(() => { mobileMenu.style.display = 'none'; }, 300);
          if (openIcon) openIcon.style.display = 'block';
          if (closeIcon) closeIcon.style.display = 'none';
          document.body.style.overflow = '';
        }
      };

      menuToggle.addEventListener('click', toggleDrawer);

      // Clean up drawer state on page swap (Astro View Transitions)
      document.addEventListener('astro:before-swap', () => {
        document.body.style.overflow = '';
      }, { once: true });
    }

    // 3. Scroll effects (Reading progress + Sticky header shadow)
    const header = document.querySelector('.glass-header-nav');
    const bar = document.getElementById('reading-progress');

    const handleScroll = () => {
      const winScroll = document.documentElement.scrollTop || document.body.scrollTop;
      
      // Reading progress
      if (bar) {
        const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
        const scrolled = height > 0 ? (winScroll / height) * 100 : 0;
        bar.style.width = scrolled + '%';
      }

      // Header scrolled state
      if (header) {
        if (winScroll > 15) {
          header.classList.add('is-scrolled');
        } else {
          header.classList.remove('is-scrolled');
        }
      }
    };

    window.removeEventListener('scroll', handleScroll);
    window.addEventListener('scroll', handleScroll);
    // Initial call to set state on load
    handleScroll();
  }

  // Run on startup
  initHeaderControls();
  // Run on View Transitions page swap
  document.addEventListener('astro:page-load', initHeaderControls);
</script>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
      padding: 0.5rem 0;
    margin-bottom: 2.5rem;
  }

  .glass-header-nav {
    background: var(--bg-surface);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border-primary);
    transition: box-shadow 0.25s ease, background-color 0.25s ease, border-color 0.25s ease;
  }

  .glass-header-nav.is-scrolled {
    background: var(--bg-surface-scrolled, rgba(245, 245, 245, 0.9));
    border-bottom-color: rgba(29, 115, 112, 0.15);
    box-shadow: 
      0 10px 30px -10px rgba(29, 115, 112, 0.08), 
      0 1px 3px rgba(0, 0, 0, 0.02);
  }

  :global(.dark) .glass-header-nav.is-scrolled {
    background: var(--bg-surface-scrolled-dark, rgba(18, 18, 18, 0.9));
    border-bottom-color: rgba(79, 179, 175, 0.25);
    box-shadow: 
      0 10px 30px -10px rgba(0, 0, 0, 0.5), 
      0 1px 4px rgba(0, 0, 0, 0.3),
      0 0 20px rgba(79, 179, 175, 0.03);
  }

  .header-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--text-primary);
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .logo-text {
    white-space: nowrap;
  }

  .logo-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent-signature, #a855f7);
    filter: drop-shadow(0 0 6px var(--accent-signature-semi, rgba(168, 85, 247, 0.2)));
  }

  .coral-highlight {
    color: var(--accent-signature, #a855f7);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .nav-links {
    display: flex;
    gap: 1.25rem;
    align-items: center;
  }

  .nav-link {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.25s ease;
    cursor: pointer;
    background: transparent;
    border: none;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.5rem 0;
    white-space: nowrap;
  }

  .nav-link:hover, .nav-link:focus-visible {
    color: var(--text-primary);
  }



  /* Hamburger & Drawer button */
  .theme-toggle-btn, .hamburger-btn {
    background: transparent;
    border: 1px solid var(--border-primary);
    color: var(--text-secondary);
    padding: 0.5rem;
    border-radius: var(--radius-sm);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    min-width: 44px;
    min-height: 44px;
  }

  .theme-toggle-btn:hover, .hamburger-btn:hover {
    color: var(--text-primary);
    border-color: var(--border-hover);
    background: var(--bg-hover);
  }

  .hamburger-btn {
    display: none;
  }

  /* Mobile navigation drawer styling */
  .mobile-drawer {
    position: fixed;
    top: 64px;
    left: 0;
    width: 100vw;
    max-width: 100%;
    height: calc(100vh - 64px);
    height: calc(100dvh - 64px);
    height: calc(100dvh - 64px);
    background: var(--bg-card-opaque, #ffffff);
    z-index: 99;
    padding: 2rem 1.5rem;
    transform: translateY(-20px);
    opacity: 0;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease;
  }

  .mobile-drawer.open {
    transform: translateY(0);
    opacity: 1;
  }

  .mobile-drawer-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .mobile-nav-link {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text-primary);
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border-primary);
  }

  .mobile-nav-link:hover {
    color: var(--accent-signature, #a855f7);
  }

  /* Theme Toggle icons */
  .sun-icon {
    display: none;
  }
  .moon-icon {
    display: block;
  }

  :global(.dark) .sun-icon {
    display: block;
  }
  :global(.dark) .moon-icon {
    display: none;
  }

  /* Progress Bar styling */
  .reading-progress-bar {
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 0%;
    height: 2px;
    background: var(--accent-signature, #a855f7);
    box-shadow: 0 0 8px var(--accent-signature-glow);
    z-index: 101;
    transition: width 0.1s ease;
  }

  @media (max-width: 1080px) {
    .nav-links {
      display: none;
    }
    
    .hamburger-btn {
      display: flex;
    }
  }

  @media (max-width: 640px) {
    header {
    padding: 0.5rem 0;
    }
  }
</style>
