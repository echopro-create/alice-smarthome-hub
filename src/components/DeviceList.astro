---
interface Props {
	devices: string[];
}

const { devices } = Astro.props;

// Функция для выбора SVG иконки устройства на основе названия
const getDeviceIcon = (deviceName: string) => {
	const name = deviceName.toLowerCase();
	if (name.includes("станция") || name.includes("колонка") || name.includes("алиса")) {
		return `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="device-svg"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/></svg>`;
	}
	if (name.includes("температур") || name.includes("влажност") || name.includes("климат")) {
		return `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="device-svg"><path d="M14 4v10.54a4 4 0 1 1-4 0V4a2 2 0 0 1 4 0Z"/></svg>`;
	}
	if (name.includes("открыт") || name.includes("двер") || name.includes("окн")) {
		return `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="device-svg"><path d="M13 4h3a2 2 0 0 1 2 2v14"/><path d="M2 20h20"/><path d="M13 4H9a2 2 0 0 0-2 2v14"/><path d="M13 15h.01"/><path d="M13 4v16"/></svg>`;
	}
	if (name.includes("движен")) {
		return `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="device-svg"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>`;
	}
	if (name.includes("розетк") || name.includes("реле") || name.includes("выключател")) {
		return `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="device-svg"><path d="M12 22v-5"/><path d="M9 8V2"/><path d="M15 8V2"/><path d="M18 8H6A2 2 0 0 0 4 10v1a4 4 0 0 0 4 4h8a4 4 0 0 0 4-4v-1a2 2 0 0 0-2-2Z"/></svg>`;
	}
	if (name.includes("ламп") || name.includes("свет") || name.includes("лент")) {
		return `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="device-svg"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .6 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/></svg>`;
	}
	if (name.includes("пульт")) {
		return `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="device-svg"><circle cx="12" cy="12" r="2"/><path d="M12 2v8"/><path d="M4.93 10.93a8 8 0 1 1 14.14 0"/></svg>`;
	}
	if (name.includes("хаб") || name.includes("шлюз")) {
		return `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="device-svg"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><path d="M9 1v3"/><path d="M15 1v3"/><path d="M9 20v3"/><path d="M15 20v3"/><path d="M20 9h3"/><path d="M20 15h3"/><path d="M1 9h3"/><path d="M1 15h3"/></svg>`;
	}
	if (name.includes("увлажнител")) {
		return `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="device-svg"><path d="M12 22a7 7 0 0 0 7-7c0-4.3-7-11-7-11S5 10.7 5 15a7 7 0 0 0 7 7Z"/></svg>`;
	}
	if (name.includes("кондиционер") || name.includes("сплит")) {
		return `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="device-svg"><line x1="2" y1="12" x2="22" y2="12"/><line x1="12" y1="2" x2="12" y2="22"/><path d="m20 16-4-4 4-4"/><path d="m4 8 4 4-4 4"/><path d="m16 4-4 4-4-4"/><path d="m8 20 4-4 4 4"/></svg>`;
	}
	return `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="device-svg"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>`;
};

// Генерация демонстрационных партнерских ссылок Яндекс Дистрибуции
const getMarketLink = (deviceName: string) => {
	const query = encodeURIComponent(deviceName);
	return `https://market.yandex.ru/search?text=${query}&clid=999&mclid=demo-cpa`;
};
---

<div class="eq-box card-outlined">
  <h2 class="eq-title font-outfit">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="inline-title-svg" style="display: inline-block; vertical-align: middle; margin-right: 0.5rem; color: var(--accent-signature, #f97316);"><path d="M12 22v-5"/><path d="M9 8V2"/><path d="M15 8V2"/><path d="M18 8H6A2 2 0 0 0 4 10v1a4 4 0 0 0 4 4h8a4 4 0 0 0 4-4v-1a2 2 0 0 0-2-2Z"/></svg>Необходимое оборудование
  </h2>
  <div class="eq-grid">
    {devices.map((device) => (
      <div class="eq-card">
        <div class="eq-info">
          <div class="eq-icon-wrap" aria-hidden="true" set:html={getDeviceIcon(device)}></div>
          <span class="eq-name">{device}</span>
        </div>
        <a 
          href={getMarketLink(device)} 
          target="_blank" 
          rel="noopener noreferrer" 
          class="eq-btn font-outfit"
        >
          <span>Купить на Яндекс Маркете</span>
          <span class="eq-btn-arrow">→</span>
        </a>
      </div>
    ))}
  </div>
</div>

<style>
  .eq-box {
    padding: 1.5rem;
    margin: 2rem 0;
    container-type: inline-size;
    container-name: eq-container;
  }

  .eq-title {
    font-size: 1.2rem;
    margin-bottom: 1.25rem;
    color: var(--text-primary);
    display: flex;
    align-items: center;
  }

  .eq-grid {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* Default Card layout (for narrow containers like sidebar or mobile screens) */
  .eq-card {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 1rem;
    padding: 1.25rem;
    background: var(--bg-item);
    border: 1px solid var(--border-item);
    border-radius: var(--radius-md);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), 
                border-color 0.3s ease, 
                box-shadow 0.3s ease,
                background-color 0.3s ease;
  }

  .eq-card:hover {
    border-color: var(--border-hover);
  }

  .eq-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .eq-icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: var(--bg-main);
    border: 1px solid var(--border-primary);
    border-radius: 12px;
    color: var(--text-secondary);
    box-shadow: var(--shadow-inset);
    flex-shrink: 0;
    transition: transform 0.2s ease, color 0.2s ease;
  }

  .eq-card:hover .eq-icon-wrap {
    transform: scale(1.05) rotate(3deg);
    color: var(--accent-signature);
  }

  .eq-name {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--text-primary);
    line-height: 1.4;
  }

  .eq-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-white);
    background: linear-gradient(135deg, var(--accent-signature) 0%, var(--accent-signature) 100%);
    border-radius: var(--radius-sm);
    box-shadow: 0 4px 12px var(--accent-signature-trans);
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    text-decoration: none;
    width: 100%;
    min-height: 44px;
  }

  .eq-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 16px var(--accent-signature-semi);
    filter: brightness(1.05);
  }

  .eq-btn-arrow {
    transition: transform 0.2s ease;
  }

  .eq-btn:hover .eq-btn-arrow {
    transform: translateX(3px);
  }

  /* Adaptive Horizontal layout for wide containers (>= 480px) */
  @container eq-container (min-width: 480px) {
    .eq-card {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 1.5rem;
      padding: 1rem 1.5rem;
    }

    .eq-info {
      flex: 1;
      min-width: 0;
    }

    .eq-btn {
      width: auto;
      flex-shrink: 0;
    }
  }
</style>
