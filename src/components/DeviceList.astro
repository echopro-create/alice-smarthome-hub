---
interface Props {
  devices: string[];
}

const { devices } = Astro.props;

// Функция для выбора иконки устройства на основе названия
const getDeviceIcon = (deviceName: string) => {
  const name = deviceName.toLowerCase();
  if (name.includes('станция') || name.includes('колонка') || name.includes('алиса')) return '🔊';
  if (name.includes('температур') || name.includes('влажност') || name.includes('климат')) return '🌡️';
  if (name.includes('открыт') || name.includes('двер') || name.includes('окн')) return '🚪';
  if (name.includes('движен')) return '👁️';
  if (name.includes('розетк') || name.includes('реле') || name.includes('выключател')) return '🔌';
  if (name.includes('ламп') || name.includes('свет') || name.includes('лент')) return '💡';
  if (name.includes('пульт')) return '📟';
  if (name.includes('хаб') || name.includes('шлюз')) return '🎛️';
  if (name.includes('увлажнител')) return '💧';
  if (name.includes('кондиционер') || name.includes('сплит')) return '❄️';
  return '⚙️';
};

// Генерация демонстрационных партнерских ссылок Яндекс Дистрибуции
const getMarketLink = (deviceName: string) => {
  const query = encodeURIComponent(deviceName);
  return `https://market.yandex.ru/search?text=${query}&clid=999&mclid=demo-cpa`;
};
---

<div class="eq-box glass">
  <h2 class="eq-title font-outfit"><span aria-hidden="true">🔌</span> Необходимое оборудование</h2>
  <div class="eq-grid">
    {devices.map((device) => (
      <div class="eq-card">
        <div class="eq-info">
          <div class="eq-icon-wrap" aria-hidden="true">
            <span class="eq-icon">{getDeviceIcon(device)}</span>
          </div>
          <span class="eq-name">{device}</span>
        </div>
        <a 
          href={getMarketLink(device)} 
          target="_blank" 
          rel="noopener noreferrer" 
          class="eq-btn font-outfit"
        >
          <span>Купить на Яндекс Маркете</span>
          <span class="eq-btn-arrow">→</span>
        </a>
      </div>
    ))}
  </div>
</div>

<style>
  .eq-box {
    padding: 1.5rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-primary);
    margin: 2rem 0;
    container-type: inline-size;
    container-name: eq-container;
  }

  .eq-title {
    font-size: 1.2rem;
    margin-bottom: 1.25rem;
    color: var(--text-primary);
  }

  .eq-grid {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* Default Card layout (for narrow containers like sidebar or mobile screens) */
  .eq-card {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 1rem;
    padding: 1.25rem;
    background: var(--bg-item);
    border: 1px solid var(--border-item);
    border-radius: var(--radius-md);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), 
                border-color 0.3s ease, 
                box-shadow 0.3s ease,
                background-color 0.3s ease;
  }

  .eq-card:hover {
    transform: translateY(-2px);
    background: var(--bg-hover);
    border-color: var(--border-hover);
    box-shadow: var(--shadow-sm);
  }

  .eq-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .eq-icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: var(--bg-main);
    border: 1px solid var(--border-primary);
    border-radius: 12px;
    font-size: 1.4rem;
    box-shadow: var(--shadow-inset);
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .eq-card:hover .eq-icon-wrap {
    transform: scale(1.05) rotate(3deg);
  }

  .eq-icon {
    line-height: 1;
  }

  .eq-name {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--text-primary);
    line-height: 1.4;
  }

  .eq-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-white);
    background: linear-gradient(135deg, var(--yandex-red) 0%, var(--yandex-red-dark) 100%);
    border-radius: var(--radius-sm);
    box-shadow: 0 4px 12px var(--yandex-red-glow);
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    text-decoration: none;
    width: 100%;
  }

  .eq-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 16px var(--yandex-red-glow-heavy);
    filter: brightness(1.05);
  }

  .eq-btn-arrow {
    transition: transform 0.2s ease;
  }

  .eq-btn:hover .eq-btn-arrow {
    transform: translateX(3px);
  }

  /* Adaptive Horizontal layout for wide containers (>= 480px) */
  @container eq-container (min-width: 480px) {
    .eq-card {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 1.5rem;
      padding: 1rem 1.5rem;
    }

    .eq-info {
      flex: 1;
      min-width: 0;
    }

    .eq-btn {
      width: auto;
      flex-shrink: 0;
    }
  }
</style>
